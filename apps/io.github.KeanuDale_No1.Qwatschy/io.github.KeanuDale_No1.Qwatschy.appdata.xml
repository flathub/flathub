<component type="desktop-application">
  <id>io.github.KeanuDale_No1.Qwatschy</id>
  <name>Qwatschy</name>
  <summary>Cross-platform voice chat application</summary>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>MIT</project_license>
  <description>
    <p>
      Qwatschy is a modern voice chat application with real-time audio and text chat capabilities.
      Connect with friends and colleagues through intuitive voice channels and text messaging.
    </p>
    <p>Features:</p>
    <ul>
      <li>Real-time voice communication</li>
      <li>Text chat in channels</li>
      <li>Create and manage voice channels</li>
      <li>Cross-platform support (Windows, Linux, Web)</li>
      <li>Simple and intuitive user interface</li>
    </ul>
  </description>
