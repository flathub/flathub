{
  "app-id": "com.MarkJBobak.NimApp",
  "runtime": "org.freedesktop.Platform",
  "runtime-version": "24.08",
  "sdk": "org.freedesktop.Sdk",
  "command": "nim.py",
  "finish-args": [
    "--share=ipc",
    "--socket=wayland",
    "--socket=fallback-x11",
    "--socket=pulseaudio",
    "--device=dri"
  ],
  "modules": [
    {
      "name": "pygame",
      "buildsystem": "simple",
      "build-commands": [
        "python3 -m pip install --no-deps --prefix=/app pygame*.whl"
      ],
      "sources": [
        { "type": "dir", "path": "." }
      ]
    },
    {
      "name": "my-nim-app",
      "buildsystem": "simple",
      "build-commands": [
        "install -Dm755 nim /app/bin/nim",
        "install -Dm755 nim.py /app/bin/nim.py",
        "install -Dm644 com.MarkJBobak.NimApp.desktop /app/share/applications/com.MarkJBobak.NimApp.desktop",
        "install -Dm644 icon.svg /app/share/icons/hicolor/scalable/apps/com.MarkJBobak.NimApp.svg"
      ],
      "sources": [
        { "type": "dir", "path": "." }
      ]
    }
  ]
}
