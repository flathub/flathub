<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>com.github.IlyaP358.SaturnLauncher.GUI</id>
  
  <name>Saturn Launcher</name>
  <developer_name>IlyaP358</developer_name>
  <summary>A modern, lightweight Minecraft launcher</summary>
  
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>GPL-3.0-or-later</project_license>
  
  <description>
    <p>
      Saturn Launcher is a lightweight, open-source Minecraft launcher designed for performance and ease of use.
      It supports installing and running various Minecraft versions, including Vanilla, Forge, Fabric and all snapshots.
    </p>
    <ul>
      <li>Lightweight and fast</li>
      <li>Mod loader support (Forge, Fabric)</li>
      <li>Shaders loader support</li>
      <li>Instance management</li>
    </ul>
  </description>
  
  <launchable type="desktop-id">com.github.IlyaP358.SaturnLauncher.GUI.desktop</launchable>
  
  <screenshots>
    <screenshot type="default">
      <caption>Main Window</caption>
      <image>https://raw.githubusercontent.com/IlyaP358/saturn-web/main/flatpak_screens/main_windows.png</image>
    </screenshot>
    <screenshot>
      <caption>Instance Settings</caption>
      <image>https://raw.githubusercontent.com/IlyaP358/saturn-web/main/flatpak_screens/instance_settings.png</image>
    </screenshot>
  </screenshots>
  
  <url type="homepage">https://github.com/IlyaP358/SaturnLauncher</url>
  <url type="bugtracker">https://github.com/IlyaP358/SaturnLauncher/issues</url>
  
  <content_rating type="oars-1.1" />
  
  <releases>
    <release version="0.1.0" date="2026-01-22">
      <description>
        <p>Initial Flatpak release.</p>
      </description>
    </release>
  </releases>
</component>
