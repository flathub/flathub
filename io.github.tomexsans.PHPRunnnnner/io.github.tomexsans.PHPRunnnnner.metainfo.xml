<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>io.github.tomexsans.PHPRunnnnner</id>

  <name>PHPRunnnnner</name>
  <summary>Run and tinker with PHP code interactively</summary>

  <metadata_license>MIT</metadata_license>
  <project_license>MIT</project_license>

  <description>
    <p>
      PHPRunnnnner is a free, Tinkerwell-inspired PHP code runner built with Electron and Vue 3.
      It lets you quickly write and execute PHP snippets in a clean, distraction-free interface —
      perfect for testing ideas, debugging logic, or learning PHP on the fly.
    </p>
    <p>Features include:</p>
    <ul>
      <li>Multi-tab editor with persistent session restore</li>
      <li>Syntax highlighting powered by Monaco Editor</li>
      <li>Save and manage named code snippets</li>
      <li>Laravel project support via Artisan bootstrap</li>
      <li>SSH and local PHP connection profiles</li>
      <li>Structured dump output for arrays, objects, and collections</li>
      <li>Configurable PHP binary, font size, tab size, and word wrap</li>
    </ul>
  </description>

  <launchable type="desktop-id">io.github.tomexsans.PHPRunnnnner.desktop</launchable>

  <url type="homepage">https://github.com/tomexsans/phprunnnnner</url>
  <url type="bugtracker">https://github.com/tomexsans/phprunnnnner/issues</url>

  <developer id="io.github.tomexsans">
    <name>Tomexsans</name>
  </developer>

  <branding>
    <color type="primary" scheme_preference="dark">#1e1e2e</color>
    <color type="primary" scheme_preference="light">#cba6f7</color>
  </branding>

