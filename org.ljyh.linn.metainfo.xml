<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>org.ljyh.linn</id>

  <name>Linn</name>
  <summary>Third-party NetEase Cloud Music player</summary>
  <developer id="org.ljyh">
    <name>Ljyh</name>
  </developer>

  <description>
    <p>Linn is a lightweight GTK4/Adwaita music client for NetEase Cloud Music, built with Rust and Relm4.</p>
    <p>Features include playlist management, lyrics display, artist pages, album browsing, and collections.</p>
  </description>

  <launchable type="desktop-id">org.ljyh.linn.desktop</launchable>

  <categories>
    <category>AudioVideo</category>
    <category>Audio</category>
    <category>Player</category>
  </categories>

  <metadata_license>CC0-1.0</metadata_license>
  <project_license>GPL-3.0-or-later</project_license>

  <url type="homepage">https://github.com/ljyh/linn</url>
  <url type="bugtracker">https://github.com/ljyh/linn/issues</url>

  <releases>
    <release version="0.1.0" date="2026-04-28">
      <description>
        <p>Initial release.</p>
      </description>
    </release>
  </releases>

  <content_rating type="oars-1.1" />

  <requires>
    <display_length compare="ge">360</display_length>
  </requires>

  <recommends>
    <control>keyboard</control>
    <control>pointing</control>
    <control>touch</control>
  </recommends>

  <supports>
    <control>console</control>
  </supports>
</component>