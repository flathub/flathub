{
    "id": "org.kde.calindori",
    "runtime": "org.kde.Platform",
    "runtime-version": "6.10",
    "sdk": "org.kde.Sdk",
    "command": "calindori",
    "rename-icon": "calindori",
    "rename-appdata-file": "org.kde.calindori.appdata.xml",
    "finish-args": [
        "--device=dri",
        "--share=ipc",
        "--socket=fallback-x11",
        "--socket=wayland",
        "--share=network"
    ],
    "cleanup": [
        "/include",
        "/lib/cmake",
        "/share/qlogging-categories6"
    ],
    "modules": [
        {
            "name": "kpeople",
            "buildsystem": "cmake-ninja",
            "config-opts": [
                "-DBUILD_TESTING=OFF",
                "-DCMAKE_BUILD_TYPE=RelWithDebInfo"
            ],
            "builddir": true,
            "sources": [
                {
                    "type": "archive",
                    "url": "https://download.kde.org/stable/frameworks/6.24/kpeople-6.24.0.tar.xz",
                    "sha256": "d3e267753eb64c3bbba8e4af4a4503695ee62d015b30c2dad1a1f1343890fea4",
                    "x-checker-data": {
                        "type": "anitya",
                        "project-id": 8762,
                        "stable-only": true,
                        "url-template": "https://download.kde.org/stable/frameworks/$major.$minor/kpeople-$version.tar.xz"
                    }
                }
            ]
        },
        {
            "name": "org.kde.calindori",
            "buildsystem": "cmake-ninja",
            "config-opts": [
                "-DBUILD_TESTING=OFF",
                "-DCMAKE_BUILD_TYPE=RelWithDebInfo"
            ],
            "builddir": true,
            "sources": [
                {
                    "type": "archive",
                    "url": "https://download.kde.org/stable/release-service/25.12.3/src/calindori-25.12.3.tar.xz",
                    "sha256": "32e78ceabbf5a569ba3dca2cba84800b84afd2ff2a64c477dfeeb1cb366ee7e6",
                    "x-checker-data": {
                        "type": "anitya",
                        "project-id": 8763,
                        "stable-only": true,
                        "url-template": "https://download.kde.org/stable/release-service/$version/src/calindori-$version.tar.xz"
                    }
                },
                {
                    "type": "patch",
                    "path": "appdata-homepage.patch"
                }
            ]
        }
    ]
}
