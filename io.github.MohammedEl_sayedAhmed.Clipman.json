{
    "app-id": "io.github.MohammedEl_sayedAhmed.Clipman",
    "runtime": "org.gnome.Platform",
    "runtime-version": "47",
    "sdk": "org.gnome.Sdk",
    "command": "clipman",
    "finish-args": [
        "--share=ipc",
        "--socket=wayland",
        "--socket=fallback-x11",
        "--talk-name=org.gnome.Shell",
        "--talk-name=org.gnome.Shell.Extensions.clipman"
    ],
    "modules": [
        {
            "name": "wl-clipboard",
            "buildsystem": "meson",
            "config-opts": ["-Dfishcompletiondir=no"],
            "sources": [
                {
                    "type": "archive",
                    "url": "https://github.com/bugaevc/wl-clipboard/archive/refs/tags/v2.2.1.tar.gz",
                    "sha256": "6eb8081207fb5581d1d82c4bcd9587205a31a3d47bea3ebeb7f41aa1143783eb"
                }
            ]
        },
        {
            "name": "clipman",
            "buildsystem": "simple",
            "build-commands": [
                "install -d /app/share/clipman",
                "cp -r clipman/ /app/share/clipman/clipman/",
                "cp clipman.py /app/share/clipman/",
                "cp launcher.sh /app/share/clipman/",
                "chmod +x /app/share/clipman/launcher.sh",
                "sed -e 's/com.clipman.Clipman/io.github.MohammedEl_sayedAhmed.Clipman/g' -e 's|Exec=.*|Exec=clipman|' -e '/NoDisplay/d' data/com.clipman.Clipman.desktop > data/io.github.MohammedEl_sayedAhmed.Clipman.desktop",
                "install -Dm644 data/io.github.MohammedEl_sayedAhmed.Clipman.desktop /app/share/applications/io.github.MohammedEl_sayedAhmed.Clipman.desktop",
                "install -Dm644 data/com.clipman.Clipman.svg /app/share/icons/hicolor/scalable/apps/io.github.MohammedEl_sayedAhmed.Clipman.svg",
                "sed -e 's|<id>com.clipman.Clipman</id>|<id>io.github.MohammedEl_sayedAhmed.Clipman</id>|' -e 's|com.clipman.Clipman.desktop|io.github.MohammedEl_sayedAhmed.Clipman.desktop|' data/com.clipman.Clipman.metainfo.xml > data/io.github.MohammedEl_sayedAhmed.Clipman.metainfo.xml",
                "install -Dm644 data/io.github.MohammedEl_sayedAhmed.Clipman.metainfo.xml /app/share/metainfo/io.github.MohammedEl_sayedAhmed.Clipman.metainfo.xml",
                "install -d /app/bin",
                "echo '#!/bin/sh' > /app/bin/clipman",
                "echo 'exec python3 /app/share/clipman/clipman.py \"$@\"' >> /app/bin/clipman",
                "chmod +x /app/bin/clipman"
            ],
            "sources": [
                {
                    "type": "archive",
                    "url": "https://github.com/MohammedEl-sayedAhmed/clipman/archive/refs/tags/v1.0.1.tar.gz",
                    "sha256": "f603bbdfce7c2165fdef0cbba3c07db50c999a5a30eb8b182a29341d98b758a4"
                }
            ]
        }
    ]
}
