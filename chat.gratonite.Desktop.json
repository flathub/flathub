{
  "app-id": "chat.gratonite.Desktop",
  "base": "org.electronjs.Electron2.BaseApp",
  "base-version": "25.08",
  "runtime": "org.freedesktop.Platform",
  "runtime-version": "25.08",
  "sdk": "org.freedesktop.Sdk",
  "command": "chat.gratonite.Desktop",
  "separate-locales": false,
  "tags": [
    "proprietary"
  ],
  "finish-args": [
    "--share=ipc",
    "--socket=wayland",
    "--socket=x11",
    "--socket=pulseaudio",
    "--share=network",
    "--device=all",
    "--talk-name=org.freedesktop.ScreenSaver",
    "--filesystem=xdg-download",
    "--filesystem=xdg-pictures:ro",
    "--filesystem=xdg-videos:ro",
    "--filesystem=xdg-run/pipewire-0",
    "--filesystem=xdg-run/speech-dispatcher",
    "--talk-name=org.kde.StatusNotifierWatcher",
    "--talk-name=com.canonical.AppMenu.Registrar",
    "--talk-name=com.canonical.indicator.application",
    "--talk-name=com.canonical.Unity",
    "--system-talk-name=org.freedesktop.UPower",
    "--env=XCURSOR_PATH=/run/host/user-share/icons:/run/host/share/icons",
    "--env=ELECTRON_TRASH=gio"
  ],
  "modules": [
    {
      "name": "gratonite",
      "buildsystem": "simple",
      "build-commands": [
        "install -Dm755 gratonite.sh /app/bin/chat.gratonite.Desktop",
        "mkdir -p /app/gratonite",
        "cp -r gratonite-desktop locales resources *.pak *.so* *.bin *.dat *.json chrome* snapshot_blob.bin vk_swiftshader_icd.json LICENSE* LICENSES* /app/gratonite/ || true",
        "chmod 755 /app/gratonite/gratonite-desktop",
        "install -Dm644 chat.gratonite.Desktop.desktop /app/share/applications/chat.gratonite.Desktop.desktop",
        "install -Dm644 chat.gratonite.Desktop.svg /app/share/icons/hicolor/scalable/apps/chat.gratonite.Desktop.svg",
        "install -Dm644 chat.gratonite.Desktop.metainfo.xml /app/share/metainfo/chat.gratonite.Desktop.metainfo.xml"
      ],
      "post-install": [
        "desktop-file-edit --set-key=Exec --set-value='chat.gratonite.Desktop %U' /app/share/applications/chat.gratonite.Desktop.desktop",
        "desktop-file-edit --set-key=Icon --set-value=chat.gratonite.Desktop /app/share/applications/chat.gratonite.Desktop.desktop"
      ],
      "sources": [
        {
          "type": "archive",
          "dest-filename": "gratonite.tar.gz",
          "url": "https://gratonite.chat/downloads/gratonite-desktop-1.0.7.tar.gz",
          "sha256": "18f81f92fcbb5504d8d02a7d47d5564f6a77b734aaa524d8135ce5d5337c32ea",
          "strip-components": 1
        },
        {
          "type": "file",
          "path": "gratonite.sh"
        },
        {
          "type": "file",
          "path": "chat.gratonite.Desktop.desktop"
        },
        {
          "type": "file",
          "path": "chat.gratonite.Desktop.svg"
        },
        {
          "type": "file",
          "path": "chat.gratonite.Desktop.metainfo.xml"
        }
      ]
    }
  ]
}
