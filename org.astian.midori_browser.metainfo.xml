<component type="desktop-application">
  <id>org.astian.midori_browser</id>
  <name>Midori Browser</name>
  <summary>Web browser by Astian</summary>

  <metadata_license>CC0-1.0</metadata_license>
  <project_license>MPL-2.0</project_license>

  <developer id="org.astian">
    <name>Astian</name>
  </developer>

  <launchable type="desktop-id">org.astian.midori_browser.desktop</launchable>

  <url type="homepage">https://astian.org</url>
  <url type="bugtracker">https://github.com/goastian/midori-desktop/issues</url>
  <url type="vcs-browser">https://github.com/goastian/org.astian.midori_browser</url>

  <description>
    <p>
      Midori Browser is a web browser project maintained by Astian.
      This Flatpak package repackages the official Linux release archives
      published by the upstream project for desktop use.
    </p>
    <p>
      It provides a desktop-integrated package for Linux systems using Flatpak,
      while tracking official upstream releases from the Midori Desktop project.
    </p>
  </description>

  <categories>
    <category>Network</category>
    <category>WebBrowser</category>
  </categories>

