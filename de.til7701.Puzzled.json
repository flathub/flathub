{
  "id": "de.til7701.Puzzled",
  "runtime": "org.gnome.Platform",
  "runtime-version": "49",
  "sdk": "org.gnome.Sdk",
  "sdk-extensions": [
    "org.freedesktop.Sdk.Extension.rust-stable"
  ],
  "command": "puzzled",
  "finish-args": [
    "--share=ipc",
    "--socket=fallback-x11",
    "--device=dri",
    "--socket=wayland",
    "--env=RUST_LOG=Info"
  ],
  "build-options": {
    "append-path": "/usr/lib/sdk/rust-stable/bin",
    "env": {
      "RUST_BACKTRACE": "1",
      "RUST_LOG": "puzzled=debug"
    }
  },
  "cleanup": [
    "/include",
    "/lib/pkgconfig",
    "/man",
    "/share/doc",
    "/share/gtk-doc",
    "/share/man",
    "/share/pkgconfig",
    "*.la",
    "*.a"
  ],
  "modules": [
    {
      "name": "puzzled",
      "builddir": true,
      "buildsystem": "meson",
      "config-opts": [
        "--buildtype=release"
      ],
      "build-options": {
        "append-path": "/usr/lib/sdk/rust-stable/bin",
        "env": {
          "CARGO_NET_OFFLINE": "true"
        }
      },
      "sources": [
        {
          "type": "git",
          "url": "https://github.com/Til7701/Puzzled.git",
          "tag": "v1.0.0",
          "commit": "a4ab1e9fd579e9073f7122f5e6c8d285bc593814"
        },
        "cargo-sources.json",
        {
          "type": "shell",
          "commands": [
            "mkdir -p .cargo",
            "cp -vf cargo/config .cargo/config.toml"
          ]
        }
      ]
    }
  ]
}
