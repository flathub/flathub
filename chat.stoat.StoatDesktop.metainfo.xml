<component type="desktop">
  <id>chat.stoat.StoatDesktop</id>
  <launchable type="desktop-id">chat.stoat.StoatDesktop.desktop</launchable>
  <name>Stoat</name>
  <developer id="chat.stoat">
    <name>Revolt Platforms Ltd</name>
  </developer>
  <summary>The chat app where you are the main character</summary>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>AGPL-3.0</project_license>
  <icon type="remote" height="256" width="256">
    https://raw.githubusercontent.com/stoatchat/assets/3a0d29a0e7984e41afca1a0c945ffeac1e6dcd91/desktop/icon.png</icon>
  <description>
    <h2>Text channels,<br /> done right.</h2>
    <p>Attach images. 🐈 <a>@mention</a> users.<br />
      <a href="">Link</a> to websites. Welcome to the
      21st century.</p>
  </description>
  <screenshots>
    <screenshot type="default">
      <caption>Main window</caption>
      <image>https://raw.githubusercontent.com/tonur/flathub/260b032503232d7489d081eae007cc31088d6b12/screenshot.png</image>
    </screenshot>
  </screenshots>
  <releases>
    <release date="2025-12-29" version="1.1.12">
      <description>
        <p>Changes:</p>
        <ul>
          <li>Initial release (may have platform specific issues)</li>
          <li>Various fixes for the configs code.</li>
          <li>Build for macOS x86.</li>
          <li>Build for Linux arm64.</li>
        </ul>
        <p>Bug fixes:</p>
        <ul>
          <li>add NixOS compatibility for electron startup (#23) (3eb9b8e)</li>
          <li>correctly load badge count; expose to renderer (#25) (6817b55)</li>
          <li>event listener accumulation from rpc client (#26) (96fa8cc)</li>
          <li>macos: tray icon size (5eecab5)</li>
          <li>rpc should define largeImageText (#21) (cb373b6)</li>
          <li>use the correct argument for auto start (#22) (532af4a), closes #20</li>
        </ul>
      </description>
    </release>
		<release date="2024-11-06" version="1.0.8">
			<description>
				<p>Changes:</p>
				<ul>
					<li>Bumped Electron to version 33</li>
				</ul>
			</description>
		</release>
		<release date="2022-09-03" version="1.0.6">
			<description>
				<p>Bug fixes:</p>
				<ul>
					<li>fix: wrong app icon</li>
					<li>fix: correctly restore from tray icon on second instance start</li>
					<li>fix: restart from tray icon</li>
				</ul>
			</description>
		</release>
    <release date="2022-05-23" version="1.0.5">
      <description>
        <p>Bug fixes:</p>
        <ul>
          <li>fix: use getConfig() instead of store.getConfig to prevent error on quit.</li>
          <li>feat: use monochrome tray icon and fix tray icon on macOS.</li>
        </ul>
      </description>
    </release>
    <release date="2022-05-10" version="1.0.4">
      <description>
        <p>Small quality of life improvements and minor bug fixes:</p>
        <ul>
          <li>prevent launching multiple instances.</li>
          <li>add a tray icon.</li>
          <li>allow minimising the app to the tray.</li>
          <li>allow zooming in with "CTRL + =".</li>
          <li>artifact like shapes on start.</li>
          <li>add spell check</li>
          <li>bundle window icon correctly</li>
          <li>generate DMG rather than ZIP</li>
        </ul>
      </description>
    </release>
    <release date="2022-03-04" version="1.0.3">
      <description>
        <p>Bug fixes and clean up:</p>
        <ul>
          <li>Automate CI for publishing new releases.</li>
          <li>Fix AppX icons</li>
          <li>Update Discord RPC</li>
          <li>Change default settings</li>
        </ul>
      </description>
    </release>
    <release date="2021-08-11" version="1.0.2">
      <description>
        <p>Fixes auto-update</p>
      </description>
    </release>
  </releases>
  <url type="bugtracker">https://github.com/stoatchat/for-desktop/issues</url>
  <url type="homepage">https://stoat.chat</url>
  <url type="donation">https://wiki.revolt.chat/notes/project/financial-support</url>
  <url type="contact">https://support.stoat.chat/contact</url>
