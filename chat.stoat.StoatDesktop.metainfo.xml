<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop">
    <id>chat.stoat.StoatDesktop</id>
    <metadata_license>CC0-1.0</metadata_license>
    <project_license>AGPL-3.0</project_license>

    <name>Stoat</name>
    <summary>A modern chat app</summary>

    <developer id="chat.stoat">
        <name>Stoat Team</name>
    </developer>

    <url type="homepage">https://stoat.chat</url>
    <url type="vcs-browser">https://github.com/stoatchat/for-desktop</url>

    <description>
        <p>Stoat is a messaging platform that lets you join servers, participate in conversations, send direct messages, and share media.</p>
    </description>

    <screenshots>
        <screenshot type="default">
            <image>https://github.com/Racclyn/screenshots/raw/master/stoat.png</image>
            <caption>Main chat interface</caption>
        </screenshot>
    </screenshots>

    <launchable type="desktop-id">chat.stoat.StoatDesktop.desktop</launchable>

    <categories>
        <category>Network</category>
        <category>Chat</category>
    </categories>

    <releases>
        <release version="1.1.12" date="2025-12-29">
            <description>
                <p>Latest Stoat Desktop release.</p>
            </description>
        </release>
    </releases>

    <content_rating type="oars-1.1">
        <content_attribute id="social-chat">moderate</content_attribute>
        <content_attribute id="social-info">intense</content_attribute>
        <content_attribute id="social-audio">intense</content_attribute>
        <content_attribute id="social-contacts">intense</content_attribute>
    </content_rating>
</component>
