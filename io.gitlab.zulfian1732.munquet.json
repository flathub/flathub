{
    "app-id": "io.gitlab.zulfian1732.munquet",
    "runtime": "org.gnome.Platform",
    "runtime-version": "49",
    "sdk": "org.gnome.Sdk",
    "command": "munquet",
    "finish-args": [
        "--share=ipc",
        "--socket=wayland",
        "--socket=fallback-x11",
        "--device=dri"
    ],
    "cleanup": [
        "/include",
        "*.a",
        "/lib/cmake",
        "/lib/pkgconfig"
    ],
    "modules": [
        {
            "name": "boost",
            "buildsystem": "cmake-ninja",
            "builddir": true,
            "config-opts": [
                "-DBUILD_SHARED_LIBS=ON"
            ],
            "sources": [
                {
                    "type": "archive",
                    "url": "https://github.com/boostorg/boost/releases/download/boost-1.88.0/boost-1.88.0-cmake.tar.gz",
                    "sha256": "dcea50f40ba1ecfc448fdf886c0165cf3e525fef2c9e3e080b9804e8117b9694"
                }
            ],
            "cleanup": [
                "/share"
            ]
        },
        {
            "name": "rapidjson",
            "buildsystem": "cmake-ninja",
            "builddir": true,
            "config-opts": [
                "-DRAPIDJSON_BUILD_DOC=OFF",
                "-DRAPIDJSON_BUILD_EXAMPLES=OFF",
                "-DRAPIDJSON_BUILD_TESTS=OFF",
                "-DCMAKE_POLICY_VERSION_MINIMUM=3.5"
            ],
            "sources": [
                {
                    "type": "archive",
                    "url": "https://github.com/Tencent/rapidjson/archive/refs/tags/v1.1.0.tar.gz",
                    "sha256": "bf7ced29704a1e696fbccf2a2b4ea068e7774fa37f6d7dd4039d0787f8bed98e"
                },
                {
                    "type": "patch",
                    "path": "patch/rapidjson-fix-operator.patch"
                }
            ]
        },
        {
            "name": "snappy",
            "buildsystem": "cmake-ninja",
            "builddir": true,
            "config-opts": [
                "-DCMAKE_POSITION_INDEPENDENT_CODE=ON",
                "-DSNAPPY_BUILD_TESTS=OFF",
                "-DSNAPPY_BUILD_BENCHMARKS=OFF",
                "-DCMAKE_POLICY_VERSION_MINIMUM=3.5"
            ],
            "sources": [
                {
                    "type": "archive",
                    "url": "https://github.com/google/snappy/archive/refs/tags/1.1.10.tar.gz",
                    "sha256": "49d831bffcc5f3d01482340fe5af59852ca2fe76c3e05df0e67203ebbe0f1d90"
                }
            ]
        },
        {
            "name": "thrift",
            "buildsystem": "cmake-ninja",
            "builddir": true,
            "config-opts": [
                "-DBUILD_SHARED_LIBS=ON",
                "-DBUILD_TESTING=OFF",
                "-DWITH_OPENSSL=ON",
                "-DWITH_ZLIB=ON",
                "-DWITH_LIBEVENT=OFF",
                "-DWITH_C_GLIB=OFF",
                "-DWITH_JAVA=OFF",
                "-DWITH_PYTHON=OFF",
                "-DWITH_NODEJS=OFF",
                "-DWITH_JAVASCRIPT=OFF"
            ],
            "sources": [
                {
                    "type": "archive",
                    "url": "https://downloads.apache.org/thrift/0.22.0/thrift-0.22.0.tar.gz",
                    "sha256": "794a0e455787960d9f27ab92c38e34da27e8deeda7a5db0e59dc64a00df8a1e5"
                }
            ],
            "cleanup": [
                "/share"
            ]
        },
        {
            "name": "xsimd",
            "buildsystem": "cmake-ninja",
            "builddir": true,
            "config-opts": [
                "-DBUILD_TESTS=OFF"
            ],
            "sources": [
                {
                    "type": "archive",
                    "url": "https://github.com/xtensor-stack/xsimd/archive/refs/tags/14.0.0.tar.gz",
                    "sha256": "17de0236954955c10c09d6938d4c5f3a3b92d31be5dadd1d5d09fc1b15490dce"
                }
            ]
        },
        {
            "name": "arrow-cpp",
            "buildsystem": "cmake-ninja",
            "builddir": true,
            "subdir": "cpp",
            "config-opts": [
                "-DCMAKE_BUILD_TYPE=Release",
                "-DCMAKE_POSITION_INDEPENDENT_CODE=ON",
                
                "-DARROW_BUILD_SHARED=ON",
                "-DARROW_BUILD_TESTS=OFF",
                "-DARROW_BUILD_BENCHMARKS=OFF",
                "-DARROW_BUILD_EXAMPLES=OFF",
                "-DARROW_BUILD_INTEGRATION=OFF",
                "-DARROW_BUILD_UTILITIES=OFF",
                
                "-DARROW_CSV=ON",
                "-DARROW_FILESYSTEM=ON",
                "-DARROW_PARQUET=ON",
                "-DARROW_JSON=ON",
                "-DARROW_COMPUTE=ON",
                "-DARROW_DATASET=ON",
                
                "-DARROW_WITH_ZLIB=ON",
                "-DARROW_WITH_SNAPPY=ON",
                "-DARROW_WITH_ZSTD=OFF",
                "-DARROW_WITH_LZ4=OFF",
                "-DARROW_WITH_BROTLI=OFF",
                "-DARROW_WITH_RE2=OFF",
                "-DARROW_WITH_UTF8PROC=OFF",
                
                "-DARROW_MIMALLOC=OFF",
                
                "-DARROW_DEPENDENCY_SOURCE=SYSTEM",
                
                "-DARROW_SIMD_LEVEL=NONE",
                
                "-DCMAKE_POLICY_VERSION_MINIMUM=3.5"
            ],
            "sources": [
                {
                    "type": "archive",
                    "url": "https://downloads.apache.org/arrow/arrow-23.0.1/apache-arrow-23.0.1.tar.gz",
                    "sha256": "bd09adb4feac11fe49d1604f296618866702be610c86e2d513b561d877de6b18"
                }
            ]
        },
        {
            "name": "python3-meson_python",
            "buildsystem": "simple",
            "cleanup": ["*"],
            "build-commands": [
                "pip3 install --verbose --exists-action=i --no-index --find-links=\"file://${PWD}\" --prefix=${FLATPAK_DEST} \"meson_python==0.19.0\" --no-build-isolation"
            ],
            "sources": [
                {
                    "type": "file",
                    "url": "https://files.pythonhosted.org/packages/16/7f/d1b0c65b267a1463d752b324f11d3470e30889daefc4b9ec83029bfa30b5/meson_python-0.19.0-py3-none-any.whl",
                    "sha256": "67b5906c37404396d23c195e12c8825506074460d4a2e7083266b845d14f0298"
                },
                {
                    "type": "file",
                    "url": "https://files.pythonhosted.org/packages/1d/0b/da4851b1e2d9c40c9bd74c0abd94510a7d797da9ccde0a90e8953751ed4a/pyproject_metadata-0.11.0-py3-none-any.whl",
                    "sha256": "85bbecca8694e2c00f63b492c96921d6c228454057c88e7c352b2077fcaa4096"
                }
            ]
        },
        {
            "name": "python3-numpy",
            "buildsystem": "simple",
            "cleanup": ["*"],
            "build-commands": [
                "pip3 install --verbose --exists-action=i --no-index --find-links=\"file://${PWD}\" --prefix=${FLATPAK_DEST} \"numpy==2.4.2\" --no-build-isolation"
            ],
            "sources": [
                {
                    "type": "file",
                    "url": "https://files.pythonhosted.org/packages/57/fd/0005efbd0af48e55eb3c7208af93f2862d4b1a56cd78e84309a2d959208d/numpy-2.4.2.tar.gz",
                    "sha256": "659a6107e31a83c4e33f763942275fd278b21d095094044eb35569e86a21ddae"
                }
            ]
        },
        {
            "name": "python3-pyarrow",
            "buildsystem": "simple",
            "subdir": "python",
            "build-commands": [
                "pip3 install . --prefix=${FLATPAK_DEST} --no-deps --no-build-isolation"
            ],
            "sources": [
                {
                  "type": "archive",
                  "url": "https://downloads.apache.org/arrow/arrow-23.0.1/apache-arrow-23.0.1.tar.gz",
                  "sha256": "bd09adb4feac11fe49d1604f296618866702be610c86e2d513b561d877de6b18"
                }
            ]
        },
        {
            "name": "munquet",
            "buildsystem": "simple",
            "build-commands": [
                "pip3 install --no-build-isolation --prefix=${FLATPAK_DEST} ."
            ],
            "sources": [
                {
                    "type": "git",
                    "url": "https://gitlab.com/zulfian1732/munquet",
                    "tag": "v0.1.0",
                    "commit": "1dd5b8c88601d8289e8901dce993277b09bd2324"
                }
            ]
        }
    ]
}
