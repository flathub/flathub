<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>com.notepadmd.NotepadMD</id>
  <developer id="com.notepadmd">
    <name>NotepadMD</name>
  </developer>
  <name>NotepadMD</name>
  <summary>A modern cross-platform Markdown editor</summary>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>LicenseRef-proprietary=https://www.notepadmd.com/terms</project_license>

  <description>
    <p>
      NotepadMD is a feature-rich, cross-platform live block-based Markdown editor.
      It provides multiple open folder and file management, persistent sessions,
      custom themes, and import and export capabilities.
    </p>
    <p>Features include:</p>
    <ul>
      <li>Live Markdown preview with syntax highlighting</li>
      <li>Multi-tab editing with session persistence</li>
      <li>Folder browser with file tree navigation</li>
      <li>Multiple themes (Light, Dark, Midnight)</li>
      <li>Template based Docx, Google Docs, HTML and PDF export (Pro)</li>
      <li>Auto-update via Velopack</li>
    </ul>
  </description>

  <url type="homepage">https://www.notepadmd.com</url>

  <launchable type="desktop-id">com.notepadmd.NotepadMD.desktop</launchable>

  <content_rating type="oars-1.1" />

  <categories>
    <category>TextEditor</category>
    <category>Development</category>
    <category>Utility</category>
  </categories>

  <supports>
    <control>pointing</control>
    <control>keyboard</control>
  </supports>

  <screenshots>
    <screenshot type="default">
      <image>https://www.notepadmd.com/images/screenshots/1-live-markdown-editor/darktheme.png</image>
      <caption>NotepadMD Dark Theme</caption>
    </screenshot>
    <screenshot>
      <image>https://www.notepadmd.com/images/screenshots/1-live-markdown-editor/lighttheme.png</image>
      <caption>NotepadMD Light Theme</caption>
    </screenshot>
  </screenshots>

  <releases>
    <release version="1.3" date="2026-04-20">
      <url type="details">https://www.notepadmd.com/releases#version-1.3</url>
      <description>
        <p>NotepadMD 1.3 is a feature and platform release focused on a major code block overhaul, new editing workflows for block separators, copy and callouts, RTF paste support, stronger database encryption, and the first publicly distributed Linux builds.</p>
      </description>
    </release>
  </releases>

  <branding>
    <color type="primary" scheme_preference="light">#ffffff</color>
    <color type="primary" scheme_preference="dark">#1e1e1e</color>
  </branding>
</component>
