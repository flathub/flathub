<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>com.sona.app</id>
  <name>SONA</name>
  <summary>High Density Sonic Proto — music streaming</summary>
  <metadata_license>MIT</metadata_license>
  <project_license>MIT</project_license>

  <description>
    <p>
      SONA is a minimal monospace music streaming interface.
      Search and stream music, manage a queue, and control playback
      with a clean terminal-aesthetic UI.
    </p>
    <ul>
      <li>Stream music via JioSaavn API</li>
      <li>Search by track, artist or album</li>
      <li>Queue management with shuffle and repeat</li>
      <li>Oscilloscope audio visualizer</li>
      <li>User accounts with Supabase authentication</li>
      <li>320 kbps high quality streaming</li>
    </ul>
  </description>

  <launchable type="desktop-id">com.sona.app.desktop</launchable>

  <url type="homepage">https://hac8k26.github.io/sona</url>
  <url type="bugtracker">https://github.com/hac8k26/sona/issues</url>

  <screenshots>
    <screenshot type="default">
      <caption>SONA main streaming interface</caption>
      <image>https://hac8k26.github.io/sona/assets/screenshot.png</image>
    </screenshot>
  </screenshots>

  <releases>
    <release version="1.0.0" date="2026-03-26">
      <description><p>Initial release.</p></description>
    </release>
  </releases>

  <content_rating type="oars-1.1"/>

  <categories>
    <category>Audio</category>
    <category>Music</category>
  </categories>
</component>
