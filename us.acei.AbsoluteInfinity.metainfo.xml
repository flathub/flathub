<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
    <id>us.acei.AbsoluteInfinity</id>

    <name>Absolute Infinity</name>
    <summary>2D Space Trading &amp; Combat Game</summary>

    <developer id="us.acei">
        <name>Acei.us</name>
    </developer>
    <url type="homepage">https://acei.us/project-4</url>

    <metadata_license>CC-BY-SA-4.0</metadata_license>
    <project_license>LicenseRef-Proprietary</project_license>

    <description>
        <p>
            Absolute Infinity is a small handcrafted 2D space simulator. Embark on a journey through a galaxy filled with random encounters, simulated economies, and approximately 32 procedurally generated star systems.
        </p>
        <p>
            <em>Features</em>
        </p>
        <ul>
            <li>Own and pilot various ships</li>
            <li>Explore randomly generated star systems</li>
            <li>Trade and sell goods for money</li>
            <li>Craft new materials</li>
            <li>Ship to ship combat</li>
            <li>A short story about overcoming The Impasse</li>
        </ul>
    </description>

    <content_rating type="oars-1.1">
        <content_attribute id="violence-cartoon">moderate</content_attribute>
        <content_attribute id="violence-fantasy">moderate</content_attribute>
        <content_attribute id="drugs-narcotics">mild</content_attribute>
    </content_rating>

