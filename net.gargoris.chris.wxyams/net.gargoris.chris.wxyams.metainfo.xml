  <name>wxYam's</name>
  <name xml:lang="fr">wxYam's</name>
  <summary>Multiplayer dice game based on Yahtzee</summary>
  <summary xml:lang="fr">Jeu de dés multijoueur basé sur le Yam's</summary>

  <developer id="net.gargoris">
    <name>Gargoris</name>
  </developer>

  <description>
    <p>
      wxYam's is a multiplayer dice game based on the classic Yahtzee rules.
      Play solo against AI opponents of varying difficulty, or challenge your
      friends online in real-time duels.
    </p>
    <p xml:lang="fr">
      wxYam's est un jeu de dés multijoueur basé sur les règles classiques du Yam's.
      Jouez en solo contre des adversaires IA de difficulté variable, ou défiez vos
      amis en ligne dans des duels en temps réel.
    </p>
    <ul>
      <li>Solo mode with 5 AI difficulty levels</li>
      <li>Online multiplayer duels in real time</li>
      <li>Friends list and invitations</li>
      <li>Available on Android, Desktop, iOS and Web</li>
    </ul>
  </description>

  <launchable type="desktop-id">net.gargoris.chris.wxyams.desktop</launchable>

