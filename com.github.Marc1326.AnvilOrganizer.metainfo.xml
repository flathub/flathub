<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>com.github.Marc1326.AnvilOrganizer</id>
  <name>Anvil Organizer</name>
  <summary>Native Linux Mod Manager inspired by Mod Organizer 2</summary>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>GPL-3.0-or-later</project_license>

  <description>
    <p>
      Anvil Organizer is a native Linux mod manager for games like Skyrim,
      Fallout 4, Cyberpunk 2077, Baldur's Gate 3, Starfield, and more.
    </p>
    <p>
      Inspired by Mod Organizer 2, it features virtual file system deployment,
      profile management, Nexus Mods integration, drag-and-drop load ordering,
      and plugin conflict detection.
    </p>
  </description>

  <launchable type="desktop-id">com.github.Marc1326.AnvilOrganizer.desktop</launchable>

  <url type="homepage">https://anvil-organizer.net</url>
  <url type="bugtracker">https://github.com/Marc1326/Anvil-Organizer/issues</url>
  <url type="vcs-browser">https://github.com/Marc1326/Anvil-Organizer</url>

  <developer id="com.github.Marc1326">
    <name>Marc</name>
  </developer>

  <provides>
    <binary>anvil-organizer</binary>
  </provides>

  <content_rating type="oars-1.1" />

  <releases>
    <release version="1.2.1" date="2026-03-28">
      <description>
        <p>Plugin tab categories, Google Search Console, custom domain.</p>
      </description>
    </release>
  </releases>

  <categories>
    <category>Game</category>
    <category>Utility</category>
  </categories>

  <keywords>
    <keyword>mod</keyword>
    <keyword>modding</keyword>
    <keyword>gaming</keyword>
    <keyword>steam</keyword>
    <keyword>proton</keyword>
    <keyword>nexus</keyword>
  </keywords>
</component>
