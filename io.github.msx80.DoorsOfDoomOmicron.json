{
    "id": "io.github.msx80.DoorsOfDoomOmicron",
    "runtime": "org.freedesktop.Platform",
    "runtime-version": "25.08",
    "sdk": "org.freedesktop.Sdk",
    "command": "doorsofdoom",
    "separate-locales": false,
    "sdk-extensions": [
        "org.freedesktop.Sdk.Extension.openjdk21"
    ],
    "finish-args": [
        "--socket=x11",
        "--device=dri",
        "--share=ipc",
        "--socket=pulseaudio"
    ],
    "modules": [
        {
            "name": "openjdk",
            "buildsystem": "simple",
            "build-commands": [
                "/usr/lib/sdk/openjdk21/install.sh"
            ]
        },
        {
            "name": "doorsofdoom",
            "buildsystem": "simple",
            "build-commands": [
                "install -D doorsofdoom /app/bin/doorsofdoom",
                "install -D doorsofdoom-desktop.jar /app/share/doorsofdoom-desktop.jar",
                "install -Dm644 io.github.msx80.DoorsOfDoomOmicron.png /app/share/icons/hicolor/512x512/apps/io.github.msx80.DoorsOfDoomOmicron.png",
                "install -Dm644 io.github.msx80.DoorsOfDoomOmicron.desktop /app/share/applications/io.github.msx80.DoorsOfDoomOmicron.desktop",
                "install -Dm644 io.github.msx80.DoorsOfDoomOmicron.metainfo.xml /app/share/metainfo/io.github.msx80.DoorsOfDoomOmicron.metainfo.xml"
            ],
            "sources": [
                {
                    "type": "script",
                    "dest-filename": "doorsofdoom",
                    "commands": [
                        "exec /app/jre/bin/java -Duser.home=$XDG_DATA_HOME -jar /app/share/doorsofdoom-desktop.jar \"$@\""
                    ]
                },
                {
                    "type": "file",
                    "url": "https://github.com/msx80/DoorsOfDoomOmicron/releases/download/v0.0.9/doorsofdoom-desktop.jar",
                    "sha256": "8450415f587bd74946e37d6cafa11639d3bb97b70d45118ebd3033444deea6ce",
                    "dest-filename": "doorsofdoom-desktop.jar"
                },
                {
                    "type": "file",
                    "url": "https://raw.githubusercontent.com/msx80/DoorsOfDoomOmicron/refs/tags/v0.0.9/fastlane/metadata/android/en-US/images/icon.png",
                    "sha256": "9a4c31eaa3523d4b2604eae50acf5a63ca26016cfe61a3b0db5f77ec8e3e40fb",
                    "dest-filename": "io.github.msx80.DoorsOfDoomOmicron.png"
                },
                {
                    "type": "file",
                    "url": "https://raw.githubusercontent.com/msx80/DoorsOfDoomOmicron/4cb68f67e04d01b04557b670893d7e3b8122b827/flatpak/io.github.msx80.DoorsOfDoomOmicron.desktop",
                    "sha256": "005288597b09913f6db7bc49add9ba207291c812b6bba9b201589142363eb915"
                    
                },
		{
                    "type": "file",
                    "url": "https://raw.githubusercontent.com/msx80/DoorsOfDoomOmicron/4cb68f67e04d01b04557b670893d7e3b8122b827/flatpak/io.github.msx80.DoorsOfDoomOmicron.metainfo.xml",
                    "sha256": "72316b49cf4e15b8420c526caea5b7ed2db828269211bb7cbc068475736710b6"
                }  
            ]
        }
    ]
}
