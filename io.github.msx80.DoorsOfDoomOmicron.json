{
    "id": "io.github.msx80.DoorsOfDoomOmicron",
    "runtime": "org.freedesktop.Platform",
    "runtime-version": "25.08",
    "sdk": "org.freedesktop.Sdk",
    "command": "doorsofdoom",
    "separate-locales": false,
    "sdk-extensions": [
        "org.freedesktop.Sdk.Extension.openjdk21"
    ],
    "finish-args": [
        "--socket=x11",
        "--device=dri",
        "--share=ipc",
        "--socket=pulseaudio"
    ],
    "modules": [
        {
            "name": "openjdk",
            "buildsystem": "simple",
            "build-commands": [
                "/usr/lib/sdk/openjdk21/install.sh"
            ]
        },
        {
            "name": "doorsofdoom",
            "buildsystem": "simple",
            "build-commands": [
                "install -D doorsofdoom /app/bin/doorsofdoom",
                "install -D doorsofdoom-desktop.jar /app/share/doorsofdoom-desktop.jar",
                "install -Dm644 io.github.msx80.DoorsOfDoomOmicron.png /app/share/icons/hicolor/512x512/apps/io.github.msx80.DoorsOfDoomOmicron.png",
                "install -Dm644 io.github.msx80.DoorsOfDoomOmicron.desktop /app/share/applications/io.github.msx80.DoorsOfDoomOmicron.desktop",
                "install -Dm644 io.github.msx80.DoorsOfDoomOmicron.metainfo.xml /app/share/metainfo/io.github.msx80.DoorsOfDoomOmicron.metainfo.xml"
            ],
            "sources": [
                {
                    "type": "script",
                    "dest-filename": "doorsofdoom",
                    "commands": [
                        "exec /app/jre/bin/java -Duser.home=$XDG_DATA_HOME -jar /app/share/doorsofdoom-desktop.jar \"$@\""
                    ]
                },
                {
                    "type": "file",
                    "url": "https://github.com/msx80/DoorsOfDoomOmicron/releases/download/v0.0.9/doorsofdoom-desktop.jar",
                    "sha256": "8450415f587bd74946e37d6cafa11639d3bb97b70d45118ebd3033444deea6ce"
                },
                {
                    "type": "file",
                    "path": "io.github.msx80.DoorsOfDoomOmicron.png"
                },
                {
                    "type": "file",
                    "path": "io.github.msx80.DoorsOfDoomOmicron.desktop"
                },
		{
                    "type": "file",
                    "path": "io.github.msx80.DoorsOfDoomOmicron.metainfo.xml"
                }  
            ]
        }
    ]
}
