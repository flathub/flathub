<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>app.pikr.Pikr</id>
  <name>Pikr</name>
  <summary>Color picker with WCAG contrast checking</summary>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>LicenseRef-proprietary</project_license>
  <developer id="app.pikr">
    <name>Ricardo Dantas</name>
  </developer>
  <description>
    <p>
      Pikr is a beautiful color picker with built-in WCAG accessibility
      contrast checking. Pick colors from anywhere on your screen and
      ensure your designs are accessible to everyone.
    </p>
    <p>Features:</p>
    <ul>
      <li>Pick any color from your screen</li>
      <li>WCAG AA and AAA contrast checking</li>
      <li>Multiple color formats (Hex, RGB, HSL, HSB, LAB, OpenGL)</li>
      <li>Color history</li>
      <li>Auto-save between sessions</li>
    </ul>
  </description>
  <url type="homepage">https://getpikr.app</url>
  <url type="bugtracker">https://github.com/ricardodantas/pikr/issues</url>
  <launchable type="desktop-id">app.pikr.Pikr.desktop</launchable>
  <provides>
    <binary>pikr</binary>
  </provides>
  <branding>
    <color type="primary" scheme_preference="light">#f5c518</color>
    <color type="primary" scheme_preference="dark">#1a1a2e</color>
  </branding>
  <content_rating type="oars-1.1" />
  <releases>
    <release version="1.0.2" date="2026-02-17">
      <description>
        <p>Initial Flathub release</p>
      </description>
    </release>
  </releases>
  <screenshots>
    <screenshot type="default">
      <caption>Pikr main window with color picker and contrast checking</caption>
      <image type="source">https://getpikr.app/screenshots/pikr-main.png</image>
    </screenshot>
  </screenshots>
</component>
