{
  "app-id": "com.streamix.app",
  "runtime": "org.freedesktop.Platform",
  "runtime-version": "24.08",
  "sdk": "org.freedesktop.Sdk",
  "base": "org.electronjs.Electron2.BaseApp",
  "base-version": "24.08",
  "command": "streamix",
  "separate-locales": false,
  "finish-args": [
    "--share=ipc",
    "--device=dri",
    "--socket=wayland",
    "--socket=x11",
    "--socket=pulseaudio",
    "--share=network",
    "--filesystem=xdg-download"
  ],
  "modules": [
    {
      "name": "streamix",
      "buildsystem": "simple",
      "build-commands": [
        "cp -r * /app/main/",
        "install -D streamix.sh /app/bin/streamix",
        "install -D -m0644 com.streamix.app.desktop /app/share/applications/com.streamix.app.desktop",
        "install -D -m0644 com.streamix.app.metainfo.xml /app/share/metainfo/com.streamix.app.metainfo.xml",
        "install -D -m0644 icon.png /app/share/icons/hicolor/512x512/apps/com.streamix.app.png"
      ],
      "sources": [
        {
          "type": "archive",
          "url": "https://github.com/Zetsukae/streamix/releases/download/STABLE-Streamix-1.0.0-FLATHUB/streamix-1.0.0.tar.gz",
          "sha256": "7ad4cfec008f141d1a0eae307831f1de05cba11b6a89dd16a7838e6eaf100cd3"
        },
        {
          "type": "file",
          "url": "https://raw.githubusercontent.com/Zetsukae/streamix/main/assets/icon.png",
          "sha256": "4872d7e69e40ab0a5bfb2421b9215133b3302369ba6642a1c8c4be46fec496ac",
          "dest-filename": "icon.png"
        },
        {
          "type": "script",
          "dest-filename": "streamix.sh",
          "commands": [
            "exec zypak-wrapper /app/main/streamix \"$@\""
          ]
        },
        {
          "type": "file",
          "path": "com.streamix.app.desktop"
        },
        {
          "type": "file",
          "path": "com.streamix.app.metainfo.xml"
        }
      ]
    }
  ]
}
