{
  "app-id": "io.github.SimoneAncona.gtk4-battery-usage",
  "runtime": "org.gnome.Platform",
  "runtime-version": "49",
  "sdk": "org.gnome.Sdk",
  "command": "battery-usage",
  "finish-args": [
    "--share=ipc",
    "--socket=fallback-x11",
    "--socket=wayland",
    "--talk-name=org.freedesktop.UPower",
    "--system-talk-name=org.freedesktop.UPower"
  ],
  "modules": [
    {
      "name": "python3-dbus",
      "buildsystem": "meson",
      "sources": [
        {
          "type": "git",
          "url": "https://gitlab.freedesktop.org/dbus/dbus-python.git",
          "tag": "dbus-python-1.3.2"
        }
      ]
    },
    {
      "name": "battery-usage",
      "buildsystem": "simple",
      "build-commands": [
        "install -Dm755 main.py /app/bin/battery-usage",
        "install -Dm644 io.github.SimoneAncona.gtk4-battery-usage.desktop /app/share/applications/io.github.SimoneAncona.gtk4-battery-usage.desktop",
        "install -Dm644 io.github.SimoneAncona.gtk4-battery-usage.metainfo.xml /app/share/metainfo/io.github.SimoneAncona.gtk4-battery-usage.metainfo.xml",
        "install -Dm644 io.github.SimoneAncona.gtk4-battery-usage.svg /app/share/icons/hicolor/scalable/apps/io.github.SimoneAncona.gtk4-battery-usage.svg"
      ],
      "sources": [
        {
          "type": "dir",
          "path": "."
        }
      ]
    }
  ]
}
