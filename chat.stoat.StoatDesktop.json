{
  "app-id": "chat.stoat.StoatDesktop",
  "runtime": "org.freedesktop.Platform",
  "runtime-version": "25.08",
  "sdk": "org.freedesktop.Sdk",
  "base": "org.electronjs.Electron2.BaseApp",
  "base-version": "25.08",
  "command": "stoat-desktop",
  "separate-locales": false,

  "finish-args": [
    "--share=ipc",
    "--socket=wayland",
    "--socket=fallback-x11",
    "--socket=pulseaudio",
    "--share=network",
    "--device=dri",
    "--device=shm",
    "--talk-name=org.kde.StatusNotifierWatcher",
    "--env=XCURSOR_PATH=/run/host/user-share/icons:/run/host/share/icons"
  ],

  "modules": [
    {
      "name": "stoat",
      "buildsystem": "simple",

      "build-commands": [
        "cp -a stoat-desktop /app/",
        "install -Dm775 stoat-StoatDesktop.sh /app/bin/stoat-desktop",
        "install -D chat.stoat.StoatDesktop.desktop -t /app/share/applications/",
        "install -D chat.stoat.StoatDesktop.metainfo.xml -t /app/share/metainfo/",
        "install -D chat.stoat.StoatDesktop.png /app/share/icons/hicolor/256x256/apps/chat.stoat.StoatDesktop.png"
      ],

      "sources": [
        {
          "type": "archive",
          "url": "https://github.com/stoatchat/for-desktop/releases/download/v1.1.12/Stoat-linux-x64-1.1.12.zip",
          "sha256": "eabbdb9a84867669725d84bb1b7884ea752e2f82076c34ca5a249e6c0557ab6f",
          "dest": "stoat-desktop",
          "only-arches": ["x86_64"]
        },
        {
          "type": "archive",
          "url": "https://github.com/stoatchat/for-desktop/releases/download/v1.1.12/Stoat-linux-arm64-1.1.12.zip",
          "sha256": "d5fd93f977abd813e6855756d814ad29b10f6255cd813f34565bf31aa83343c4",
          "dest": "stoat-desktop",
          "only-arches": ["aarch64"]
        },
        {
          "type": "file",
          "path": "stoat-StoatDesktop.sh",
          "dest-filename": "stoat-StoatDesktop.sh"
        },
        {
          "type": "file",
          "path": "chat.stoat.StoatDesktop.desktop"
        },
        {
          "type": "file",
          "path": "chat.stoat.StoatDesktop.metainfo.xml"
        },
        {
          "type": "file",
          "url": "https://raw.githubusercontent.com/stoatchat/assets/f106946659af67ad4f008588ac51570029b2fd47/desktop/icon.png",
          "sha256": "5bef7f10d4090cf8eb99d66de47f708557d4c21c66f3c7ff80c8ba82165884c6",
          "dest-filename": "chat.stoat.StoatDesktop.png"
        }
      ]
    }
  ]
}
