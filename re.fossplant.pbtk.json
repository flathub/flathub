                },
                {
                    "type": "file",
                    "url": "https://files.pythonhosted.org/packages/13/69/33ddede1939fdd074bce5434295f38fae7136463422fe4fd3e0e89b98062/charset_normalizer-3.4.4.tar.gz",
                    "sha256": "94537985111c35f28720e43603b8e7b43a6ecfb2ce1d3058bbe955b73404e21a"
                },
                {
                    "type": "file",
                    "url": "https://files.pythonhosted.org/packages/0e/61/66938bbb5fc52dbdf84594873d5b51fb1f7c7794e9c0f5bd885f30bc507b/idna-3.11-py3-none-any.whl",
                    "sha256": "771a87f49d9defaf64091e6e6fe9c18d4833f140bd19464795bc32d966ca37ea"
                },
                {
                    "type": "file",
                    "url": "https://files.pythonhosted.org/packages/16/df/90e09253b321a37e315b08f4bcd7dcc68a5f9a45f58e909ba0cf5847ddbc/pbtk-1.0.8-py3-none-any.whl",
                    "sha256": "8164435e84cf864d0b693ef8435f4e63b9c2a27755168b1fc84a62564f85e4ba"
                },
                {
                    "type": "file",
                    "url": "https://files.pythonhosted.org/packages/ba/25/7c72c307aafc96fa87062aa6291d9f7c94836e43214d43722e86037aac02/protobuf-6.33.5.tar.gz",
                    "sha256": "6ddcac2a081f8b7b9642c09406bc6a4290128fce5f471cddd165960bb9119e5c"
                },
                {
                    "type": "file",
                    "url": "https://files.pythonhosted.org/packages/1e/db/4254e3eabe8020b458f1a747140d32277ec7a271daf1d235b70dc0b4e6e3/requests-2.32.5-py3-none-any.whl",
