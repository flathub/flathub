                }
            ]
        },
        {
            "name": "openjdk",
            "buildsystem": "simple",
            "build-commands": [
                "/usr/lib/sdk/openjdk8/install.sh"
            ]
        },
        {
            "name": "pbtk",
            "buildsystem": "simple",
            "build-commands": [
                "install -Dm644 ./packaging/assets/re.fossplant.pbtk.svg -t /app/share/icons/hicolor/scalable/apps/",
                "install -Dm644 ./packaging/assets/re.fossplant.pbtk.metainfo.xml -t /app/share/metainfo/",
                "install -Dm644 ./packaging/assets/re.fossplant.pbtk.desktop -t /app/share/applications/"
            ],
            "sources": [
                {
                    "type": "git",
                    "url": "https://github.com/marin-m/pbtk.git",
