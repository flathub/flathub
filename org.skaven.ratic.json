{
  "id": "org.skaven.ratic",
  "runtime": "org.gnome.Platform",
  "runtime-version": "49",
  "sdk": "org.gnome.Sdk",
  "sdk-extensions" : [
    "org.freedesktop.Sdk.Extension.rust-nightly"
  ],
  "command": "ratic",
  "finish-args": [
    "--share=ipc",
    "--socket=fallback-x11",
    "--socket=wayland",
    "--socket=pulseaudio",
    "--filesystem=xdg-music:ro"
  ],
  "cleanup" : [
    "/include",
    "/lib/pkgconfig",
    "/man",
    "/share/doc",
    "/share/gtk-doc",
    "/share/man",
    "/share/pkgconfig",
    "*.la",
    "*.a"
],
  "modules": [
    {
      "name": "ratic",
      "buildsystem": "simple",
      "build-options": {
        "append-path": "/usr/lib/sdk/rust-nightly/bin",
        "env": {
          "CARGO_HOME": "/run/build/ratic/cargo",
          "CARGO_NET_OFFLINE": "true",
          "RUST_BACKTRACE": "1",
          "RUST_LOG": "ratic=info"
        }
      },
      "build-commands": [
        "cargo --offline fetch --manifest-path Cargo.toml --verbose",
        "cargo build --offline --release --all-features",
        "install -Dm0755 target/release/ratic ${FLATPAK_DEST}/bin/ratic",
        "install -Dm0644 target/share/glib-2.0/schemas/gschemas.compiled ${FLATPAK_DEST}/share/glib-2.0/schemas/gschemas.compiled",
        "install -Dm0644 data/icons/hicolor/scalable/apps/logo.svg ${FLATPAK_DEST}/share/icons/hicolor/scalable/apps/${FLATPAK_ID}.svg",
        "install -Dm0644 data/icons/hicolor/scalable/apps/logo_black.svg ${FLATPAK_DEST}/share/icons/hicolor/symbolic/apps/${FLATPAK_ID}_black.svg",
        "install -Dm0644 data/org.skaven.ratic.desktop ${FLATPAK_DEST}/share/applications/${FLATPAK_ID}.desktop",
        "install -Dm0644 data/org.skaven.ratic.service ${FLATPAK_DEST}/share/dbus-1/services/${FLATPAK_ID}.service",
        "install -Dm0644 data/org.skaven.ratic.metainfo.xml ${FLATPAK_DEST}/share/metainfo/${FLATPAK_ID}.metainfo.xml"        
      ],
      "sources": [
        {
          "type": "git",
          "url": "https://gitlab.gnome.org/RatCornu/ratic.git",
          "tag": "v0.1.2",
          "commit": "49d6b9faa8be86e052baad2c92e09fbd2174f0e3"
        },
        "cargo-sources.json"
      ]
    }
  ]
}
