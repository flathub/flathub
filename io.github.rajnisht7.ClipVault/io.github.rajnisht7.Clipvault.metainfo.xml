<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">

  <id>io.github.rajnisht7.ClipVault</id>

  <name>ClipVault</name>

  <summary>Clipboard History Manager</summary>

  <metadata_license>CC0-1.0</metadata_license>

  <project_license>GPL-3.0-or-later</project_license>

  <description>
    <p>
      ClipVault is a modern clipboard history manager for Linux.
      It allows you to search your clipboard history, pin important clips,
      and supports both text and image entries.
    </p>

    <ul>
      <li>Instantly search clipboard history</li>
      <li>Supports both text and image clips</li>
      <li>Pin important clips so they are never lost</li>
      <li>Clean GTK4 and libadwaita interface</li>
    </ul>
  </description>

  <launchable type="desktop-id">
    io.github.rajnisht7.ClipVault.desktop
  </launchable>

  <url type="homepage">
    https://github.com/rajnisht7/clipvault
  </url>

  <url type="bugtracker">
    https://github.com/rajnisht7/clipvault/issues
  </url>

  <releases>
    <release version="1.0.0" date="2026-03-06">
      <description>
        <p>Initial release of ClipVault.</p>
      </description>
    </release>
  </releases>

