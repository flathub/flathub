<?xml version="1.0" encoding="UTF-8"?>
<mime-info xmlns="http://www.freedesktop.org/standards/shared-mime-info">
   <mime-type type="application/x-aloxbook">
      <comment>AloxBook Database</comment>
      <glob pattern="*.aloxbook" />
      <!-- generic-icon uses app-ID prefix so Flatpak will export it to the host.
           File managers fall back to this when no icon named "application-x-aloxbook" exists. -->
      <generic-icon name="com.aloxbook.AloxBook-x-aloxbook" />
   </mime-type>
</mime-info>
