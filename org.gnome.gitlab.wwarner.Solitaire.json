{
    "id": "org.gnome.gitlab.wwarner.Solitaire",
    "runtime": "org.gnome.Platform",
    "runtime-version": "49",
    "sdk": "org.gnome.Sdk",
    "sdk-extensions": [
        "org.freedesktop.Sdk.Extension.rust-stable"
    ],
    "command": "solitaire",
    "finish-args": [
        "--share=ipc",
        "--socket=fallback-x11",
        "--device=dri",
        "--socket=wayland"
    ],
    "build-options": {
        "append-path": "/usr/lib/sdk/rust-stable/bin"
    },
    "cleanup": [
        "/include",
        "/lib/pkgconfig",
        "/man",
        "/share/doc",
        "/share/gtk-doc",
        "/share/man",
        "/share/pkgconfig",
        "*.la",
        "*.a"
    ],
    "modules": [
        {
            "name": "solitaire",
            "buildsystem": "meson",
            "sources": [
                {
                    "type": "git",
                    "url": "https://gitlab.gnome.org/wwarner/solitaire.git",
                    "commit": "29276537282966eaff321944be445a52ca0f9f12"
                },
                "solitaire-cargo-sources.json",
                {
                    "type" : "shell",
                    "commands" : [
                        "mkdir .cargo",
                        "cat cargo/config >> .cargo/config.toml",
                        "cat .cargo/config.toml"
                    ]
                }
            ]
        }
    ]
}
