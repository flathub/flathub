{
    "id": "org.gnome.gitlab.wwarner.Solitaire",
    "runtime": "org.gnome.Platform",
    "runtime-version": "50",
    "sdk": "org.gnome.Sdk",
    "sdk-extensions": [
        "org.freedesktop.Sdk.Extension.rust-stable"
    ],
    "command": "solitaire",
    "finish-args": [
        "--share=ipc",
        "--socket=fallback-x11",
        "--device=dri",
        "--socket=wayland"
    ],
    "build-options": {
        "append-path": "/usr/lib/sdk/rust-stable/bin"
    },
    "modules": [
        {
            "name": "solitaire",
            "buildsystem": "meson",
            "config-opts": [
                "--buildtype=release"
            ],
            "sources": [
                {
                    "type": "git",
                    "url": "https://gitlab.gnome.org/wwarner/Solitaire.git",
                    "tag": "50.rc.1",
                    "commit": "20c216fbb4a1188707445982971e3d68b878153e"
                },
                "solitaire-cargo-sources.json",
                {
                    "type" : "shell",
                    "commands" : [
                        "mkdir .cargo",
                        "cat cargo/config >> .cargo/config.toml",
                        "cat .cargo/config.toml"
                    ]
                }
            ]
        }
    ]
}
