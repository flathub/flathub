{
    "app-id": "com.cassidyjames.dippi",
    "runtime": "org.gnome.Platform",
    "runtime-version": "49",
    "sdk": "org.gnome.Sdk",
    "command": "com.cassidyjames.dippi",
    "finish-args": [
        "--share=ipc",
        "--socket=fallback-x11",
        "--socket=wayland",
        "--device=dri"
    ],
    "modules": [
        {
            "name": "dippi",
            "buildsystem": "meson",
            "config-opts": [
                "--buildtype=release"
            ],
            "sources": [
                {
                    "type": "git",
                    "url": "https://github.com/cassidyjames/dippi.git",
                    "tag": "5.0.0",
                    "commit": "1d883ba3c7d6b6f7cb6f0464471bdb4671078b89",
                    "x-checker-data": {
                        "type": "git",
                        "tag-pattern": "^([\\d.]+)$"
                    }
                }
            ]
        }
    ]
}
