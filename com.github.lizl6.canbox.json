{
  "app-id": "com.github.lizl6.canbox",
  "runtime": "org.freedesktop.Platform",
  "runtime-version": "25.08",
  "sdk": "org.freedesktop.Sdk",
  "command": "canbox-launcher",
  "finish-args": [
    "--share=ipc",
    "--socket=x11",
    "--socket=wayland",
    "--share=network",
    "--device=dri",
    "--filesystem=home",
    "--filesystem=xdg-documents",
    "--filesystem=xdg-download",
    "--talk-name=org.freedesktop.Notifications",
    "--own-name=com.github.lizl6.canbox"
  ],
  "modules": [
    {
      "name": "canbox",
      "buildsystem": "simple",
      "sources": [
        {
          "type": "archive",
          "url": "https://github.com/rexlevin/canbox-flatpak/releases/download/0.1.0/canbox-linux-x64-0.1.0.tar.gz",
          "sha256": "bfeb722a38e47f71ffe0fdc677fd70bf9c66c84080bc76f99d4745d0632834a3",
          "dest": "canbox-src"
        },
        {
          "type": "file",
          "url": "https://raw.githubusercontent.com/rexlevin/canbox-flatpak/0.1.0/logo_512x512.png",
          "sha256": "976f30f23100b4cb45e399e28c2e5a57ee72348c1db3dab7a88349b85d06f69c",
          "dest-filename": "logo_512x512.png"
        },
        {
          "type": "file",
          "url": "https://raw.githubusercontent.com/rexlevin/canbox-flatpak/0.1.0/logo_256x256.png",
          "sha256": "d3091550c109ec66678c2b185605972a1caf2f60aebdef88a22d3bbff8f16768",
          "dest-filename": "logo_256x256.png"
        },
        {
          "type": "file",
          "url": "https://raw.githubusercontent.com/rexlevin/canbox-flatpak/0.1.0/logo_128x128.png",
          "sha256": "8e76af5b17129858a0b7ebf143d7f4245d1f0d006146e744555fa7e70af429aa",
          "dest-filename": "logo_128x128.png"
        }
      ],
      "build-commands": [
        "mkdir -p /app/bin",
        "printf '#!/bin/bash\\nexec /app/bin/canbox --no-sandbox \"$@\"\\n' > /app/bin/canbox-launcher",
        "chmod +x /app/bin/canbox-launcher",
        "install -Dm755 canbox-src/canbox /app/bin/canbox",
        "install -Dm755 canbox-src/chrome_crashpad_handler /app/bin/",
        "install -Dm755 canbox-src/chrome-sandbox /app/bin/",
        "cp -r canbox-src/resources /app/bin/",
        "cp -r canbox-src/locales /app/bin/",
        "cp canbox-src/*.pak /app/bin/ 2>/dev/null || true",
        "cp canbox-src/*.dat /app/bin/ 2>/dev/null || true",
        "cp canbox-src/*.bin /app/bin/ 2>/dev/null || true",
        "cp canbox-src/*.so* /app/bin/ 2>/dev/null || true",
        "cp canbox-src/*.json /app/bin/ 2>/dev/null || true",
        "cp canbox-src/*.html /app/bin/ 2>/dev/null || true",
        "mkdir -p /app/share/icons/hicolor/512x512/apps",
        "mkdir -p /app/share/icons/hicolor/256x256/apps",
        "mkdir -p /app/share/icons/hicolor/128x128/apps",
        "install -Dm644 logo_512x512.png /app/share/icons/hicolor/512x512/apps/com.github.lizl6.canbox.png",
        "install -Dm644 logo_256x256.png /app/share/icons/hicolor/256x256/apps/com.github.lizl6.canbox.png",
        "install -Dm644 logo_128x128.png /app/share/icons/hicolor/128x128/apps/com.github.lizl6.canbox.png",
        "mkdir -p /app/share/applications",
        "printf '[Desktop Entry]\\nVersion=1.0\\nType=Application\\nName=Canbox\\nGenericName=Application Management Tool\\nComment=Some useful apps you need for your life\\nExec=canbox-launcher\\nIcon=com.github.lizl6.canbox\\nCategories=Utility;System\\nTerminal=false\\nStartupWMClass=canbox\\nMimeType=\\n' > com.github.lizl6.canbox.desktop",
        "install -Dm644 com.github.lizl6.canbox.desktop /app/share/applications/com.github.lizl6.canbox.desktop",
        "rm -f com.github.lizl6.canbox.desktop",
        "rm -rf canbox-src"
      ]
    }
  ]
}
