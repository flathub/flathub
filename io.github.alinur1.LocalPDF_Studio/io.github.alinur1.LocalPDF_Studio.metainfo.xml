<component type="desktop-application">
  <id>io.github.alinur1.LocalPDF_Studio</id>
  <name>LocalPDF Studio</name>
  <summary>Offline, open-source, privacy-first PDF toolkit</summary>
  <description>
    <p>LocalPDF Studio is a free, open-source, privacy-first PDF toolkit built to work 100% offline — no document uploads, no cloud required. Whether you’re merging PDFs, splitting large files, extracting images, adding watermarks, or locking/unlocking documents, this tool gives you full control — without compromising your privacy.</p>
  </description>
