{
  "app-id": "com.openstickies.OpenStickies",
  "runtime": "org.freedesktop.Platform",
  "runtime-version": "24.08",
  "sdk": "org.freedesktop.Sdk",
  "command": "openstickies",
  "finish-args": [
    "--share=ipc",
    "--socket=x11",
    "--device=dri",
    "--talk-name=org.freedesktop.Notifications",
    "--talk-name=org.kde.StatusNotifierWatcher",
    "--filesystem=xdg-documents:ro",
    "--filesystem=xdg-pictures:ro"
  ],
  "modules": [
    {
      "name": "openstickies",
      "buildsystem": "simple",
      "build-commands": [
        "install -Dm755 apply_extra /app/bin/apply_extra",
        "install -Dm755 openstickies-wrapper /app/bin/openstickies",
        "install -Dm644 com.openstickies.OpenStickies.desktop /app/share/applications/com.openstickies.OpenStickies.desktop",
        "install -Dm644 com.openstickies.OpenStickies.metainfo.xml /app/share/metainfo/com.openstickies.OpenStickies.metainfo.xml",
        "install -Dm644 icons/icon-256.png /app/share/icons/hicolor/256x256/apps/com.openstickies.OpenStickies.png",
        "install -Dm644 icons/icon-128.png /app/share/icons/hicolor/128x128/apps/com.openstickies.OpenStickies.png",
        "install -Dm644 icons/icon-64.png /app/share/icons/hicolor/64x64/apps/com.openstickies.OpenStickies.png"
      ],
      "sources": [
        {
          "type": "extra-data",
          "filename": "OpenStickies.tar.gz",
          "url": "https://github.com/HimaSphere/OpenStickies/releases/download/v2.8.0/OpenStickies_Free_2.8.0-x86_64.tar.gz",
          "sha256": "a5dd34e4278c49e36ce90e1017621b2e3a246f5de7d4d7b5981a2366bc9de778",
          "size": 77783597,
          "x-checker-data": {
            "type": "json",
            "url": "https://api.github.com/repos/HimaSphere/OpenStickies/releases/latest",
            "version-query": ".tag_name | sub(\"^v\"; \"\")",
            "url-query": ".assets[] | select(.name | test(\"Free.*x86_64.tar.gz$\")) | .browser_download_url"
          }
        },
        {
          "type": "script",
          "dest-filename": "apply_extra",
          "commands": [
            "mkdir -p openstickies",
            "tar xf OpenStickies.tar.gz -C openstickies",
            "rm -f OpenStickies.tar.gz"
          ]
        },
        {
          "type": "script",
          "dest-filename": "openstickies-wrapper",
          "commands": [
            "export QT_QPA_PLATFORM=xcb",
            "export QT_IM_MODULE=ibus",
            "exec /app/extra/openstickies/AppRun \"$@\""
          ]
        },
        {
          "type": "file",
          "path": "com.openstickies.OpenStickies.desktop"
        },
        {
          "type": "file",
          "path": "com.openstickies.OpenStickies.metainfo.xml"
        },
        {
          "type": "file",
          "path": "icons/icon-256.png",
          "dest": "icons"
        },
        {
          "type": "file",
          "path": "icons/icon-128.png",
          "dest": "icons"
        },
        {
          "type": "file",
          "path": "icons/icon-64.png",
          "dest": "icons"
        }
      ]
    }
  ]
}