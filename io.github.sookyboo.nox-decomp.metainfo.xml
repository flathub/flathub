<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
    <id>io.github.sookyboo.nox-decomp</id>

    <name>Nox-Decomp</name>
    <summary>Comment=Source Port of Nox (2000) to Linux with hi-res scaling, gamepad support, and LAN/Internet multiplayer (original game data required)</summary>

    <metadata_license>CC0-1.0</metadata_license>
    <project_license>Unlicense</project_license>

    <developer id="io.github.sookyboo">
        <name>sookyboo</name>
    </developer>

    <launchable type="desktop-id">io.github.sookyboo.nox-decomp.desktop</launchable>

    <description>
        <p>
            Nox-Decomp is a source port of the classic action RPG <em>Nox</em> (2000).
        </p>
        <p>
            <strong>This package does not ship any Nox game assets.</strong>
            You must own a legitimate copy of Nox (for example the GOG installer) and provide the installer/data files yourself.
            For automatic extraction place GOG installer matching 'setup_nox*.exe' in your home directory in ~/nox-decomp/gamefiles/.
            Or manually provide extracted files so this exists: ~/nox-decomp/gamefiles/app/gamedata.bin
        </p>
        <p>Features include:</p>
        <ul>
            <li>Fully completable single-player campaigns for all classes (warrior, wizard, conjurer).</li>
            <li>Multiplayer over LAN and Internet (via OpenNox lobby servers).</li>
            <li>Built-in gamepad support and automatic scaling to your device’s native resolution.</li>
            <li>Works well on Steam Deck (Flatpak) and lightweight ARM Linux handhelds (PortMaster) and Windows.</li>
        </ul>
    </description>

    <provides>
        <binary>noxd.i386</binary>
        <binary>start.sh</binary>
    </provides>

    <categories>
        <category>Game</category>
        <category>RolePlaying</category>
        <category>ActionGame</category>
    </categories>

    <keywords>
        <keyword>Nox</keyword>
        <keyword>RPG</keyword>
        <keyword>Action RPG</keyword>
        <keyword>LAN</keyword>
        <keyword>Multiplayer</keyword>
