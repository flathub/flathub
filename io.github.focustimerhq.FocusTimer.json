{
  "app-id": "io.github.focustimerhq.FocusTimer",
  "runtime": "org.gnome.Platform",
  "runtime-version": "49",
  "sdk": "org.gnome.Sdk",
  "command": "focus-timer",
  "finish-args": [
    "--device=dri",
    "--share=ipc",
    "--socket=fallback-x11",
    "--socket=wayland",
    "--socket=pulseaudio",
    "--system-talk-name=org.freedesktop.login1",
    "--system-talk-name=org.freedesktop.timedate1",
    "--talk-name=org.freedesktop.Notifications",
    "--talk-name=org.freedesktop.ScreenSaver",
    "--talk-name=org.gnome.Mutter.IdleMonitor",
    "--talk-name=org.gnome.ScreenSaver",
    "--talk-name=org.gnome.Shell"
  ],
  "cleanup": [
    "/include",
    "/lib/girepository-1.0",
    "/lib/pkgconfig",
    "/man",
    "/share/aclocal",
    "/share/doc",
    "/share/gir-1.0",
    "/share/gtk-doc",
    "/share/pkgconfig",
    "/share/man",
    "/share/vala",
    "*.la",
    "*.a"
  ],
  "modules": [
    {
      "name": "libpeas",
      "buildsystem": "meson",
      "builddir": true,
      "config-opts": [
        "-Dgjs=false",
        "-Dlua51=false",
        "-Dpython3=false",
        "-Dintrospection=true",
        "-Dvapi=true"
      ],
      "sources": [
        {
          "type": "git",
          "url": "https://gitlab.gnome.org/GNOME/libpeas.git",
          "tag": "2.2.0",
          "commit": "39a2b9c55deaa5246b99b502b53896d3ad41846b"
        }
      ]
    },
    {
      "name": "gom",
      "buildsystem": "meson",
      "builddir": true,
      "sources": [
        {
          "type": "git",
          "url": "https://gitlab.gnome.org/GNOME/gom.git",
          "tag": "0.5.5",
          "commit": "0dbeaa81f83ca230d9240be0ff704dc0865a0f1f"
        }
      ]
    },
    {
      "name": "focus-timer",
      "buildsystem": "meson",
      "builddir": true,
      "config-opts": [
        "-Dprofile=default",
        "-Dautomation=disabled",
        "--buildtype",
        "release"
      ],
      "sources": [
        {
          "type": "git",
          "url": "https://github.com/focustimerhq/FocusTimer.git",
          "tag": "1.0",
          "commit": "75781eda5a5a686980bcedc8bbd407d6cae914ca"
        }
      ]
    }
  ]
}
