<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>app.tuneline.Tuneline</id>
  <name>Tuneline</name>
  <summary>Play any media playlist</summary>

  <metadata_license>CC0-1.0</metadata_license>
  <project_license>LicenseRef-proprietary</project_license>

  <description>
    <p>
      Tuneline is a cross-platform media player that loads your own media playlists.
      Bring your own M3U file, Xtream credentials, or portal URL and Tuneline plays
      them with a clean, modern interface.
    </p>
    <p>Features:</p>
    <ul>
      <li>Load M3U, Xtream, and Stalker-format playlists</li>
      <li>Electronic program guide with a schedule view</li>
      <li>Favorites and watch history</li>
      <li>Hardware-accelerated video playback via libmpv</li>
    </ul>
  </description>

  <launchable type="desktop-id">app.tuneline.Tuneline.desktop</launchable>

  <url type="homepage">https://tuneline.app</url>
  <url type="contact">mailto:support@tuneline.app</url>

  <developer_name>Tuneline</developer_name>

  <categories>
    <category>AudioVideo</category>
    <category>Video</category>
    <category>Player</category>
  </categories>

  <screenshots>
    <screenshot type="default">
      <caption>Live playback with program guide</caption>
      <image>https://tuneline.app/screenshots/flathub-1.png</image>
    </screenshot>
    <screenshot>
      <caption>Movies library</caption>
      <image>https://tuneline.app/screenshots/flathub-2.png</image>
    </screenshot>
    <screenshot>
      <caption>Series browser</caption>
      <image>https://tuneline.app/screenshots/flathub-3.png</image>
    </screenshot>
  </screenshots>

  <content_rating type="oars-1.1"/>

  <branding>
    <color type="primary" scheme_preference="light">#4A9EFF</color>
    <color type="primary" scheme_preference="dark">#0D1B2A</color>
  </branding>

  <releases>
    <release version="0.1.0" date="2026-04-23">
      <description>
        <p>First Flathub release.</p>
      </description>
    </release>
  </releases>
</component>
