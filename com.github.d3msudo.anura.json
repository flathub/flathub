{
    "app-id": "com.github.d3msudo.anura",
    "runtime": "org.gnome.Platform",
    "runtime-version": "50",
    "sdk": "org.gnome.Sdk",
    "command": "anura",
    "finish-args": [
        "--share=network",
        "--share=ipc",
        "--socket=fallback-x11",
        "--socket=wayland",
        "--device=dri"
    ],
    "cleanup": [
        "/include",
        "/lib/pkgconfig",
        "/share/doc",
        "/share/man",
        "*.la",
        "*.a"
    ],
    "modules": [
        {
            "name": "leptonica",
            "config-opts": [
                "--disable-static",
                "--with-libpng",
                "--with-jpeg",
                "--with-libtiff",
                "--with-zlib"
            ],
            "cleanup": [
                "/bin",
                "/include",
                "/lib/pkgconfig",
                "*.la"
            ],
            "sources": [
                {
                    "type": "git",
                    "url": "https://github.com/DanBloomberg/leptonica.git",
                    "tag": "1.85.0"
                }
            ]
        },
        {
            "name": "tesseract",
            "config-opts": [
                "--disable-static",
                "--disable-graphics",
                "--enable-legacy"
            ],
            "cleanup": [
                "/include",
                "/lib/pkgconfig",
                "*.la"
            ],
            "sources": [
                {
                    "type": "git",
                    "url": "https://github.com/tesseract-ocr/tesseract.git",
                    "tag": "5.5.0"
                }
            ],
            "modules": [
                {
                    "name": "tessdata-fast",
                    "buildsystem": "simple",
                    "build-commands": [
                        "mkdir -p /app/share/tessdata",
                        "cp eng.traineddata ita.traineddata /app/share/tessdata/"
                    ],
                    "sources": [
                        {
                            "type": "file",
                            "url": "https://github.com/tesseract-ocr/tessdata_fast/raw/main/eng.traineddata",
                            "sha256": "7d4322bd2a7749724879683fc3912cb542f19906c83bcc1a52132556427170b2"
                        },
                        {
                            "type": "file",
                            "url": "https://github.com/tesseract-ocr/tessdata_fast/raw/main/ita.traineddata",
                            "sha256": "b8f89e1e785118dac4d51ae042c029a64edb5c3ee42ef73027a6d412748d8827"
                        }
                    ]
                }
            ]
        },
        {
            "name": "libportal",
            "buildsystem": "meson",
            "builddir": true,
            "config-opts": [
                "-Ddocs=false",
                "-Dtests=false",
                "-Dvapi=false",
                "-Dintrospection=true",
                "-Dbackend-gtk3=disabled",
                "-Dbackend-gtk4=enabled",
                "-Dbackend-qt5=disabled"
            ],
            "cleanup": [
                "/include",
                "/lib/pkgconfig",
                "/share/gir-1.0",
                "*.la"
            ],
            "sources": [
                {
                    "type": "git",
                    "url": "https://github.com/flatpak/libportal.git",
                    "tag": "0.9.1"
                }
            ]
        },
        {
            "name": "zbar",
            "buildsystem": "autotools",
            "cleanup": [
                "/bin",
                "/include",
                "/lib/pkgconfig",
                "/share/doc",
                "/share/man",
                "*.la"
            ],
            "config-opts": [
                "--disable-static",
                "--without-gtk",
                "--without-qt",
                "--without-qt5",
                "--without-xv",
                "--without-dbus",
                "--without-java",
                "--without-python",
                "--without-imagemagick",
                "--disable-video",
                "--disable-doc",
                "--with-introspection=no",
                "--enable-codes=qrcode,code128,code39"
            ],
            "sources": [
                {
                    "type": "git",
                    "url": "https://github.com/mchehab/zbar.git",
                    "tag": "0.23.93"
                },
                {
                    "type": "shell",
                    "commands": [
                        "autoreconf -vfi"
                    ]
                }
            ]
        },
        {
            "name": "python3-modules",
            "buildsystem": "simple",
            "build-commands": [],
            "modules": [
                {
                    "name": "python3-requests",
                    "buildsystem": "simple",
                    "build-commands": [
                        "pip3 install --verbose --no-deps --no-build-isolation --prefix=/app ."
                    ],
                    "sources": [
                        {
                            "type": "git",
                            "url": "https://github.com/psf/requests.git",
                            "tag": "v2.32.3"
                        }
                    ]
                },
                {
                    "name": "python3-pillow",
                    "buildsystem": "simple",
                    "build-commands": [
                        "pip3 install --verbose --no-deps --no-build-isolation --prefix=/app ."
                    ],
                    "sources": [
                        {
                            "type": "git",
                            "url": "https://github.com/python-pillow/Pillow.git",
                            "tag": "11.0.0"
                        }
                    ]
                },
                {
                    "name": "python3-pytesseract",
                    "buildsystem": "simple",
                    "build-commands": [
                        "pip3 install --verbose --no-deps --no-build-isolation --prefix=/app ."
                    ],
                    "sources": [
                        {
                            "type": "git",
                            "url": "https://github.com/madmaze/pytesseract.git",
                            "tag": "v0.3.13"
                        }
                    ]
                },
                {
                    "name": "python3-gTTS",
                    "buildsystem": "simple",
                    "build-commands": [
                        "pip3 install --verbose --no-deps --no-build-isolation --prefix=/app ."
                    ],
                    "sources": [
                        {
                            "type": "git",
                            "url": "https://github.com/pndurette/gTTS.git",
                            "tag": "v2.5.1"
                        }
                    ]
                },
                {
                    "name": "python3-dateutil",
                    "buildsystem": "simple",
                    "build-commands": [
                        "pip3 install --verbose --no-deps --no-build-isolation --prefix=/app ."
                    ],
                    "sources": [
                        {
                            "type": "git",
                            "url": "https://github.com/dateutil/dateutil.git",
                            "tag": "2.9.0.post0"
                        }
                    ]
                }
            ]
        },
        {
            "name": "anura",
            "builddir": true,
            "buildsystem": "meson",
            "sources": [
                {
                    "type": "git",
                    "url": "https://github.com/D3M-Sudo/Anura.git",
                    "tag": "v0.1.0"
                }
            ]
        }
    ]
}
