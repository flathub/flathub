{
    "app-id": "com.github.d3msudo.anura",
    "runtime": "org.gnome.Platform",
    "runtime-version": "50",
    "sdk": "org.gnome.Sdk",
    "command": "anura",
    "finish-args": [
        "--share=network",
        "--share=ipc",
        "--socket=fallback-x11",
        "--socket=wayland",
        "--device=dri",
        "--talk-name=org.gnome.Shell.Screenshot",
        "--talk-name=org.kde.kspread.screenshot"
    ],
    "cleanup": [
        "/include",
        "/lib/pkgconfig",
        "/share/doc",
        "/share/man",
        "*.la",
        "*.a"
    ],
    "modules": [
        "leptonica.json",
        "tesseract.json",
        "libportal.json",
        "zbar.json",
        "python3-modules.json",
        "python3-gTTS.json",
        {
            "name": "anura",
            "builddir": true,
            "buildsystem": "meson",
            "sources": [
                {
                    "type": "git",
                    "url": "https://github.com/D3M-Sudo/Anura.git",
                    "tag": "v0.1.0"
                }
            ]
        }
    ]
}
