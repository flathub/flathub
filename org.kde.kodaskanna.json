{
    "id": "org.kde.kodaskanna",
    "runtime": "org.kde.Platform",
    "runtime-version": "6.10",
    "sdk": "org.kde.Sdk",
    "command": "kodaskanna",
    "rename-icon": "kodaskanna",
    "rename-appdata-file": "org.kde.kodaskanna.appdata.xml",
    "finish-args": [
        "--device=dri",
        "--share=ipc",
        "--socket=fallback-x11",
        "--socket=wayland",
        "--filesystem=xdg-pictures:ro"
    ],
    "cleanup": [
        "/include",
        "/lib/cmake",
        "/lib/pkgconfig",
        "/share/qlogging-categories6",
        "*.a"
    ],
    "modules": [
        {
            "name": "zxing",
            "config-opts": [
                "-DBUILD_DEPENDENCIES=LOCAL",
                "-DBUILD_SHARED_LIBS=OFF",
                "-DBUILD_EXAMPLES=OFF"
            ],
            "buildsystem": "cmake-ninja",
            "builddir": true,
            "sources": [
                {
                    "type": "archive",
                    "url": "https://github.com/zxing-cpp/zxing-cpp/archive/v2.3.0.tar.gz",
                    "sha256": "64e4139103fdbc57752698ee15b5f0b0f7af9a0331ecbdc492047e0772c417ba",
                    "x-checker-data": {
                        "type": "anitya",
                        "project-id": 376699,
                        "stable-only": true,
                        "url-template": "https://github.com/zxing-cpp/zxing-cpp/archive/v$version.tar.gz"
                    }
                }
            ]
        },
        {
            "name": "kodaskanna",
            "buildsystem": "cmake-ninja",
            "config-opts": [
                "-DBUILD_TESTING=OFF"
            ],
            "sources": [
                {
                    "type": "archive",
                    "url": "https://download.kde.org/unstable/kodaskanna/0.2.2/src/kodaskanna-0.2.2.tar.xz",
                    "sha256": "d32e42297ab1a81a96b68683d1d5ff9034036e29d590c482dce2619eea687a80",
                    "x-checker-data": {
                        "type": "anitya",
                        "project-id": 375753,
                        "stable-only": true,
                        "url-template": "https://download.kde.org/unstable/kodaskanna/$version/src/kodaskanna-$version.tar.xz"
                    }
                },
                {
                    "type": "patch",
                    "path": "scalable.patch"
                }
            ]
        }
    ]
}
