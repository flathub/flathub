<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>cc.snowify.Snowify</id>

  <name>Snowify</name>
  <summary>A desktop music player that streams from free sources</summary>

  <developer id="cc.snowify">
    <name>Nyaku</name>
  </developer>

  <metadata_license>CC0-1.0</metadata_license>
  <project_license>MIT</project_license>

  <url type="homepage">https://snowify.cc</url>
  <url type="bugtracker">https://github.com/nyakuoff/Snowify/issues</url>

  <description>
    <p>
      Snowify is a desktop music player that streams audio from YouTube Music.
      Search for any song, artist, or album and start listening instantly — no
      account required.
    </p>
    <p>Features include:</p>
    <ul>
      <li>Stream millions of songs from YouTube Music for free</li>
      <li>Create and manage playlists</li>
      <li>Import local audio files into your playlists</li>
      <li>Synced lyrics display</li>
      <li>Music video playback</li>
      <li>Smart autoplay queue with recommendations</li>
      <li>Discord Rich Presence</li>
      <li>Cloud sync across devices</li>
      <li>Variety of themes</li>
    </ul>
  </description>

  <launchable type="desktop-id">cc.snowify.Snowify.desktop</launchable>

  <screenshots>
    <screenshot type="default">
      <image>https://raw.githubusercontent.com/nyakuoff/Snowify/main/assets/screenshots/home.png</image>
      <caption>Home view</caption>
    </screenshot>
    <screenshot>
      <image>https://raw.githubusercontent.com/nyakuoff/Snowify/main/assets/screenshots/explore.png</image>
      <caption>Explore new music and trending tracks</caption>
    </screenshot>
    <screenshot>
      <image>https://raw.githubusercontent.com/nyakuoff/Snowify/main/assets/screenshots/playlist.png</image>
      <caption>Playlist view</caption>
    </screenshot>
    <screenshot>
      <image>https://raw.githubusercontent.com/nyakuoff/Snowify/main/assets/screenshots/artist.png</image>
      <caption>Artist page</caption>
    </screenshot>
    <screenshot>
      <image>https://raw.githubusercontent.com/nyakuoff/Snowify/main/assets/screenshots/lyrics.png</image>
      <caption>Synced lyrics display</caption>
    </screenshot>
  </screenshots>

  <content_rating type="oars-1.1" />

  <releases>
    <release version="1.3.3" date="2026-03-21" />
    <release version="1.3.2" date="2026-03-15" />
  </releases>

  <supports>
    <control>pointing</control>
    <control>keyboard</control>
  </supports>

  <requires>
    <internet>always</internet>
  </requires>
</component>
