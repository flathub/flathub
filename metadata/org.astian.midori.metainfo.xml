<component type="desktop-application">
  <id>org.astian.midori</id>
  <launchable type="desktop-id">org.astian.midori.desktop</launchable>
  <name>Midori Browser</name>
  <developer id="org.astian">
    <name>Astian, Inc.</name>
  </developer>
  <summary>A privacy-focused web browser</summary>
  <metadata_license>FSFAP</metadata_license>
  <project_license>MPL-2.0</project_license>
  <description>
    <p>
      Midori Browser is a privacy-focused web browser built by Astian.
      Based on Firefox, it provides a fast, secure and private browsing
      experience with built-in privacy protections.
    </p>
    <p>Features include:</p>
    <ul>
      <li>Built-in privacy and tracking protection</li>
      <li>Vertical tab support</li>
      <li>Modern and customizable interface</li>
      <li>Cross-platform sync via Astian Account</li>
      <li>Tor integration for anonymous browsing</li>
    </ul>
  </description>
  <url type="homepage">https://astian.org/midori-browser</url>
  <url type="bugtracker">https://github.com/goastian/midori-desktop/issues</url>
  <url type="donation">https://donate.stripe.com/00g6s675Xawl6ZO9AH</url>
  <url type="vcs-browser">https://github.com/goastian/midori-desktop</url>
  <url type="contribute">https://github.com/goastian/midori-desktop</url>

  <branding>
    <color type="primary" scheme_preference="light">#03a66a</color>
    <color type="primary" scheme_preference="dark">#024d31</color>
  </branding>

  <content_rating type="oars-1.1" />

  <screenshots>
