    <screenshot>
      <image>https://raw.githubusercontent.com/goastian/midori-desktop/main/assets/screenshots/adblock.png</image>
      <caption>Built-in ad and tracking protection</caption>
    </screenshot>
  </screenshots>

  <releases>
