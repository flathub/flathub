{
  "app-id": "io.github.archisman_panigrahi.wombat",
  "runtime": "org.gnome.Platform",
  "runtime-version": "50",
  "sdk": "org.gnome.Sdk",
  "sdk-extensions": [
    "org.freedesktop.Sdk.Extension.rust-stable"
  ],

  "command": "wombat",

  "finish-args": [
    "--device=dri",
    "--share=ipc",
    "--socket=wayland",
    "--socket=fallback-x11"
  ],

  "modules": [
    {
      "name": "wombat",
      "buildsystem": "simple",

      "build-options": {
        "append-path": "/usr/lib/sdk/rust-stable/usr/bin",
        "env": {
          "CARGO_HOME": "/run/build/wombat/cargo",
          "RUSTUP_HOME": "/run/build/wombat/rustup",
          "CARGO_NET_OFFLINE": "true",
          "PATH": "/usr/lib/sdk/rust-stable/bin:/app/bin:/usr/bin"
        }
      },

      "build-commands": [
        "rm -f cargo/config",

        "mkdir -p .cargo",
        "cp cargo/config.toml .cargo/config.toml",

        "cargo --offline fetch --manifest-path Cargo.toml --verbose",
        "cargo build --offline --release --frozen",

        "install -Dm755 target/release/wombat /app/bin/wombat",
        "install -Dm644 data/io.github.archisman_panigrahi.wombat.desktop /app/share/applications/io.github.archisman_panigrahi.wombat.desktop",
        "install -Dm644 data/io.github.archisman_panigrahi.wombat.metainfo.xml /app/share/metainfo/io.github.archisman_panigrahi.wombat.metainfo.xml",
        "install -Dm644 data/io.github.archisman_panigrahi.wombat.png /app/share/icons/hicolor/512x512/apps/io.github.archisman_panigrahi.wombat.png"
      ],

      "sources": [
        {
          "type": "git",
          "url": "https://github.com/archisman-panigrahi/wombat.git",
          "commit": "8a8d83369d663cffc5a9a6aa2eec10e6144c57d6"
        },

        "cargo-sources.json",

        {
          "type": "inline",
          "dest": "cargo",
          "dest-filename": "config.toml",
          "contents": "[source.crates-io]\nreplace-with = \"vendored-sources\"\n\n[source.vendored-sources]\ndirectory = \"cargo/vendor\"\n"
        }
      ]
    }
  ]
}