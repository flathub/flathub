<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>org.skaven.ratic</id>

  <name>Ratic</name>
  <summary>Complete music player</summary>

  <metadata_license>CC-BY-SA-4.0</metadata_license>
  <project_license>GPL-3.0-or-later</project_license>

  <url type="homepage">https://gitlab.gnome.org/ratcornu/ratic</url>
  <url type="bugtracker">https://gitlab.gnome.org/ratcornu/ratic/issues</url>
  <url type="contact">https://matrix.to/#/#ratic:skaven.org</url>

  <developer id="org.skaven">
    <name>Rat Cornu</name>
  </developer>

  <content_rating type="oars-1.1" />

  <description>
    <p>
      Offline music player with lots of features, built with Rust, GTK, adwaita, relm and GStreamer.
    </p>
    <ul>
      <li>Support most music file types</li>
      <li>Entirely offline</li>
      <li>Fully responsive while loading a library</li>
      <li>Low memory usage, even with thousands of musics with cover image</li>
      <li>Sort and group by album, artist, full-text searching</li>
      <li>Dynamic blurred background with light/dark modes</li>
      <li>Music queue with several play modes</li>
      <li>Supports MPRIS controls</li>
    </ul>
  </description>

  <launchable type="desktop-id">org.skaven.ratic.desktop</launchable>
  <screenshots>
    <screenshot type="default">
      <image>https://gitlab.gnome.org/ratcornu/ratic/-/raw/main/docs/preview-main.png</image>
      <caption>Main view of the application</caption>
    </screenshot>
  </screenshots>

  <icon type="stock">ratic</icon>

  <categories>
    <category>AudioVideo</category>
    <category>Music</category>
  </categories>

  <provides>
    <binary>ratic</binary>
  </provides>

