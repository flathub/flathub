{
    "app-id": "com.fogpanther.FogPanther",
    "runtime": "org.gnome.Platform",
    "runtime-version": "49",
    "sdk": "org.gnome.Sdk",
    "command": "fogpanther",
    "finish-args": [
        "--share=ipc",
        "--socket=fallback-x11",
        "--socket=wayland",
        "--device=dri"
    ],
    "modules": [
        {
            "name": "fogpanther",
            "buildsystem": "simple",
            "build-commands": [
                "install -Dm755 bin/fogpanther bin/fogpanther-thumbnailer -t /app/bin/",
                "install -Dm644 LICENSE -t /app/share/licenses/com.fogpanther.FogPanther/",
                "cp -a lib/. /app/lib/",
                "cp -a share/. /app/share/"
            ],
            "sources": [
                {
                    "type": "archive",
                    "url": "https://www.fogpanther.com/releases/fogpanther-0.4.1-r5-x86_64.tar.xz",
                    "sha256": "786ce5b12560873874af4c5283536d09a9f387d8059ebea2c13d7beb51dd0e6a",
                    "only-arches": ["x86_64"]
                },
                {
                    "type": "archive",
                    "url": "https://www.fogpanther.com/releases/fogpanther-0.4.1-r5-aarch64.tar.xz",
                    "sha256": "52a50666739b09b4ba49a3699ae21d101d1ebbb5e783359430d69ad6f61f8c5b",
                    "only-arches": ["aarch64"]
                }
            ]
        }
    ]
}
