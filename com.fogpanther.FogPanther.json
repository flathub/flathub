{
    "app-id": "com.fogpanther.FogPanther",
    "runtime": "org.gnome.Platform",
    "runtime-version": "49",
    "sdk": "org.gnome.Sdk",
    "command": "fogpanther",
    "finish-args": [
        "--share=ipc",
        "--socket=fallback-x11",
        "--socket=wayland",
        "--device=dri"
    ],
    "modules": [
        {
            "name": "fogpanther",
            "buildsystem": "simple",
            "build-commands": [
                "install -Dm755 bin/fogpanther bin/fogpanther-thumbnailer -t /app/bin/",
                "install -Dm644 LICENSE -t /app/share/licenses/com.fogpanther.FogPanther/",
                "cp -a lib/. /app/lib/",
                "cp -a share/. /app/share/"
            ],
            "sources": [
                {
                    "type": "archive",
                    "url": "https://www.fogpanther.com/releases/fogpanther-0.4.1-r4-x86_64.tar.xz",
                    "sha256": "9e1efcd375fae911297d8493487a8f24d69c5611c36a61f1f4bc68ded49eb875",
                    "only-arches": ["x86_64"]
                },
                {
                    "type": "archive",
                    "url": "https://www.fogpanther.com/releases/fogpanther-0.4.1-r4-aarch64.tar.xz",
                    "sha256": "309882445f143ce4669be2d6127261e3466249509d34c1209eb83a9690d55a50",
                    "only-arches": ["aarch64"]
                }
            ]
        }
    ]
}
