{
    "app-id": "com.fogpanther.FogPanther",
    "runtime": "org.gnome.Platform",
    "runtime-version": "49",
    "sdk": "org.gnome.Sdk",
    "command": "fogpanther",
    "finish-args": [
        "--share=ipc",
        "--socket=fallback-x11",
        "--socket=wayland",
        "--device=dri"
    ],
    "modules": [
        {
            "name": "fogpanther",
            "buildsystem": "simple",
            "build-commands": [
                "install -Dm755 bin/fogpanther bin/fogpanther-thumbnailer -t /app/bin/",
                "install -Dm644 LICENSE -t /app/share/licenses/com.fogpanther.FogPanther/",
                "cp -a lib/. /app/lib/",
                "cp -a share/. /app/share/"
            ],
            "sources": [
                {
                    "type": "archive",
                    "url": "https://www.fogpanther.com/releases/fogpanther-0.4.1-r3-x86_64.tar.xz",
                    "sha256": "d488e59370285325556e6761825e34ab79e495c673161de2fb251f90988690d6",
                    "strip-components": 1,
                    "only-arches": ["x86_64"]
                },
                {
                    "type": "archive",
                    "url": "https://www.fogpanther.com/releases/fogpanther-0.4.1-r3-aarch64.tar.xz",
                    "sha256": "fe1cf988f82388c99f7a57dd8c8a66ccc635d8d0a82325450d9d260582534c8b",
                    "strip-components": 1,
                    "only-arches": ["aarch64"]
                }
            ]
        }
    ]
}
