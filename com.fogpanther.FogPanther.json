{
    "app-id": "com.fogpanther.FogPanther",
    "runtime": "org.gnome.Platform",
    "runtime-version": "48",
    "sdk": "org.gnome.Sdk",
    "command": "fogpanther",
    "finish-args": [
        "--share=ipc",
        "--socket=fallback-x11",
        "--socket=wayland",
        "--device=dri"
    ],
    "modules": [
        {
            "name": "fogpanther",
            "buildsystem": "simple",
            "build-commands": [
                "install -Dm755 bin/fogpanther bin/fogpanther-thumbnailer -t /app/bin/",
                "install -Dm644 LICENSE -t /app/share/licenses/com.fogpanther.FogPanther/",
                "cp -a lib/. /app/lib/",
                "cp -a share/. /app/share/"
            ],
            "sources": [
                {
                    "type": "archive",
                    "url": "https://www.fogpanther.com/releases/fogpanther-0.4.0-r1-x86_64.tar.xz",
                    "sha256": "da35cfcc6fa276e2dba2d86f848748459bd7f4f361b9244a0b3e2cc39f47e2c3",
                    "strip-components": 1
                }
            ]
        }
    ]
}
