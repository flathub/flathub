<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>io.github.SimoneAncona.gtk4-battery-usage</id>

  <name>Battery Usage</name>
  <summary>Monitor your battery charge history</summary>

  <metadata_license>CC0-1.0</metadata_license>
  <project_license>GPL-3.0-or-later</project_license>

  <description>
    <p>
      Battery Usage lets you visualize your laptop battery charge history over time.
      It reads data directly from UPower and displays an interactive line chart
      showing how your battery level changed over the last hour, 6 hours, 24 hours,
      or 7 days.
    </p>
    <p>Features:</p>
    <ul>
      <li>Interactive chart with hover tooltips</li>
      <li>Configurable time span: 1 hour, 6 hours, 24 hours, 7 days</li>
      <li>Live stats: current charge, full capacity, charge/discharge rate</li>
      <li>Follows your system accent color</li>
    </ul>
  </description>

  <launchable type="desktop-id">io.github.SimoneAncona.gtk4-battery-usage.desktop</launchable>

  <url type="homepage">https://github.com/SimoneAncona/battery-usage</url>
  <url type="bugtracker">https://github.com/SimoneAncona/battery-usage/issues</url>

  <developer id="it.SimoneAncona">
    <name>Simone Ancona</name>
  </developer>

  <branding>
    <color type="primary" scheme_preference="light">#e0f5ec</color>
    <color type="primary" scheme_preference="dark">#1a3d2e</color>
  </branding>

  <content_rating type="oars-1.1"/>

  <releases>
    <release version="1.0.0" date="2026-03-18">
      <description>
        <p>Initial release.</p>
      </description>
    </release>
  </releases>

  <supports>
    <control>pointing</control>
    <control>keyboard</control>
    <control>touch</control>
  </supports>

  <requires>
    <display_length compare="ge">360</display_length>
  </requires>
</component>
