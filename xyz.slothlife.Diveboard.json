{
  "app-id": "xyz.slothlife.Diveboard",
  "runtime": "org.gnome.Platform",
  "runtime-version": "50",
  "sdk": "org.gnome.Sdk",
  "sdk-extensions": ["org.freedesktop.Sdk.Extension.rust-stable"],
  "command": "diveboard",
  "finish-args": [
    "--share=network",
    "--share=ipc",
    "--socket=fallback-x11",
    "--device=dri",
    "--socket=wayland"
  ],
  "build-options": {
    "append-path": "/usr/lib/sdk/rust-stable/bin",
    "env": {
      "CARGO_REGISTRIES_CRATES_IO_PROTOCOL": "sparse",
      "RUST_BACKTRACE": "1",
      "RUST_LOG": "diveboard=debug"
    }
  },
  "cleanup": [
    "/include",
    "/lib/pkgconfig",
    "/man",
    "/share/doc",
    "/share/gtk-doc",
    "/share/man",
    "/share/pkgconfig",
    "*.la",
    "*.a"
  ],
  "modules": [
    {
      "name": "gdk-pixbuf",
      "buildsystem": "meson",
      "config-opts": [
        "-Dbuiltin_loaders=png,jpeg",
        "-Dman=false",
        "-Dgtk_doc=false",
        "-Dintrospection=disabled",
        "-Dinstalled_tests=false",
        "-Dgio_sniffing=false"
      ],
      "sources": [
        {
          "type": "archive",
          "url": "https://download.gnome.org/sources/gdk-pixbuf/2.42/gdk-pixbuf-2.42.12.tar.xz",
          "sha256": "b9505b3445b9a7e48ced34760c3bcb73e966df3ac94c95a148cb669ab748e3c7"
        }
      ]
    },
    {
      "name": "protobuf-c",
      "buildsystem": "autotools",
      "config-opts": ["--disable-protoc"],
      "sources": [
        {
          "type": "archive",
          "url": "https://github.com/protobuf-c/protobuf-c/releases/download/v1.5.2/protobuf-c-1.5.2.tar.gz",
          "sha256": "e2c86271873a79c92b58fef7ebf8de1aa0df4738347a8bd5d4e65a80a16d0d24"
        }
      ]
    },
    {
      "name": "libshumate",
      "buildsystem": "meson",
      "config-opts": ["-Dvapi=false", "-Dgtk_doc=false"],
      "builddir": true,
      "sources": [
        {
          "type": "archive",
          "url": "https://gitlab.gnome.org/GNOME/libshumate/-/archive/1.6.0/libshumate-1.6.0.tar.gz",
          "sha256": "8a4de928ec6943ce9a8a23cb84e9b871caa1ceb92f3e5a3e2969f6212015a7fb"
        }
      ]
    },
    {
      "name": "diveboard",
      "builddir": true,
      "buildsystem": "meson",
      "config-opts": ["-Dbuildtype=release"],
      "sources": [
        {
          "type": "archive",
          "url": "https://codeberg.org/baarkerlounger/diveboard-gtk/releases/download/v0.5.0/diveboard-0.5.0.tar.xz",
          "sha256": "7e8214b4480e2b762f307b05a087fc9d538f42b5a25aba3b810e476464511091"
        }
      ]
    }
  ]
}
