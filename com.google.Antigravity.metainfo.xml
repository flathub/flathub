<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>com.google.Antigravity</id>
  <name>Google Antigravity</name>
  <summary>AI-powered agentic development platform</summary>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>LicenseRef-proprietary=https://antigravity.google/terms</project_license>
  <developer id="com.google">
    <name>Google LLC</name>
  </developer>
  <description>
    <p>**NOTE: This wrapper is not associated with, supported by, or verified by the Google LLC.**</p>
    <p>
      Google Antigravity is an agentic development platform that combines a familiar,
      AI-powered coding experience with a new agent-first interface. Deploy agents that
      autonomously plan, execute, and verify complex tasks across the editor, terminal,
      and browser.
    </p>
    <p>Features include:</p>
    <ul>
      <li>Editor view - A familiar IDE interface with an AI agent sidebar</li>
      <li>Manager view - Control center for orchestrating multiple agents working in parallel</li>
      <li>Artifacts system - Verifiable deliverables including task lists, implementation plans, and recordings</li>
      <li>Powered by Gemini 3 Pro, Gemini 3 Deep Think, and Gemini 3 Flash</li>
      <li>Support for Claude Sonnet 4.5 and OpenAI models</li>
    </ul>
  </description>
  <url type="homepage">https://antigravity.google/</url>
  <url type="help">https://antigravity.google/docs/get-started</url>
  <url type="bugtracker">https://github.com/flathub/com.google.Antigravity/issues</url>
  <url type="faq">https://antigravity.google/docs/faq</url>
  <url type="contact">https://antigravity.google/support</url>

  <launchable type="desktop-id">com.google.Antigravity.desktop</launchable>
  <provides>
    <binary>antigravity</binary>
  </provides>
  <screenshots>
    <screenshot type="default">
      <image>https://antigravity.google/assets/screenshot-editor.png</image>
      <caption>Editor view with AI agent sidebar</caption>
    </screenshot>
    <screenshot>
      <image>https://antigravity.google/assets/screenshot-manager.png</image>
      <caption>Manager view for orchestrating multiple agents</caption>
    </screenshot>
  </screenshots>
  <branding>
    <color type="primary" scheme_preference="light">#e8f0fe</color>
    <color type="primary" scheme_preference="dark">#202124</color>
  </branding>
  <content_rating type="oars-1.1">
    <content_attribute id="social-info">moderate</content_attribute>
  </content_rating>
  <releases>
    <release version="1.20.6" date="2026-03-17">
      <description>
        <p>Latest stable release.</p>
      </description>
    </release>
  </releases>
  <requires>
    <display_length compare="ge">768</display_length>
  </requires>
  <recommends>
    <control>keyboard</control>
    <control>pointing</control>
    <display_length compare="ge">1024</display_length>
  </recommends>
</component>
