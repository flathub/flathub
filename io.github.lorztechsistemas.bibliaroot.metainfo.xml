<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>io.github.lorztechsistemas.bibliaroot</id>
  <name>BíbliaRoot</name>
  <summary>Leitura e estudo bíblico offline para Linux</summary>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>MIT</project_license>
  <url type="homepage">https://github.com/lorztechsistemas/holly-bible-linux</url>
  <url type="bugtracker">https://github.com/lorztechsistemas/holly-bible-linux/issues</url>
  <url type="vcs-browser">https://github.com/lorztechsistemas/holly-bible-linux</url>
  <developer id="io.github.lorztechsistemas">
    <name>BíbliaRoot</name>
  </developer>
  <launchable type="desktop-id">io.github.lorztechsistemas.bibliaroot.desktop</launchable>
  <description>
    <p>Aplicativo desktop para leitura e estudo bíblico offline com múltiplas traduções, busca textual, favoritos, notas, cadernos de estudo e planos de leitura.</p>
    <p>Inclui comparação de traduções, referências cruzadas (via importação), conteúdo diário com notificação e interface traduzível.</p>
    <ul>
      <li>Leitura offline com múltiplas traduções SQLite</li>
      <li>Busca rápida e busca avançada de estudo</li>
      <li>Notas por versículo, tags e cadernos</li>
      <li>Planos de leitura com progresso</li>
      <li>Tema claro/escuro e UI multilíngue</li>
    </ul>
  </description>
