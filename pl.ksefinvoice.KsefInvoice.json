{
    "app-id": "pl.ksefinvoice.KsefInvoice",
    "runtime": "org.freedesktop.Platform",
    "runtime-version": "25.08",
    "sdk": "org.freedesktop.Sdk",
    "command": "ksef_wrapper.sh",
    "finish-args": [
        "--share=ipc",
        "--socket=fallback-x11",
        "--socket=wayland",
        "--share=network",
        "--filesystem=xdg-config/kdeglobals:ro",
        "--device=dri"
    ],
    "modules": [
        {
            "name": "ksef-binary",
            "buildsystem": "simple",
            "build-commands": [
                "mkdir -p /app/lib /app/bin",
                "cp -r ./* /app/lib/",
                "ln -s /app/lib/KsefInvoice /app/bin/KsefInvoice",
                "install -Dm644 pl.ksefinvoice.KsefInvoice.metainfo.xml /app/share/metainfo/pl.ksefinvoice.KsefInvoice.metainfo.xml",
                "install -Dm644 pl.ksefinvoice.KsefInvoice.desktop /app/share/applications/pl.ksefinvoice.KsefInvoice.desktop",
                "install -Dm644 pl.ksefinvoice.KsefInvoice.png /app/share/icons/hicolor/128x128/apps/pl.ksefinvoice.KsefInvoice.png",
                "install -Dm644 LICENSE /app/share/licenses/pl.ksefinvoice.KsefInvoice/LICENSE",
                "install -Dm755 ksef_wrapper.sh /app/bin/ksef_wrapper.sh"
            ],
            "sources": [
                {
                    "type": "archive",
                    "url": "https://github.com/JDyszczynski/pl.ksefinvoice.app/releases/download/v1.0.5-1/KsefInvoice-1.0.5-1.tar.gz",
                    "sha256": "76eb53fb7093d366d0237db7e0fdb73ace45624db439c6183b81faa412384af4",
                    "strip-components": 1
                },
                {
                    "type": "file",
                    "path": "ksef_wrapper.sh"
                }
            ]
        }
    ]
}