{
    "app-id": "pl.ksefinvoice.KsefInvoice",
    "runtime": "org.freedesktop.Platform",
    "runtime-version": "25.08",
    "sdk": "org.freedesktop.Sdk",
    "command": "ksef_wrapper.sh",
    "add-extensions": {
        "org.gtk.Gtk3theme": {
            "directory": "share/themes",
            "version": "3.22",
            "subdirectories": true,
            "no-autodownload": true,
            "autodelete": false
        }
    },
    "finish-args": [
        "--share=ipc",
        "--socket=fallback-x11",
        "--socket=wayland",
        "--socket=cups",
        "--share=network",
        "--filesystem=xdg-download",
        "--filesystem=xdg-desktop",
        "--filesystem=xdg-documents:ro",
        "--filesystem=xdg-config/kdeglobals:ro",
        "--device=dri",
        "--env=QT_QPA_PLATFORMTHEME=xdgdesktopportal",
        "--env=APP_DARK_THEME=1"
    ],
    "modules": [
        {
            "name": "ksef-binary",
            "buildsystem": "simple",
            "build-commands": [
                "mkdir -p /app/share/themes",
                "mkdir -p /app/lib/ksef",
                "cp -r ./* /app/lib/ksef/",
                "install -D pl.ksefinvoice.KsefInvoice.metainfo.xml /app/share/metainfo/pl.ksefinvoice.KsefInvoice.metainfo.xml",
                "install -D pl.ksefinvoice.KsefInvoice.desktop /app/share/applications/pl.ksefinvoice.KsefInvoice.desktop",
                "install -D pl.ksefinvoice.KsefInvoice.png /app/share/icons/hicolor/128x128/apps/pl.ksefinvoice.KsefInvoice.png",
                "install -D LICENSE /app/share/licenses/pl.ksefinvoice.KsefInvoice/LICENSE"
            ],
            "sources": [
                {
                    "type": "archive",
                    "url": "https://github.com/JDyszczynski/pl.ksefinvoice.app/releases/download/v1.0.5/KsefInvoice-1.0.5.tar.gz",
                    "sha256": "22d8ae021f7c71b0cbb7226508ac6ca757b6bf87b72a8bf6f35605c6caafd31e"
                },
                {
                    "type": "file",
                    "path": "pl.ksefinvoice.KsefInvoice.metainfo.xml"
                },
                {
                    "type": "file",
                    "path": "pl.ksefinvoice.KsefInvoice.desktop"
                },
                {
                    "type": "file",
                    "path": "pl.ksefinvoice.KsefInvoice.png"
                },
                {
                    "type": "file",
                    "path": "LICENSE"
                }
            ]
        },
        {
            "name": "launcher",
            "buildsystem": "simple",
            "build-commands": [
                "install -D ksef_wrapper.sh /app/bin/ksef_wrapper.sh"
            ],
            "sources": [
                {
                    "type": "file",
                    "path": "ksef_wrapper.sh"
                }
            ]
        }
    ]
}