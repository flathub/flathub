{
	"app-id": "com.hypixel.HytaleLauncher",
	"runtime": "org.gnome.Platform",
	"runtime-version": "49",
	"sdk": "org.gnome.Sdk",
	"command": "/app/bin/hytale-launcher",
	"finish-args": [
		"--share=ipc",
		"--socket=fallback-x11",
		"--socket=wayland",
		"--device=dri",
		"--share=network",
		"--socket=pulseaudio",
		"--talk-name=org.freedesktop.Notifications",
		"--talk-name=org.kde.StatusNotifierWatcher",
		"--talk-name=org.freedesktop.secrets",
		"--env=WEBKIT_DISABLE_COMPOSITING_MODE=1"
	],
	"modules": [
		{
			"name": "launcher",
			"buildsystem": "simple",
			"build-commands": [
				"unzip hytale-launcher.zip",
				"install -Dm755 hytale-launcher -t /app/bin",
				"install -Dm644 $FLATPAK_ID.desktop /app/share/applications/$FLATPAK_ID.desktop",
				"install -Dm644 $FLATPAK_ID.metainfo.xml -t /app/share/metainfo",
				"for size in 32 48 64 128 256; do install -Dm644 hicolor/${size}x${size}/apps/com.hypixel.HytaleLauncher.png /app/share/icons/hicolor/${size}x${size}/apps/$FLATPAK_ID.png; done"
			],
			"sources": [
				{
					"type": "extra-data",
					"url": "https://launcher.hytale.com/builds/release/linux/amd64/hytale-launcher-2026.01.24-997c2cb.zip",
					"sha256": "1be14530eb4b54f1f6cda590f3b8f299febe254015144280e12332b9813d319d",
					"size": 11694737,
					"filename": "hytale-launcher.zip"
				},
				{
					"type": "file",
					"path": "com.hypixel.HytaleLauncher.desktop"
				},
				{
					"type": "file",
					"path": "com.hypixel.HytaleLauncher.metainfo.xml"
				},
				{
					"type": "file",
					"path": "icons/hicolor/32x32/apps/com.hypixel.HytaleLauncher.png"
				},
				{
					"type": "file",
					"path": "icons/hicolor/48x48/apps/com.hypixel.HytaleLauncher.png"
				},
				{
					"type": "file",
					"path": "icons/hicolor/64x64/apps/com.hypixel.HytaleLauncher.png"
				},
				{
					"type": "file",
					"path": "icons/hicolor/128x128/apps/com.hypixel.HytaleLauncher.png"
				},
				{
					"type": "file",
					"path": "icons/hicolor/256x256/apps/com.hypixel.HytaleLauncher.png"
				}

			]
		}
	]
}
