{
  "app-id": "org.koderoots.musik",
  "runtime": "org.kde.Platform",
  "runtime-version": "6.10",
  "sdk": "org.kde.Sdk",
  "command": "musik",
  "finish-args": [
    "--share=ipc",
    "--socket=fallback-x11",
    "--socket=wayland",
    "--socket=pulseaudio",
    "--device=dri",
    "--filesystem=xdg-music:ro",
    "--filesystem=xdg-download:ro",
    "--talk-name=org.mpris.MediaPlayer2",
    "--own-name=org.mpris.MediaPlayer2.musik"
  ],
  "modules": [
    {
      "name": "musik",
      "buildsystem": "cmake-ninja",
      "config-opts": ["-DCMAKE_BUILD_TYPE=Release"],
      "builddir": true,
      "sources": [
        {
          "type": "git",
          "url": "https://github.com/KodeRoots/Musik.git",
          "tag": "0.1.0",
          "commit": "cdf78f519d1830800432eb0e79efbabeadc5eecc"
        }
      ]
    }
  ]
}
