{
  "app-id": "org.koderoots.musik",
  "runtime": "org.kde.Platform",
  "runtime-version": "6.10",
  "sdk": "org.kde.Sdk",
  "command": "musik",
  "finish-args": [
    "--share=ipc",
    "--socket=fallback-x11",
    "--socket=wayland",
    "--socket=pulseaudio",
    "--device=dri",
    "--filesystem=xdg-music:ro",
    "--filesystem=xdg-download:ro"
  ],
  "modules": [
    {
      "name": "musik",
      "buildsystem": "cmake-ninja",
      "config-opts": ["-DCMAKE_BUILD_TYPE=Release"],
      "builddir": true,
      "sources": [
        {
          "type": "git",
          "url": "https://github.com/KodeRoots/Musik.git",
          "tag": "0.1.1",
          "commit": "776a30b002fb94330dfaf42e90d7601c353ccc99"
        }
      ]
    }
  ]
}
