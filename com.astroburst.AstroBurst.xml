<?xml version="1.0" encoding="UTF-8"?>
<mime-info xmlns="http://www.freedesktop.org/standards/shared-mime-info">
  <mime-type type="application/fits">
    <comment>FITS Astronomical Image</comment>
    <glob pattern="*.fits"/>
    <glob pattern="*.fit"/>
    <glob pattern="*.fts"/>
    <magic priority="60">
      <match type="string" offset="0" value="SIMPLE  ="/>
    </magic>
  </mime-type>
  <mime-type type="application/asdf">
    <comment>ASDF Astronomical Data</comment>
    <glob pattern="*.asdf"/>
    <magic priority="60">
      <match type="string" offset="0" value="#ASDF"/>
    </magic>
  </mime-type>
</mime-info>
