{
    "id": "ru.transistor_radio.transistor",
    "runtime": "org.kde.Platform",
    "runtime-version": "6.9",
    "sdk": "org.kde.Sdk",
    "command": "transistor",
    "finish-args": [
        "--share=ipc",
        "--share=network",
        "--socket=x11",
        "--socket=wayland",
        "--device=dri",
        "--filesystem=xdg-download",
        "--socket=pulseaudio",
        "--talk-name=org.freedesktop.Notifications",
        "--talk-name=org.kde.StatusNotifierWatcher",
        "--own-name=org.kde.StatusNotifierItem-2-2"
    ],
    "separate-locales": false,

    "modules": [
        {
            "name": "kirigami-addons",
            "buildsystem": "cmake-ninja",
            "sources": [
                {
                    "type": "archive",
                    "url": "https://invent.kde.org/libraries/kirigami-addons/-/archive/v1.9.0/kirigami-addons-v1.9.0.tar.gz",
                    "sha256": "2e5eef802b109a495cd2910f7a207b60d1de02f04a02932b59c446a8a7328a98"
                }
            ],
            "config-opts": [
                "-DBUILD_TESTING=OFF",
                "-DCMAKE_BUILD_TYPE=Release",
                "-DBUILD_WITH_QT6=ON"
            ]
        },
        {
            "name": "transistor",
            "buildsystem": "cmake-ninja",
            "builddir": true,
            "sources": [ { "type": "dir", "path": "." } ]
        }
    ]
}

