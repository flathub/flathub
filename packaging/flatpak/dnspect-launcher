#!/usr/bin/env bash
set -euo pipefail

export DNS_SPEED_LAB_HOST="${DNS_SPEED_LAB_HOST:-127.0.0.1}"
export DNS_SPEED_LAB_PORT="${DNS_SPEED_LAB_PORT:-8000}"
export DNS_SPEED_LAB_OPEN_BROWSER=0
export DNS_SPEED_LAB_FRONTEND_DIR="${DNS_SPEED_LAB_FRONTEND_DIR:-/app/share/dnspect/frontend}"
export DNS_SPEED_LAB_DATA_DIR="${DNS_SPEED_LAB_DATA_DIR:-/app/share/dnspect/data}"

server_pid=""

cleanup() {
  if [[ -n "${server_pid}" ]] && kill -0 "${server_pid}" 2>/dev/null; then
    kill "${server_pid}" 2>/dev/null || true
    wait "${server_pid}" 2>/dev/null || true
  fi
}

trap cleanup EXIT INT TERM

dnspect &
server_pid="$!"

python3 - <<'PY'
import os
import time
import urllib.error
import urllib.request

host = os.environ.get("DNS_SPEED_LAB_HOST", "127.0.0.1")
port = os.environ.get("DNS_SPEED_LAB_PORT", "8000")
url = f"http://{host}:{port}/api/health"

for _ in range(50):
    try:
        with urllib.request.urlopen(url, timeout=0.5) as response:
            if response.status == 200:
                break
    except (urllib.error.URLError, TimeoutError):
        time.sleep(0.2)
else:
    raise SystemExit(0)
PY

url="http://${DNS_SPEED_LAB_HOST}:${DNS_SPEED_LAB_PORT}"

if command -v gio >/dev/null 2>&1; then
  gio open "${url}" >/dev/null 2>&1 || true
elif command -v xdg-open >/dev/null 2>&1; then
  xdg-open "${url}" >/dev/null 2>&1 || true
else
  python3 -m webbrowser "${url}" >/dev/null 2>&1 || true
fi

wait "${server_pid}"
