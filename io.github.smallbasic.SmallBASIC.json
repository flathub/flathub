{
  "app-id": "io.github.smallbasic.SmallBASIC",
  "runtime": "org.freedesktop.Platform",
  "runtime-version": "25.08",
  "sdk": "org.freedesktop.Sdk",
  "command": "sbasicg",
  "finish-args": [
    "--socket=wayland",
    "--socket=fallback-x11",
    "--socket=pulseaudio",
    "--device=dri",
    "--share=ipc",
    "--env=SBASICPATH=/app/lib/smallbasic"
  ],
  "modules": [
    {
      "name": "xxd",
      "buildsystem": "simple",
      "build-options": {
        "strip": true
      },
      "build-commands": [
        "cd src/xxd && make",
        "install -D src/xxd/xxd /app/bin/xxd"
      ],
      "sources": [
        {
          "type": "git",
          "url": "https://github.com/vim/vim.git",
          "tag": "v9.1.0"
        }
      ]
    },
    {
      "name": "sbasic",
      "buildsystem": "autotools",
      "build-options": {
        "strip": true
      },
      "config-opts": [
        "--prefix=/app"
      ],
      "sources": [
        {
          "type": "git",
          "url": "https://github.com/smallbasic/SmallBASIC.git",
          "tag": "12_32_FLATPAK_3"
        }
      ]
    },
    {
      "name": "smallbasic-plugins",
      "sources": [
        {
          "type": "git",
          "url": "https://github.com/smallbasic/smallbasic.plugins.git",
          "commit": "12_32"
        }
      ]
    },
    {
      "name": "sbasicg",
      "buildsystem": "autotools",
      "build-options": {
        "strip": true
      },
      "config-opts": [
        "--prefix=/app",
        "--enable-sdl",
        "--with-flatpak"
      ],
      "sources": [
        {
          "type": "git",
          "url": "https://github.com/smallbasic/SmallBASIC.git",
          "tag": "12_32_FLATPAK_3"
        }
      ]
    }
  ]
}
