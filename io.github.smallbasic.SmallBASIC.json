{
  "app-id": "io.github.smallbasic.SmallBASIC",
  "runtime": "org.freedesktop.Platform",
  "runtime-version": "25.08",
  "sdk": "org.freedesktop.Sdk",
  "command": "sbasicg",
  "build-options": {
    "strip": true,
    "no-debuginfo": true
  },
  "finish-args": [
    "--socket=wayland",
    "--socket=fallback-x11",
    "--socket=pulseaudio",
    "--device=dri",
    "--share=ipc",
    "--env=SBASICPATH=/app/lib/smallbasic/plugins"
  ],
  "cleanup": [
    "/include",
    "/lib/pkgconfig",
    "/lib/cmake",
    "/bin/xxd",
    "*.a",
    "*.la"
  ],
  "modules": [
    {
      "name": "smallbasic-plugins",
      "buildsystem": "simple",
      "build-commands": [
        "./autogen.sh",
        "./configure --prefix=/app",
        "make -s",
        "mkdir -p ${FLATPAK_DEST}/lib/smallbasic/plugins",
        "find . -name '*.so' -exec install -D {} ${FLATPAK_DEST}/lib/smallbasic/plugins/ \\;"
      ],
      "sources": [
        {
          "type": "git",
          "url": "https://github.com/smallbasic/smallbasic.plugins.git",
          "commit": "12_32"
        }
      ]
    },
    {
      "name": "xxd",
      "buildsystem": "simple",
      "build-commands": [
        "cd src/xxd && make",
        "install -D src/xxd/xxd /app/bin/xxd"
      ],
      "sources": [
        {
          "type": "git",
          "url": "https://github.com/vim/vim.git",
          "tag": "v9.1.0"
        }
      ]
    },
    {
      "name": "sbasic",
      "buildsystem": "simple",
      "build-commands": [
        "sh autogen.sh",
        "./configure --prefix=/app",
        "make install -s -j$(nproc)"
      ],
      "sources": [
        {
          "type": "git",
          "url": "https://github.com/smallbasic/SmallBASIC.git",
          "tag": "12_32_FLATPAK_2"
        }
      ]
    },
    {
      "name": "sbasicg",
      "buildsystem": "simple",
      "build-commands": [
        "sh autogen.sh",
        "./configure --prefix=/app --enable-sdl --with-flatpak",
        "make install -s -j$(nproc)"
      ],
      "sources": [
        {
          "type": "git",
          "url": "https://github.com/smallbasic/SmallBASIC.git",
          "tag": "12_32_FLATPAK_2"
        }
      ]
    }
  ]
}
