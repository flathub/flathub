{
    "app-id": "com.fogpanther.FogPanther",
    "runtime": "org.gnome.Platform",
    "runtime-version": "48",
    "sdk": "org.gnome.Sdk",
    "command": "fogpanther",
    "finish-args": [
        "--share=ipc",
        "--socket=fallback-x11",
        "--socket=wayland",
        "--device=dri",
        "--filesystem=home"
    ],
    "modules": [
        {
            "name": "fogpanther",
            "buildsystem": "simple",
            "build-commands": [
                "mkdir -p /app/bin/ /app/lib/ /app/share/",
                "cp -r bin/* /app/bin/",
                "cp -r lib/* /app/lib/",
                "cp -r share/* /app/share/"
            ],
            "sources": [
                {
                    "type": "archive",
                    "url": "https://www.fogpanther.com/releases/fogpanther-0.3.5-x86_64.tar.xz",
                    "sha256": "d183ccfd7571fd781ae01bbf7ef9ef040e0178b39617469019be08e883b4cd02",
                    "strip-components": 1
                }
            ]
        }
    ]
}
