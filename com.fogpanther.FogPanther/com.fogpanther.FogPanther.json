{
    "app-id": "com.fogpanther.FogPanther",
    "runtime": "org.gnome.Platform",
    "runtime-version": "48",
    "sdk": "org.gnome.Sdk",
    "command": "fogpanther",
    "finish-args": [
        "--share=ipc",
        "--socket=fallback-x11",
        "--socket=wayland",
        "--device=dri",
        "--filesystem=home"
    ],
    "modules": [
        {
            "name": "fogpanther",
            "buildsystem": "simple",
            "build-commands": [
                "cp -r bin/* /app/bin/",
                "cp -r lib/* /app/lib/",
                "cp -r share/* /app/share/"
            ],
            "sources": [
                {
                    "type": "archive",
                    "url": "https://www.fogpanther.com/releases/fogpanther-0.3.5-x86_64.tar.xz",
                    "sha256": "05b97f24a446b8432c494510bf160ef600d55a91c2a5e3368d1e5d5c7e400963",
                    "strip-components": 1
                }
            ]
        }
    ]
}
