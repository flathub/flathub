<!DOCTYPE node PUBLIC "-//freedesktop//DTD D-BUS Object Introspection 1.0//EN"
    "http://www.freedesktop.org/standards/dbus/1.0/introspect.dtd">
<!--
  Interface: pl.deno.kir.szafirhostproxy.NativeMessaging
  Service:   pl.deno.kir.szafirhostproxy
  Path:      /pl/deno/kir/SzafirHostProxy

  Used by flatpak-host-wrapper for browser native messaging.
  The proxy forwards stdin/stdout/stderr (as Unix fds) to a fresh
  pl.deno.kir.szafirhost process launched via the Flatpak Development API.
-->
<node>
  <interface name="pl.deno.kir.szafirhostproxy.NativeMessaging">
    <!--
      Link: called by the browser wrapper to establish a native messaging session.

      args:   Browser-supplied arguments (Chrome: 1 arg, Firefox: 2 args).
      fd_in:  File descriptor to use as stdin  (fd 0) for the host process.
      fd_out: File descriptor to use as stdout (fd 1) for the host process.
      fd_err: File descriptor to use as stderr (fd 2) for the host process.

      This method has NoReply=true; the caller should keep its process alive
      (e.g. via "sleep infinity") to hold the fd pipes open while the host runs.
    -->
    <method name="Link">
      <annotation name="org.freedesktop.DBus.Method.NoReply" value="true"/>
      <arg name="args"    type="as" direction="in"/>
      <arg name="fd_in"   type="h"  direction="in"/>
      <arg name="fd_out"  type="h"  direction="in"/>
      <arg name="fd_err"  type="h"  direction="in"/>
    </method>
  </interface>
</node>
