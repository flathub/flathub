{
    "id": "ca.wiilink.Patcher",

    "runtime": "org.kde.Platform",
    "runtime-version": "6.10",
    "sdk": "org.kde.Sdk",
    "base": "io.qt.PySide.BaseApp",
    "base-version": "6.10",

    "build-options": {
        "env": {
            "BASEAPP_REMOVE_WEBENGINE": "1",
            "BASEAPP_DISABLE_NUMPY": "1"
        }
    },

    "cleanup-commands": [
        "/app/cleanup-BaseApp.sh"
    ],

    "command": "WiiLinkPatcherGUI",
    "finish-args": [
        "--socket=fallback-x11",
        "--socket=wayland",
        "--device=dri",
        "--share=ipc",
        "--share=network"
    ],
    "modules": [
        "python3-requirements.json",

        {
            "name": "WiiLinkPatcherGUI",
            "buildsystem" : "simple",
            "build-commands" : [
                "pyside6-project build ./pyproject.toml",
                "pip3 install --no-build-isolation --prefix=/app .",
                "install -Dm0644 flatpak/icons/16x16.png /app/share/icons/hicolor/16x16/apps/ca.wiilink.Patcher.png",
                "install -Dm0644 flatpak/icons/32x32.png /app/share/icons/hicolor/32x32/apps/ca.wiilink.Patcher.png",
                "install -Dm0644 flatpak/icons/48x48.png /app/share/icons/hicolor/48x48/apps/ca.wiilink.Patcher.png",
                "install -Dm0644 flatpak/icons/64x64.png /app/share/icons/hicolor/64x64/apps/ca.wiilink.Patcher.png",
                "install -Dm0644 flatpak/icons/128x128.png /app/share/icons/hicolor/128x128/apps/ca.wiilink.Patcher.png",
                "install -Dm0644 flatpak/icons/256x256.png /app/share/icons/hicolor/256x256/apps/ca.wiilink.Patcher.png",
                "install -Dm0644 flatpak/icons/512x512.png /app/share/icons/hicolor/512x512/apps/ca.wiilink.Patcher.png",
                "install -Dm0644 flatpak/ca.wiilink.Patcher.desktop /app/share/applications/ca.wiilink.Patcher.desktop",
                "install -Dm0644 flatpak/ca.wiilink.Patcher.metainfo.xml /app/share/metainfo/ca.wiilink.Patcher.metainfo.xml"
            ],
            "sources": [
                {
                    "type": "archive",
                    "url": "https://github.com/WiiLink24/WiiLink-Patcher-GUI/archive/refs/tags/v1.4.1.tar.gz",
                    "sha256": "d2820dcbd1f63680b3074a443ea5b3e4dddc05c48dc0960410fede22974871c7"
                }
            ]
        }
    ]
}
