{
  "app-id": "com.martinwaweru.RocketLander",
  "runtime": "org.gnome.Platform",
  "runtime-version": "44",
  "sdk": "org.gnome.Sdk",
  "command": "/app/bin/RocketLander",
  "modules": [
    {
      "name": "rocket-lander",
      "buildsystem": "simple",
      "build-commands": [
     	 "mkdir -p /app/bin",
   	 "./Rocket_Lander-x86_64.AppImage --appimage-extract",
   	 "cp -r squashfs-root/* /app/bin/",
   	 "mv /app/bin/AppRun /app/bin/RocketLander",
   	 "chmod +x /app/bin/RocketLander"
      ],
      "sources": [
        {
          "type": "file",
          "path": "Rocket_Lander-x86_64.AppImage"
        }
      ]
    }
  ]
}

