[Desktop Entry]
Version=1.0
Type=Application
Name=qBittorrent Companion
Comment=Native desktop remote for qBittorrent
# The %U is the placeholder for the Magnet URL passed by the browser
Exec=qBittorrentCompanion.Desktop %U
Icon=io.github.axeia.qBittorrentCompanion
Terminal=false
Categories=Network;FileTransfer;P2P;
Keywords=torrent;qbittorrent;remote;
# This line tells Linux which protocols this app handles
MimeType=x-scheme-handler/magnet;application/x-bittorrent;