<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>chat.gratonite.Desktop</id>
  <name>Gratonite</name>
  <summary>Talk, play, hang out</summary>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>LicenseRef-proprietary=https://gratonite.chat/terms</project_license>
  <developer id="chat.gratonite">
    <name>Gratonite</name>
  </developer>

  <description>
    <p>
      Gratonite is a free messaging, voice, and video app for communities.
      Whether you're part of a gaming group, school club, art community, or
      just a handful of friends — Gratonite makes it easy to talk every day.
    </p>
    <p>
      Organize conversations into channels, hop into voice chat when you're
      free, share your screen, and build your community with moderation tools,
      custom roles, and more.
    </p>
    <p>
      The Flatpak version runs in a sandbox for better security and privacy.
      Game activity detection is not available in the sandboxed version.
    </p>
  </description>

  <url type="homepage">https://gratonite.chat</url>
  <url type="bugtracker">https://gratonite.chat/feedback</url>
  <url type="help">https://gratonite.chat/help</url>

  <launchable type="desktop-id">chat.gratonite.Desktop.desktop</launchable>

  <provides>
    <binary>chat.gratonite.Desktop</binary>
  </provides>

  <categories>
    <category>Network</category>
    <category>Chat</category>
    <category>InstantMessaging</category>
  </categories>

  <supports>
    <control>pointing</control>
    <control>keyboard</control>
  </supports>

  <content_rating type="oars-1.1">
    <content_attribute id="social-chat">intense</content_attribute>
    <content_attribute id="social-audio">intense</content_attribute>
    <content_attribute id="social-contacts">intense</content_attribute>
    <content_attribute id="social-info">moderate</content_attribute>
  </content_rating>

  <releases>
    <release version="1.0.7" date="2026-03-18">
      <description>
        <p>Latest stable release.</p>
      </description>
    </release>
  </releases>

  <screenshots>
    <screenshot type="default">
      <image>https://gratonite.chat/app/assets/screenshots/chat.png</image>
      <caption>Chatting in a Gratonite server</caption>
    </screenshot>
    <screenshot>
      <image>https://gratonite.chat/app/assets/screenshots/voice.png</image>
      <caption>Gratonite home dashboard</caption>
    </screenshot>
  </screenshots>
</component>
