<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>io.github.rdoxalis.bluesoundplayer</id>

  <name>BlueSound Controller</name>
  <summary>Control BluOS and Sonos multi-room audio players</summary>

  <metadata_license>MIT</metadata_license>
  <project_license>MIT</project_license>

  <description>
    <p>
      BlueSound Controller lets you discover and control BluOS and Sonos audio
      players on your local network.
    </p>
    <p>Features:</p>
    <ul>
      <li>Automatic network scanning to find all BluOS and Sonos players</li>
      <li>Playback control: play, pause, stop, next, previous</li>
      <li>Volume control with live updates</li>
      <li>Access and play presets/favorites from your players</li>
      <li>Transfer radio streams between players</li>
      <li>Player grouping for multi-room audio</li>
      <li>Multi-language support (English, German, Swahili)</li>
      <li>Light and dark theme</li>
    </ul>
    <p>
      No cloud account required. All communication stays on your local network.
    </p>
  </description>

  <launchable type="desktop-id">io.github.rdoxalis.bluesoundplayer.desktop</launchable>

  <url type="homepage">https://github.com/rdOxalis/bluesoundplayer</url>
  <url type="bugtracker">https://github.com/rdOxalis/bluesoundplayer/issues</url>
  <url type="vcs-browser">https://github.com/rdOxalis/bluesoundplayer</url>
  <url type="donation">https://paypal.me/CarlDarkman</url>

  <developer id="io.github.rdoxalis">
    <name>rdOxalis</name>
  </developer>

  <content_rating type="oars-1.1" />

  <releases>
    <release version="1.0.0" date="2026-03-13">
      <description>
        <p>Initial release</p>
      </description>
    </release>
  </releases>

  <requires>
    <display_length compare="ge">768</display_length>
  </requires>

  <supports>
    <control>pointing</control>
    <control>keyboard</control>
  </supports>
</component>
