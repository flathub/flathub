{
    "id": "org.kde.konqueror",
    "runtime": "org.kde.Platform",
    "runtime-version": "6.10",
    "sdk": "org.kde.Sdk",
    "base": "io.qt.qtwebengine.BaseApp",
    "base-version": "6.10",
    "command": "konqueror",
    "rename-icon": "konqueror",
    "rename-appdata-file": "org.kde.konqueror.metainfo.xml",
    "finish-args": [
        "--device=dri",
        "--share=ipc",
        "--socket=fallback-x11",
        "--socket=wayland",
        "--share=network",
        "--socket=pulseaudio"
    ],
    "cleanup": [
        "/include",
        "/lib/cmake",
        "/share/qlogging-categories6"
    ],
    "modules": [
        {
            "name": "kdesu",
            "buildsystem": "cmake-ninja",
            "sources": [
                {
                    "type": "archive",
                    "url": "https://download.kde.org/stable/frameworks/6.24/kdesu-6.24.0.tar.xz",
                    "sha256": "be5add002c4f3d96c2632ecebbf5633d9792f9d13d61a91a6a2c349540a807d3",
                    "x-checker-data": {
                        "type": "anitya",
                        "project-id": 8762,
                        "stable-only": true,
                        "url-template": "https://download.kde.org/stable/frameworks/$major.$minor/kdesu-$version.tar.xz"
                    }
                }
            ]
        },
        {
            "name": "konqueror",
            "buildsystem": "cmake-ninja",
            "sources": [
                {
                    "type": "archive",
                    "url": "https://download.kde.org/stable/release-service/26.04.0/src/konqueror-26.04.0.tar.xz",
                    "sha256": "c6c3e053caf5cd2e01baf155f9579213f7fca3f85d8ef1edc95396a4fff08bfa",
                    "x-checker-data": {
                        "type": "anitya",
                        "project-id": 8763,
                        "stable-only": true,
                        "url-template": "https://download.kde.org/stable/release-service/$version/src/konqueror-$version.tar.xz"
                    }
                }
            ]
        }
    ]
}
