{
  "id": "io.github.daytimeforninja.Slowly",
  "runtime": "org.freedesktop.Platform",
  "runtime-version": "25.08",
  "base": "com.system76.Cosmic.BaseApp",
  "base-version": "stable",
  "sdk": "org.freedesktop.Sdk",
  "sdk-extensions": ["org.freedesktop.Sdk.Extension.rust-stable"],
  "command": "slowly",
  "finish-args": [
    "--socket=wayland",
    "--socket=fallback-x11",
    "--share=ipc",
    "--device=dri",
    "--socket=pulseaudio",
    "--filesystem=xdg-config/cosmic:rw",
    "--filesystem=xdg-config/slowly:rw",
    "--talk-name=com.system76.CosmicSettingsDaemon"
  ],
  "build-options": {
    "append-path": "/usr/lib/sdk/rust-stable/bin",
    "env": {
      "CARGO_HOME": "/run/build/slowly/cargo"
    }
  },
  "modules": [
    {
      "name": "slowly",
      "buildsystem": "simple",
      "build-commands": [
        "cargo build --release --offline",
        "install -Dm755 target/release/slowly /app/bin/slowly",
        "install -Dm644 data/io.github.daytimeforninja.Slowly.desktop /app/share/applications/io.github.daytimeforninja.Slowly.desktop",
        "install -Dm644 data/io.github.daytimeforninja.Slowly.metainfo.xml /app/share/metainfo/io.github.daytimeforninja.Slowly.metainfo.xml",
        "install -Dm644 data/io.github.daytimeforninja.Slowly.svg /app/share/icons/hicolor/scalable/apps/io.github.daytimeforninja.Slowly.svg"
      ],
      "sources": [
        {
          "type": "git",
          "url": "https://github.com/daytimeforninja/slowly.git",
          "tag": "v0.1.0",
          "commit": "541807c49b8fbc5f6de7ab3b105865f3462ba800"
        },
        "cargo-sources.json"
      ]
    }
  ]
}
