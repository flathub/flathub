{
    "name" : "tesseract",
    "config-opts" : [
        "--disable-static",
        "--disable-graphics",
        "--enable-legacy"
    ],
    "cleanup" : [
        "/include",
        "/lib/pkgconfig",
        "*.la"
    ],
    "sources" : [
        {
            "type" : "git",
            "url" : "https://github.com/tesseract-ocr/tesseract.git",
            "tag" : "5.5.0"
        }
    ],
    "modules" : [
        {
            "name" : "tessdata-fast",
            "buildsystem" : "simple",
            "build-commands" : [
                "mkdir -p /app/share/tessdata",
                "cp eng.traineddata ita.traineddata /app/share/tessdata/"
            ],
            "sources" : [
                {
                    "type" : "file",
                    "url" : "https://github.com/tesseract-ocr/tessdata_fast/raw/main/eng.traineddata",
                    "sha256" : "7d4322bd2a7749724879683fc3912cb542f19906c83bcc1a52132556427170b2"
                },
                {
                    "type" : "file",
                    "url" : "https://github.com/tesseract-ocr/tessdata_fast/raw/main/ita.traineddata",
                    "sha256" : "b8f89e1e785118dac4d51ae042c029a64edb5c3ee42ef73027a6d412748d8827"
                }
            ]
        }
    ]
}
