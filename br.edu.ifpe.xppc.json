          "sha256" : "b1523c7570b8cc71b43974d70df3179dc5d3313fa90919bf8c557233bcbf9043",
          "type" : "file"
        },
        {
          "url" : "https://raw.githubusercontent.com/Nasc1mento/xppc-app/master/packaging/flatpak/xppc.sh",
          "sha256" : "446d96e756f596e5324c8f8fa572600b71bdcd74e1b85729450c04993de0f27e",
          "type" : "file"
        },
        {
          "url" : "https://raw.githubusercontent.com/Nasc1mento/xppc-app/master/packaging/flatpak/br.edu.ifpe.xppc.desktop",
          "sha256" : "bfc4073540811fe672d24390a941605ca0d01371ade0dfdb991770d0b4dfb573",
          "type" : "file"
        },
        {
          "url" : "https://raw.githubusercontent.com/Nasc1mento/xppc-app/master/packaging/flatpak/br.edu.ifpe.xppc.svg",
          "sha256" : "7af55c755e70742e34b73e404a335dc965d86c9709f76d66d0909917fc56821e",
          "type" : "file"
        }
      ],
      "build-commands" : [
        "install -Dm755 xppc.sh /app/bin/xppc",
        "install -Dm644 xppc-1.0.0-all.jar /app/bin/xppc-1.0.0-all.jar",
        "install -D br.edu.ifpe.xppc.desktop /app/share/applications/br.edu.ifpe.xppc.desktop",
        "install -D br.edu.ifpe.xppc.svg /app/share/icons/hicolor/scalable/apps/br.edu.ifpe.xppc.svg"
      ]
    }
  ],
  "sdk-extensions" : [
