{
  "id": "com.nawakarit.ipdf",
  "runtime": "org.freedesktop.Platform",
  "runtime-version": "25.08",
  "sdk": "org.freedesktop.Sdk//25.08",
  "command": "ipdf",
  "finish-args": [
    "--filesystem=home",
    "--share=ipc",
    "--socket=fallback-x11",
    "--socket=wayland"
  ],
  "modules": [
    {
      "name": "ipdf",
      "buildsystem": "simple",
      "build-commands": [
        "install -D ipdf /app/bin/ipdf",
        "install -D flatpak/com.nawakarit.ipdf.desktop /app/share/applications/com.nawakarit.ipdf.desktop",
        "install -D flatpak/com.nawakarit.ipdf.metainfo.xml /app/share/metainfo/com.nawakarit.ipdf.metainfo.xml",
        "install -D icons/icon-16.png /app/share/icons/hicolor/16x16/apps/com.nawakarit.ipdf.png",
        "install -D icons/icon-32.png /app/share/icons/hicolor/32x32/apps/com.nawakarit.ipdf.png",
        "install -D icons/icon-64.png /app/share/icons/hicolor/64x64/apps/com.nawakarit.ipdf.png",
        "install -D icons/icon-128.png /app/share/icons/hicolor/128x128/apps/com.nawakarit.ipdf.png",
        "install -D icons/icon-256.png /app/share/icons/hicolor/256x256/apps/com.nawakarit.ipdf.png",
        "install -D icons/icon-512.png /app/share/icons/hicolor/512x512/apps/com.nawakarit.ipdf.png"


      ],
      "sources": [
        {

          "type": "git",
          "url": "https://github.com/nawakarit-VOID/ipdf.git",
          "tag": "v1.1.0"
          
        }

      ]
    }
  ]
}
