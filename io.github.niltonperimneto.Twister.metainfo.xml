<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>io.github.niltonperimneto.Twister</id>

  <name>Twister</name>
  <summary>Configure gaming mice on Linux</summary>

  <developer id="io.github.niltonperimneto">
    <name>Nilton Perim Neto</name>
  </developer>

  <metadata_license>CC0-1.0</metadata_license>
  <project_license>GPL-3.0-or-later</project_license>

  <description>
    <p>
      Twister is a modern, desktop-agnostic graphical interface for configuring
      gaming mice on Linux. It communicates with the ratbagd daemon over D-Bus
      to manage DPI resolution stages, button mappings, LED lighting, and
      hardware profiles for supported devices.
    </p>
    <p>
      Built with Tauri and Svelte, Twister works on any Linux desktop
      environment — GNOME, KDE Plasma, Sway, Hyprland, or a bare window
      manager — with no compositor plugins or desktop extensions required.
    </p>
    <p>
      Supported manufacturers include Logitech, ASUS ROG, SteelSeries, Roccat,
      Glorious, Sinowealth, and others. Changes are staged locally and written
      to hardware on demand, so you can review your configuration before
      committing.
    </p>
  </description>

  <launchable type="desktop-id">io.github.niltonperimneto.Twister.desktop</launchable>

  <url type="homepage">https://github.com/niltonperimneto/twister</url>
  <url type="bugtracker">https://github.com/niltonperimneto/twister/issues</url>
  <url type="vcs-browser">https://github.com/niltonperimneto/twister</url>

  <branding>
    <color type="primary" scheme_preference="light">#e0e0e0</color>
    <color type="primary" scheme_preference="dark">#1a1a2e</color>
  </branding>

