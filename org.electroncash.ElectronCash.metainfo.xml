<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
	<id>org.electroncash.ElectronCash</id>
	<name>Electron Cash</name>
	<developer id="org.electroncash">
		<name>The Electron Cash Developers</name>
	</developer>
	<summary>Lightweight Bitcoin Cash Client</summary>
	<description>
		<p>**This is a community package of Electron Cash and not officially supported by Electron-Cash.**</p>
		<p>Electron Cash is an SPV wallet for Bitcoin Cash</p>
		<p>Control your own private keys. Easily back up your wallet with a mnemonic seed phrase. Enjoy high security without downloading the blockchain or running a full node.</p>
		<p>Features:</p>
		<ul>
			<li>Fast verification of transactions using SPV</li>
			<li>Non-custodial - you control your private keys</li>
			<li>Hardware wallet support (Trezor, Ledger, KeepKey, Satochip)</li>
			<li>Cold storage support</li>
			<li>Multi-signature wallets</li>
			<li>QR code scanning for payment requests</li>
			<li>Tor integration for enhanced privacy</li>
			<li>Plugin system for extensibility</li>
		</ul>
	</description>
	<keywords>
		<keyword>cryptocurrency</keyword>
		<keyword>finance</keyword>
		<keyword>bitcoin</keyword>
		<keyword>bitcoincash</keyword>
		<keyword>wallet</keyword>
		<keyword>SPV</keyword>
		<keyword>crypto</keyword>
	</keywords>
	<metadata_license>CC0-1.0</metadata_license>
	<project_license>MIT</project_license>
	<url type="homepage">https://www.electroncash.org/</url>
	<url type="bugtracker">https://github.com/Electron-Cash/Electron-Cash/issues</url>
	<url type="vcs-browser">https://github.com/Electron-Cash/Electron-Cash</url>
	<url type="donation">https://www.electroncash.org/donate</url>
	<url type="faq">https://www.electroncash.org/faq</url>
	<url type="contact">https://www.electroncash.org/contact</url>
	<screenshots>
		<screenshot type="default">
			<image type="source">https://electroncash.org/images/wallet-shot-3.png?v=0.01</image>
			<caption>Main wallet interface showing balance and transaction history</caption>
		</screenshot>
	</screenshots>
	<translation type="gettext">electron-cash</translation>
	<provides>
		<binary>electron-cash</binary>
		<mediatype>x-scheme-handler/bitcoincash</mediatype>
		<mediatype>x-scheme-handler/cashacct</mediatype>
		<python3>electroncash</python3>
		<python3>electroncash_gui</python3>
		<python3>electroncash_plugins</python3>
	</provides>
	<launchable type="desktop-id">org.electroncash.ElectronCash.desktop</launchable>
	<content_rating type="oars-1.1">
		<content_attribute id="money-gambling">intense</content_attribute>
	</content_rating>
	<branding>
		<color type="primary" scheme_preference="light">#3355aa</color>
		<color type="primary" scheme_preference="dark">#1a3d7a</color>
	</branding>
	<releases>
		<release version="4.4.3" date="2026-03-05">
			<url type="details">https://github.com/Electron-Cash/Electron-Cash/releases/tag/4.4.3</url>
			<description>
				<p>Expanded CashTokens support, metadata downloads from BCMR servers, and various bug fixes.</p>
			</description>
		</release>
		<release version="4.4.2" date="2024-12-06">
			<url type="details">https://github.com/Electron-Cash/Electron-Cash/releases/tag/4.4.2</url>
			<description>
				<p>CashTokens support, RPA (Receive Pay Any address), and performance improvements.</p>
			</description>
		</release>
		<release version="4.4.1" date="2024-09-25">
			<url type="details">https://github.com/Electron-Cash/Electron-Cash/releases/tag/4.4.1</url>
			<description>
				<p>CashFusion improvements, hardware wallet updates, and bug fixes.</p>
			</description>
		</release>
	</releases>
</component>
