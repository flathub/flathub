<component type="desktop-application">
  <id>org.sorobanexam.anzan</id>

  <name>Anzan</name>
  <summary>Exercise your mental calculation skills</summary>
  <metadata_license>MIT</metadata_license>
  <project_license>GPL-3.0-or-later</project_license>

  <developer id="org.sorobanexam">
    <name>solsTiCe d'Hiver</name>
  </developer>

  <description>
    <p>Add or subtract the flashing numbers displayed on screen or voiced over by a TTS API. This was designed to help you exercise mental math while visualizing a soroban in your head, but you can also use it to train your soroban skills.</p>
  </description>

  <launchable type="desktop-id">org.sorobanexam.anzan.desktop</launchable>
  <screenshots>
    <screenshot type="default">
      <image>https://raw.githubusercontent.com/solsticedhiver/anzan/23478ed18917746deebe46650b504428ddf40b60/flatpak/2025-04-11T23-21.png</image>
      <caption>The main screen while flashing a number on screen</caption>
    </screenshot>
    <screenshot>
      <image>https://raw.githubusercontent.com/solsticedhiver/anzan/23478ed18917746deebe46650b504428ddf40b60/flatpak/2025-04-15T23-47.png</image>
      <caption>The settings screen</caption>
    </screenshot>
  </screenshots>

  <url type="homepage">https://github.com/solsticedhiver/anzan</url>
  <url type="bugtracker">https://github.com/solsticedhiver/anzan/issues</url>
  <update_contact>solstice.dhiver@sorobanexam.org</update_contact>

  <content_rating type="oars-1.1">
    <content_attribute id="social-info">mild</content_attribute>
  </content_rating>

  <icon type="stock">org.sorobanexam.anzan</icon>

  <categories>
    <category>Education</category>
    <category>Game</category>
  </categories>

  <releases>
    <release version="0.6.2" date="2026-03-19">
      <description>
        <p>Release description</p>
        <ul>
          <li>Switch audio library to audioplayers</li>
        </ul>
      </description>
    </release>
  </releases>

  <supports>
    <control>keyboard</control>
    <control>pointing</control>
    <control>touch</control>
  </supports>
  <requires>
    <display_length compare="ge">360</display_length>
  </requires>
</component>
