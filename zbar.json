{
    "name" : "zbar",
    "buildsystem" : "simple",
    "build-commands" : [
        "autoreconf -vfi",
        "./configure --prefix=/app --disable-static --without-gtk --without-qt --without-qt5 --without-xv --without-dbus --without-java --without-python --without-imagemagick --disable-video --disable-doc --with-introspection=no --enable-codes=qrcode,code128,code39",
        "make -j$(nproc)",
        "make install"
    ],
    "cleanup" : [
        "/bin",
        "/include",
        "/lib/pkgconfig",
        "/share/doc",
        "/share/man",
        "*.la"
    ],
    "sources" : [
        {
            "type" : "git",
            "url" : "https://github.com/mchehab/zbar.git",
            "tag" : "0.23.93"
        }
    ]
}
