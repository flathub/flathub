{
  "app-id": "io.github.scerelli.Documentius",
  "runtime": "org.kde.Platform",
  "runtime-version": "6.10",
  "sdk": "org.kde.Sdk",
  "base": "io.qt.PySide.BaseApp",
  "base-version": "6.10",
  "command": "documentius",
  "cleanup-commands": [
    "/app/cleanup-BaseApp.sh"
  ],
  "finish-args": [
    "--share=ipc",
    "--socket=fallback-x11",
    "--socket=wayland",
    "--device=dri"
  ],
  "build-options": {
    "env": {
      "BASEAPP_REMOVE_WEBENGINE": "1"
    }
  },
  "modules": [
    {
      "name": "python3-setuptools",
      "buildsystem": "simple",
      "build-commands": [
        "pip3 install --no-index --find-links=. --prefix=${FLATPAK_DEST} setuptools"
      ],
      "sources": [
        {
          "type": "file",
          "url": "https://files.pythonhosted.org/packages/9d/76/f789f7a86709c6b087c5a2f52f911838cad707cc613162401badc665acfe/setuptools-82.0.1-py3-none-any.whl",
          "sha256": "a59e362652f08dcd477c78bb6e7bd9d80a7995bc73ce773050228a348ce2e5bb"
        }
      ]
    },
    {
      "name": "python3-pymupdf",
      "buildsystem": "simple",
      "build-commands": [
        "PYMUPDF_SETUP_MUPDF_TGZ=${FLATPAK_BUILDER_BUILDDIR}/mupdf-1.27.2-source.tar.gz PYMUPDF_SETUP_MUPDF_OVERWRITE_DATA=0 pip3 install --no-build-isolation --prefix=${FLATPAK_DEST} ."
      ],
      "sources": [
        {
          "type": "archive",
          "url": "https://files.pythonhosted.org/packages/a4/fb/d80374ab091ab7ad5a5e7981a45c877ae094db668c1ab4d30f1109a4ec6a/pymupdf-1.27.2.tar.gz",
          "sha256": "37fc9cedeafb40839f86a074d4d9feab725144bdd4bbfd20308ff8957e2b10af"
        },
        {
          "type": "file",
          "url": "https://casper.mupdf.com/downloads/archive/mupdf-1.27.2-source.tar.gz",
          "sha256": "553867b135303dc4c25ab67c5f234d8e900a0e36e66e8484d99adc05fe1e8737"
        }
      ]
    },
    {
      "name": "python3-qtawesome",
      "buildsystem": "simple",
      "build-commands": [
        "pip3 install --no-index --find-links=. --prefix=${FLATPAK_DEST} QtPy QtAwesome"
      ],
      "sources": [
        {
          "type": "file",
          "url": "https://files.pythonhosted.org/packages/69/76/37c0ccd5ab968a6a438f9c623aeecc84c202ab2fabc6a8fd927580c15b5a/QtPy-2.4.3-py3-none-any.whl",
          "sha256": "72095afe13673e017946cc258b8d5da43314197b741ed2890e563cf384b51aa1"
        },
        {
          "type": "file",
          "url": "https://files.pythonhosted.org/packages/11/ef/b7c8c38d1717e2fcb777678ed11568b31062e34550e23297cc32e9e1105e/qtawesome-1.4.1-py3-none-any.whl",
          "sha256": "6a45f0ec214e0cd7c9c867772ec596799dcd5fae00a4b17717ff0d95d2e3fb64"
        }
      ]
    },
    {
      "name": "documentius",
      "buildsystem": "simple",
      "build-commands": [
        "pip3 install --no-build-isolation --prefix=${FLATPAK_DEST} .",
        "install -Dm644 packaging/io.github.scerelli.Documentius.desktop ${FLATPAK_DEST}/share/applications/io.github.scerelli.Documentius.desktop",
        "install -Dm644 packaging/io.github.scerelli.Documentius.metainfo.xml ${FLATPAK_DEST}/share/metainfo/io.github.scerelli.Documentius.metainfo.xml",
        "install -Dm644 data/icons/documentius.svg ${FLATPAK_DEST}/share/icons/hicolor/scalable/apps/io.github.scerelli.Documentius.svg",
        "install -Dm644 data/icons/io.github.scerelli.Documentius.256.png ${FLATPAK_DEST}/share/icons/hicolor/256x256/apps/io.github.scerelli.Documentius.png",
        "install -Dm644 data/icons/io.github.scerelli.Documentius.128.png ${FLATPAK_DEST}/share/icons/hicolor/128x128/apps/io.github.scerelli.Documentius.png",
        "install -Dm644 LICENSE ${FLATPAK_DEST}/share/licenses/io.github.scerelli.Documentius/LICENSE"
      ],
      "sources": [
        {
          "type": "archive",
          "url": "https://github.com/scerelli/documentius/releases/download/v0.0.1/documentius-0.0.1.tar.gz",
          "sha256": "244a36e47cebc8a1895b0775813b716f594fcbd69a09172e1843804aa45d6f81"
        }
      ]
    }
  ]
}
