{
  "app-id": "io.github.bhack.mini-eq",
  "runtime": "org.gnome.Platform",
  "runtime-version": "50",
  "sdk": "org.gnome.Sdk",
  "command": "mini-eq",
  "finish-args": [
    "--socket=fallback-x11",
    "--socket=wayland",
    "--share=ipc",
    "--device=dri",
    "--filesystem=xdg-run/pipewire-0:ro",
    "--env=PIPEWIRE_MODULE_DIR=/app/lib/pipewire-0.3:/usr/lib/x86_64-linux-gnu/pipewire-0.3:/usr/lib/aarch64-linux-gnu/pipewire-0.3:/usr/lib/pipewire-0.3",
    "--env=SPA_PLUGIN_DIR=/app/lib/spa-0.2:/usr/lib/x86_64-linux-gnu/spa-0.2:/usr/lib/aarch64-linux-gnu/spa-0.2:/usr/lib/spa-0.2"
  ],
  "cleanup": [
    "/include",
    "/etc/bash_completion.d",
    "/lib/pkgconfig",
    "/share/doc",
    "/share/gtk-doc",
    "/share/locale",
    "/share/man",
    "/share/pkgconfig",
    "*.a",
    "*.la"
  ],
  "modules": [
    {
      "name": "pipewire-filter-chain-module",
      "buildsystem": "simple",
      "build-commands": [
        "meson setup _build --prefix=/app --libdir=lib -Dauto_features=disabled -Ddocs=disabled -Dman=disabled -Dexamples=disabled -Dtests=disabled -Dinstalled_tests=disabled -Dgstreamer=disabled -Dgstreamer-device-provider=disabled -Dsession-managers=[] -Dsystemd-system-service=disabled -Dsystemd-user-service=disabled -Dlibsystemd=disabled -Dlogind=disabled -Dpipewire-alsa=disabled -Dpipewire-jack=disabled -Dpipewire-v4l2=disabled -Dselinux=disabled -Dspa-plugins=enabled -Daudioconvert=enabled -Daudiomixer=disabled -Dcontrol=disabled -Dsupport=disabled -Dalsa=disabled -Dbluez5=disabled -Djack=disabled -Dv4l2=disabled -Dlibcamera=disabled -Dvulkan=disabled -Dffmpeg=disabled -Dudev=disabled -Ddbus=disabled -Dsdl2=disabled -Dsndfile=disabled -Dlibmysofa=disabled -Dlibpulse=disabled -Droc=disabled -Davahi=disabled -Draop=disabled -Dreadline=disabled -Decho-cancel-webrtc=disabled -Dlibusb=disabled -Dx11=disabled -Dx11-xfixes=disabled -Dlibcanberra=disabled -Davb=disabled -Dgsettings=disabled -Dcompress-offload=disabled -Dopus=disabled -Dlibffado=disabled -Dgsettings-pulse-schema=disabled -Dsnap=disabled -Debur128=disabled -Dfftw=disabled -Dlv2=disabled -Donnxruntime=disabled -Daudiotestsrc=disabled -Dvideoconvert=disabled -Dvideotestsrc=disabled -Dpw-cat=disabled -Dpw-cat-ffmpeg=disabled -Dlegacy-rtkit=false -Drlimits-install=false -Dflatpak=enabled",
        "ninja -C _build src/modules/libpipewire-module-filter-chain.so spa/plugins/filter-graph/libspa-filter-graph.so spa/plugins/filter-graph/libspa-filter-graph-plugin-builtin.so",
        "install -Dm755 _build/src/modules/libpipewire-module-filter-chain.so ${FLATPAK_DEST}/lib/pipewire-0.3/libpipewire-module-filter-chain.so",
        "install -Dm755 _build/spa/plugins/filter-graph/libspa-filter-graph.so ${FLATPAK_DEST}/lib/spa-0.2/filter-graph/libspa-filter-graph.so",
        "install -Dm755 _build/spa/plugins/filter-graph/libspa-filter-graph-plugin-builtin.so ${FLATPAK_DEST}/lib/spa-0.2/filter-graph/libspa-filter-graph-plugin-builtin.so"
      ],
      "sources": [
        {
          "type": "git",
          "url": "https://gitlab.freedesktop.org/pipewire/pipewire.git",
          "tag": "1.6.1",
          "commit": "b7341d068947225fcdf62d39277606e8516d7f52"
        }
      ]
    },
    {
      "name": "wireplumber",
      "buildsystem": "meson",
      "config-opts": [
        "--libdir=lib",
        "-Dintrospection=enabled",
        "-Ddoc=disabled",
        "-Dmodules=false",
        "-Ddaemon=false",
        "-Dtools=false",
        "-Dtests=false",
        "-Ddbus-tests=false",
        "-Dsystemd=disabled",
        "-Dsystemd-system-service=false",
        "-Dsystemd-user-service=false",
        "-Delogind=disabled"
      ],
      "sources": [
        {
          "type": "git",
          "url": "https://gitlab.freedesktop.org/pipewire/wireplumber.git",
          "tag": "0.5.14",
          "commit": "07e730b279ac7a520699ae9f6b0797848a731b30"
        },
        {
          "type": "patch",
          "path": "flatpak/patches/wireplumber-0.5.14-tools-disabled-po.patch"
        }
      ]
    },
    {
      "name": "python3-jack-client",
      "buildsystem": "simple",
      "build-commands": [
        "python3 -m pip install --no-index --find-links=file://${PWD} --no-build-isolation --prefix=${FLATPAK_DEST} pycparser==3.0 cffi==2.0.0",
        "tar --no-same-owner -xf jack_client-0.5.5.tar.gz && cd jack_client-0.5.5 && PYTHONPATH=${FLATPAK_DEST}/lib/python3.13/site-packages python3 jack_build.py && mv _jack.py src/_jack.py && python3 -c \"from pathlib import Path; p = Path('setup.py'); text = p.read_text(); p.write_text(text.replace(\\\"py_modules=['jack']\\\", \\\"py_modules=['jack', '_jack']\\\"))\" && python3 -m pip install --no-index --no-deps --no-build-isolation --prefix=${FLATPAK_DEST} .",
        "install -Dm644 ${FLATPAK_DEST}/lib/python3.13/site-packages/pycparser-3.0.dist-info/licenses/LICENSE ${FLATPAK_DEST}/share/licenses/${FLATPAK_ID}/python3-jack-client/pycparser/LICENSE",
        "install -Dm644 ${FLATPAK_DEST}/lib/python3.13/site-packages/cffi-2.0.0.dist-info/licenses/LICENSE ${FLATPAK_DEST}/share/licenses/${FLATPAK_ID}/python3-jack-client/cffi/LICENSE",
        "install -Dm644 ${FLATPAK_DEST}/lib/python3.13/site-packages/jack_client-0.5.5.dist-info/licenses/LICENSE ${FLATPAK_DEST}/share/licenses/${FLATPAK_ID}/python3-jack-client/JACK-Client/LICENSE"
      ],
      "sources": [
        {
          "type": "file",
          "url": "https://files.pythonhosted.org/packages/source/p/pycparser/pycparser-3.0.tar.gz",
          "sha256": "600f49d217304a5902ac3c37e1281c9fe94e4d0489de643a9504c5cdfdfc6b29"
        },
        {
          "type": "file",
          "url": "https://files.pythonhosted.org/packages/source/c/cffi/cffi-2.0.0.tar.gz",
          "sha256": "44d1b5909021139fe36001ae048dbdde8214afa20200eda0f64c068cac5d5529"
        },
        {
          "type": "file",
          "url": "https://files.pythonhosted.org/packages/source/J/JACK-Client/jack_client-0.5.5.tar.gz",
          "sha256": "e8482097e522f0e2ef0efb95c5662932e890340f8ea4ad66fce37c3ac9608426"
        }
      ]
    },
    {
      "name": "python3-numpy",
      "buildsystem": "simple",
      "build-commands": [
        "python3 -m pip install --no-index --find-links=file://${PWD} --no-deps --prefix=${FLATPAK_DEST} numpy==2.4.4",
        "mkdir -p ${FLATPAK_DEST}/share/licenses/${FLATPAK_ID}/python3-numpy",
        "cp -a ${FLATPAK_DEST}/lib/python3.13/site-packages/numpy-2.4.4.dist-info/licenses/. ${FLATPAK_DEST}/share/licenses/${FLATPAK_ID}/python3-numpy/"
      ],
      "sources": [
        {
          "type": "file",
          "url": "https://files.pythonhosted.org/packages/d1/73/a9d864e42a01896bb5974475438f16086be9ba1f0d19d0bb7a07427c4a8b/numpy-2.4.4-cp313-cp313-manylinux_2_27_x86_64.manylinux_2_28_x86_64.whl",
          "sha256": "c901b15172510173f5cb310eae652908340f8dede90fff9e3bf6c0d8dfd92f83",
          "only-arches": [
            "x86_64"
          ]
        },
        {
          "type": "file",
          "url": "https://files.pythonhosted.org/packages/7d/90/8d23e3b0dafd024bf31bdec225b3bb5c2dbfa6912f8a53b8659f21216cbf/numpy-2.4.4-cp313-cp313-manylinux_2_27_aarch64.manylinux_2_28_aarch64.whl",
          "sha256": "45dbed2ab436a9e826e302fcdcbe9133f9b0006e5af7168afb8963a6520da103",
          "only-arches": [
            "aarch64"
          ]
        }
      ]
    },
    {
      "name": "mini-eq",
      "buildsystem": "simple",
      "build-commands": [
        "python3 -m pip install --no-index --no-deps --no-build-isolation --prefix=${FLATPAK_DEST} .",
        "install -Dm644 data/io.github.bhack.mini-eq.desktop -t ${FLATPAK_DEST}/share/applications",
        "install -Dm644 data/io.github.bhack.mini-eq.metainfo.xml -t ${FLATPAK_DEST}/share/metainfo",
        "for size in 64 128 256 512; do install -Dm644 src/mini_eq/assets/icons/hicolor/${size}x${size}/apps/io.github.bhack.mini-eq.png ${FLATPAK_DEST}/share/icons/hicolor/${size}x${size}/apps/io.github.bhack.mini-eq.png; done"
      ],
      "sources": [
        {
          "type": "archive",
          "url": "https://github.com/bhack/mini-eq/releases/download/v0.1.1/mini_eq-0.1.1.tar.gz",
          "sha256": "4877825276922915ecd7d64d9933c82855e48c849c4c4e8842f35b75075a84d4"
        }
      ]
    }
  ]
}
