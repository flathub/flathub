{
    "app-id": "com.github.ahsan3274.tauon-ai",
    "runtime": "org.freedesktop.Platform",
    "runtime-version": "24.08",
    "sdk": "org.freedesktop.Sdk",
    "sdk-extensions": [
        "org.freedesktop.Sdk.Extension.python3.12"
    ],
    "command": "tauon-ai",
    "finish-args": [
        "--share=ipc",
        "--socket=fallback-x11",
        "--socket=wayland",
        "--socket=pulseaudio",
        "--device=dri",
        "--share=network",
        "--filesystem=home",
        "--filesystem=xdg-music",
        "--filesystem=xdg-download",
        "--talk-name=org.freedesktop.Notifications",
        "--talk-name=org.mpris.MediaPlayer2.*",
        "--own-name=org.mpris.MediaPlayer2.tauon-ai",
        "--system-talk-name=org.freedesktop.UPower",
        "--env=PATH=/app/bin:/usr/bin:/app/extensions/python3.12/bin",
        "--env=PYTHONPATH=/app/lib/python3.12/site-packages",
        "--env=GDK_BACKEND=x11;wayland"
    ],
    "modules": [
        {
            "name": "tauon-ai",
            "buildsystem": "simple",
            "build-options": {
                "env": {
                    "CFLAGS": "-O2",
                    "LDFLAGS": "-O2"
                }
            },
            "build-commands": [
                "install -Dm644 extra/com.github.ahsan3274.tauon-ai.desktop /app/share/applications/com.github.ahsan3274.tauon-ai.desktop",
                "install -Dm644 extra/com.github.ahsan3274.tauon-ai.appdata.xml /app/share/metainfo/com.github.ahsan3274.tauon-ai.appdata.xml",
                "install -Dm644 extra/tauonmb.svg /app/share/icons/hicolor/scalable/apps/com.github.ahsan3274.tauon-ai.svg",
                "install -Dm755 extra/com.github.ahsan3274.tauon-ai.sh /app/bin/tauon-ai",
                "install -Dm755 lrclib-solver /app/bin/lrclib-solver",
                "python3.12 -m pip install --prefix=/app --no-deps .",
                "python3.12 -m compile_translations",
                "install -Dm755 src/nowplaying/build/TauonNowPlaying.app/Contents/MacOS/TauonNowPlaying /app/bin/TauonNowPlaying"
            ],
            "sources": [
                {
                    "type": "git",
                    "url": "https://github.com/ahsan3274/Tauon-AI-playlists.git",
                    "tag": "v9.2.0-ai",
                    "commit": "26b508f13de7f31f7978bb8e8dee32d5d2147bd7"
                },
                {
                    "type": "file",
                    "url": "https://github.com/Taiko2k/Tauon/releases/download/Extras/lrclib-solver-linux",
                    "sha256": "a8d7b6c64166d9dac6bc1ac6e903d2eaa90a5abf1c163250f290c3337cf6e8fb",
                    "dest-filename": "lrclib-solver"
                }
            ]
        }
    ]
}