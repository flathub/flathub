{
  "app-id": "com.martinwaweru.RocketLander",
  "runtime": "org.freedesktop.Platform",
  "runtime-version": "24.08",
  "sdk": "org.freedesktop.Sdk",
  "command": "RocketLander",
  "finish-args": [
    "--device=dri",
    "--socket=wayland",
    "--socket=fallback-x11",
    "--socket=pulseaudio"
  ],
  "modules": [
    {
      "name": "rocketlander",
      "buildsystem": "simple",
      "build-commands": [
        "install -Dm755 RocketLander /app/bin/RocketLander",
        "install -Dm644 com.martinwaweru.RocketLander.desktop /app/share/applications/com.martinwaweru.RocketLander.desktop",
        "install -Dm644 com.martinwaweru.RocketLander.metainfo.xml /app/share/metainfo/com.martinwaweru.RocketLander.metainfo.xml",
        "install -Dm644 rocketlander.png /app/share/icons/hicolor/256x256/apps/com.martinwaweru.RocketLander.png"
      ],
      "sources": [
        {
          "type": "archive",
          "url": "https://github.com/martonyaa/Rocket-Lander/releases/download/v1.0/RocketLander-1.0.tar.gz",
          "sha256": "8ead68eb6c6d4c57382aee99527dae9789a4de7c9b84251150c414449d8db02f"
        },
        {
          "type": "file",
          "path": "com.martinwaweru.RocketLander.desktop"
        },
        {
          "type": "file",
          "path": "com.martinwaweru.RocketLander.metainfo.xml"
        },
        {
          "type": "file",
          "path": "rocketlander.png"
        }
      ]
    }
  ]
}
