{
  "app-id": "com.martinwaweru.RocketLander",
  "runtime": "org.freedesktop.Platform",
  "runtime-version": "23.08",
  "sdk": "org.freedesktop.Sdk",
  "command": "/app/bin/RocketLander",
  
  "finish-args": [
    "--socket=x11",
    "--socket=wayland",
    "--device=dri",
    "--share=ipc",
    "--socket=pulseaudio",
    "--talk-name=org.freedesktop.Platform.Audio",
    "--filesystem=home",
    "--share=network",
    "--talk-name=org.freedesktop.Notifications"
  ],

  "modules": [
    {
      "name": "rocket-lander",
      "buildsystem": "simple",
      "build-commands": [
     	 "mkdir -p /app/bin",
   	 "./Rocket_Lander-x86_64.AppImage --appimage-extract",
   	 "cp -r squashfs-root/* /app/bin/",
   	 "mv /app/bin/AppRun /app/bin/RocketLander",
   	 "chmod +x /app/bin/RocketLander"
      ],
      "sources": [
        {
          "type": "file",
          "path": "Rocket_Lander-x86_64.AppImage"
        }
      ]
    }
  ]
}

