<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>org.fluxer.World</id>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>AGPL-3.0-or-later</project_license>
  <name>Fluxer World</name>
  <summary>Chat, voice, and community platform</summary>

  <description>
    <p>Fluxer World is a desktop client for the Fluxer messaging platform, an
    open-source community chat application with text channels, voice chat,
    direct messaging, and guild-based communities.</p>
    <p>Features include:</p>
    <ul>
      <li>Text and voice channels with real-time messaging</li>
      <li>Direct messages and group DMs</li>
      <li>Guild (server) management with roles and permissions</li>
      <li>File sharing and media embeds</li>
      <li>System tray integration and desktop notifications</li>
      <li>Native Wayland and X11 support</li>
    </ul>
  </description>

  <url type="homepage">https://fluxer.world</url>
  <url type="bugtracker">https://github.com/fluxerworld/fluxerworld/issues</url>
  <url type="donation">https://paypal.me/fluxerworld</url>

  <launchable type="desktop-id">org.fluxer.World.desktop</launchable>

  <provides>
    <binary>fluxer-world</binary>
  </provides>

  <categories>
    <category>Network</category>
    <category>InstantMessaging</category>
    <category>Chat</category>
  </categories>

  <keywords>
    <keyword>chat</keyword>
    <keyword>messaging</keyword>
    <keyword>voice</keyword>
    <keyword>community</keyword>
    <keyword>discord</keyword>
    <keyword>fluxer</keyword>
  </keywords>

  <screenshots>
    <screenshot type="default">
      <caption>Fluxer World main interface with friends list and direct messages</caption>
      <image>https://fluxer.world/screenshots/desktop-chat.png</image>
    </screenshot>
    <screenshot>
      <caption>User settings</caption>
      <image>https://fluxer.world/screenshots/desktop-settings.png</image>
    </screenshot>
    <screenshot>
      <caption>Bot settings and configuration</caption>
      <image>https://fluxer.world/screenshots/desktop-botsettings.png</image>
    </screenshot>
  </screenshots>

  <releases>
    <release version="1.0.0" date="2026-03-03">
      <description>
        <p>Initial release of Fluxer World desktop client.</p>
      </description>
    </release>
  </releases>

  <content_rating type="oars-1.1">
    <content_attribute id="social-chat">intense</content_attribute>
    <content_attribute id="social-audio">intense</content_attribute>
  </content_rating>

  <requires>
    <display_length compare="ge">768</display_length>
  </requires>

  <supports>
    <control>pointing</control>
    <control>keyboard</control>
  </supports>
</component>
