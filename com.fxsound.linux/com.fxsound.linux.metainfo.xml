<component type="desktop-application">
  <id>com.fxsound.linux</id>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>MIT</project_license>
  <name>FXSound for Linux</name>
  <summary>Audio enhancer with 10-band EQ and effects</summary>
  <description>
    <p>
      A free, open-source audio enhancer for Linux with a 10-band equalizer, effects, presets, and real-time audio visualization.
    </p>
    <p>Features:</p>
    <ul>
      <li>10-Band Parametric Equalizer (32Hz to 16kHz)</li>
      <li>5 Audio Effects: Fidelity, Ambiance, Dynamic Boost, 3D Surround, HyperBass</li>
      <li>10 Built-in Presets</li>
      <li>Real-time Audio Visualizer</li>
      <li>PulseAudio Integration</li>
    </ul>
  </description>
  <launchable type="desktop-id">com.fxsound.linux.desktop</launchable>
  <url type="homepage">https://github.com/Raul909/FXSound_For_Linux</url>
