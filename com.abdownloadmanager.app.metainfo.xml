<component type="desktop-application">
  <id>com.abdownloadmanager.app</id>
  <name>AB Download Manager</name>
  <summary>A fast and reliable download manager</summary>
  <description>
    <p>AB Download Manager is a desktop app that helps you manage and organize your downloads more efficiently than ever before.</p>
    <p>Features:</p>
    <ul>
      <li>Faster download speed with multiple connections</li>
      <li>Queues and schedulers</li>
      <li>Modern user interface with multiple themes</li>
      <li>Browser extensions integration</li>
      <li>Pause and resume functionality</li>
    </ul>
  </description>
  <launchable type="desktop-id">com.abdownloadmanager.app.desktop</launchable>
  <url type="homepage">https://abdownloadmanager.com</url>
