<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>com.tablio.app</id>

  <name>Tablio</name>
  <summary>Open-source desktop database client</summary>

  <metadata_license>CC0-1.0</metadata_license>
  <project_license>MIT</project_license>

  <url type="homepage">https://tablio.dasunnimantha.com</url>
  <url type="bugtracker">https://github.com/dasunNimantha/tablio/issues</url>
  <url type="vcs-browser">https://github.com/dasunNimantha/tablio</url>

  <description>
    <p>
      Tablio is a free, lightweight, native desktop application for managing databases.
      Connect to PostgreSQL, MySQL, MariaDB, SQLite, CockroachDB, TiDB, and
      Cassandra/ScyllaDB through a single unified interface.
    </p>
    <p>Features include:</p>
    <ul>
      <li>Browse schemas, tables, views, and functions</li>
      <li>SQL query editor with autocompletion and syntax highlighting</li>
      <li>Inline data editing with change tracking</li>
      <li>Import and export (CSV, JSON, SQL)</li>
      <li>Backup and restore</li>
      <li>Entity-relationship diagram viewer</li>
      <li>Server dashboard and role management</li>
      <li>Light and dark themes</li>
    </ul>
  </description>

  <launchable type="desktop-id">com.tablio.app.desktop</launchable>

  <branding>
    <color type="primary" scheme_preference="light">#4f94ef</color>
    <color type="primary" scheme_preference="dark">#1a3a5c</color>
  </branding>

  <content_rating type="oars-1.1" />

  <releases>
    <release version="0.1.16" date="2026-03-29">
      <description>
        <p>First public release.</p>
      </description>
    </release>
  </releases>

  <categories>
    <category>Development</category>
    <category>Database</category>
  </categories>

  <provides>
    <binary>tablio</binary>
  </provides>

  <requires>
    <display_length compare="ge">768</display_length>
  </requires>

  <supports>
    <control>pointing</control>
    <control>keyboard</control>
  </supports>
</component>
