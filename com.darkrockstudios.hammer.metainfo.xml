<?xml version="1.0" encoding="UTF-8" ?>
<component type="desktop-application">
	<id>com.darkrockstudios.hammer</id>
	<name>Hammer</name>
	<summary>A simple tool for building stories</summary>
	<metadata_license>MIT</metadata_license>
	<project_license>MIT</project_license>

	<description>
		<p>
			Hammer is a multi-platform story editor application designed for
			novelists and storytellers who want an offline-first writing experience
			with optional self-hosted synchronization.
		</p>
		<p>Features include:</p>
		<ul>
			<li>Offline-first design - your stories are always available</li>
			<li>Optional self-hosted synchronization</li>
			<li>Cross-platform support (Windows, Linux, macOS, Android)</li>
			<li>Scene-based story organization</li>
			<li>Timeline and encyclopedia features</li>
		</ul>
	</description>

	<launchable type="desktop-id">com.darkrockstudios.hammer.desktop</launchable>

