{
    "id": "org.kde.ishi",
    "runtime": "org.kde.Platform",
    "runtime-version": "6.8",
    "sdk": "org.kde.Sdk",
    "command": "ishi",
    "finish-args": [
        "--device=dri",
        "--own-name=org.mpris.MediaPlayer2.ISHI",
        "--share=ipc",
        "--share=network",
        "--socket=fallback-x11",
        "--socket=pulseaudio",
