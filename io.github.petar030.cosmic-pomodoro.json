{
  "app-id": "io.github.petar030.cosmic-pomodoro",
  "runtime": "org.freedesktop.Platform",
  "runtime-version": "24.08",
  "base": "com.system76.Cosmic.BaseApp",
  "base-version": "stable",
  "sdk": "org.freedesktop.Sdk",
  "sdk-extensions": [
    "org.freedesktop.Sdk.Extension.rust-stable"
  ],
  "command": "cosmic-pomodoro",
  "finish-args": [
    "--share=ipc",
    "--socket=fallback-x11",
    "--socket=wayland",
    "--device=dri",
    "--socket=pulseaudio",
    "--filesystem=xdg-config/cosmic:rw"
  ],
  "build-options": {
    "append-path": "/usr/lib/sdk/rust-stable/bin"
  },
  "modules": [
    {
      "name": "cosmic-pomodoro",
      "buildsystem": "simple",
      "build-options": {
        "env": {
          "CARGO_HOME": "/run/build/cosmic-pomodoro/cargo"
        }
      },
      "build-commands": [
        "cargo --offline fetch --manifest-path Cargo.toml --verbose",
        "cargo --offline build --release --verbose",
        "install -Dm755 ./target/release/cosmic-pomodoro -t /app/bin/",
        "install -Dm644 ./resources/icon.svg /app/share/icons/hicolor/scalable/apps/io.github.petar030.cosmic-pomodoro.svg",
        "install -Dm644 ./resources/icon-symbolic.svg /app/share/icons/hicolor/symbolic/apps/io.github.petar030.cosmic-pomodoro-symbolic.svg",
        "install -Dm644 ./resources/icon-128.png /app/share/icons/hicolor/128x128/apps/io.github.petar030.cosmic-pomodoro.png",
        "install -Dm644 ./resources/app.metainfo.xml /app/share/metainfo/io.github.petar030.cosmic-pomodoro.metainfo.xml",
        "install -Dm644 ./resources/app.desktop /app/share/applications/io.github.petar030.cosmic-pomodoro.desktop",
        "install -Dm644 ./resources/sounds/cosmic-pomodoro-notification.mp3 /app/share/sounds/cosmic-pomodoro/cosmic-pomodoro-notification.mp3"
      ],
      "sources": [
        {
          "type": "git",
          "url": "https://github.com/petar030/cosmic-pomodoro.git",
          "tag": "0.1.0",
          "commit": "cd576a9b8fb698b12642d4f43ecdc6fa2fb2cf0e"
        },
        "cargo-sources.json"
      ]
    }
  ]
}
