{
  "app-id": "dev.mooday.GstPipelineStudio",
  "runtime": "org.gnome.Platform",
  "runtime-version": "49",
  "sdk": "org.gnome.Sdk",
  "sdk-extensions": [
    "org.freedesktop.Sdk.Extension.rust-stable"
  ],
  "command": "gst-pipeline-studio",
  "finish-args": [
    "--socket=fallback-x11",
    "--socket=wayland",
    "--device=shm",
    "--device=all",
    "--share=ipc",
    "--share=network",
    "--filesystem=home",
    "--env=G_MESSAGES_DEBUG=none"
  ],
  "cleanup": [
    "/include",
    "/lib/pkgconfig",
    "*.la",
    "*.a"
  ],
  "build-options": {
    "append-path": "/usr/lib/sdk/rust-stable/bin",
    "strip": true
  },
  "modules": [
    {
      "name": "gst-pipeline-studio",
      "buildsystem": "meson",
      "sources": [
        {
          "type": "archive",
          "url": "https://gitlab.freedesktop.org/-/project/12908/uploads/9768db032ad41ded18cecdddd7b679c5/gst-pipeline-studio-0.5.0.tar.xz",
          "sha256": "4ada048abe6703c4276f7fc633069e8a3a41eafcb6636077573d66f700e31f97"
        }
      ]
    }
  ]
}
