[Desktop Entry]
Name=AstroBurst
GenericName=Astronomical Image Processor
Comment=Process JWST, Hubble, and Roman Space Telescope FITS/ASDF data
Exec=astroburst %F
Icon=com.astroburst.AstroBurst
Terminal=false
Type=Application
Categories=Science;Astronomy;Graphics;ImageProcessing;
Keywords=astronomy;fits;jwst;hubble;astrophotography;stacking;
MimeType=application/fits;image/fits;application/asdf;
StartupNotify=true
StartupWMClass=com.astroburst.AstroBurst
