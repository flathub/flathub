<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>fr.nationsglory.launcher</id>
  
  <name>Recube Launcher</name>
  <summary>Unofficial Launcher for NationsGlory</summary>

  <developer id="fr.nationsglory">
    <name>WebNations</name>
  </developer>
  
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>LicenseRef-proprietary=https://nationsglory.fr/cgu</project_license>
  
  <description>
     <p>**This is a community package of NationsGLory and not officially supported by WebNations and NationsGlory.**</p>
     <p> 
        Explore a universe where the creation and evolution of nations intersect. Build grandiose cities, forge alliances, and plunge into epic wars on Earth, the Moon, and even Mars.

        Get ready for a limitless gaming experience on NationsGlory, where your legend begins.
      </p>
  </description>

  <branding>
    <color type="primary" scheme_preference="light">#3584e4</color>
    <color type="primary" scheme_preference="dark">#1a5fb4</color>
  </branding>

  <content_rating type="oars-1.0">
    <content_attribute id="language-profanity">mild</content_attribute>
    <content_attribute id="language-humor">mild</content_attribute>
    <content_attribute id="social-chat">moderate</content_attribute>
    <content_attribute id="social-info">intense</content_attribute>
    <content_attribute id="money-purchasing">intense</content_attribute>
    <content_attribute id="money-advertising">mild</content_attribute>
    <content_attribute id="money-gambling">mild</content_attribute>
  </content_rating>

  <url type="homepage">https://nationsglory.fr/</url>
  <url type="bugtracker">https://github.com/flathub/fr.NationsGlory.Launcher/issues</url>
  
  <launchable type="desktop-id">fr.nationsglory.launcher.desktop</launchable>
  <screenshots>
    <screenshot type="default">
      <image>https://forgejo.maledict.me/Maledict/NationsGlory/raw/commit/6be6d53787e918026fd392e47e1a54381ee62296/screenshots/home.png</image>
      <caption>Homepage</caption>
    </screenshot>
    <screenshot>
      <image>https://forgejo.maledict.me/Maledict/NationsGlory/raw/commit/6be6d53787e918026fd392e47e1a54381ee62296/screenshots/game.png</image>
      <caption>Game Menu</caption>
    </screenshot>
    <screenshot>
      <image>https://forgejo.maledict.me/Maledict/NationsGlory/raw/commit/6be6d53787e918026fd392e47e1a54381ee62296/screenshots/settings.png</image>
      <caption>Launcher settings</caption>
    </screenshot>
  </screenshots>

  <requires>
    <control>keyboard</control>
    <control>pointing</control>
  </requires>

  <releases>
    <release version="5.0.105" date="2025-03-24">
     <description>
       <p>Updated NationsGlory Launcher to 5.0.105</p>
     </description>
    </release>
  </releases>

</component>
