<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>org.legcord.Legcord</id>
  <name>Legcord</name>
  <summary>A lightweight Discord client with built-in mods</summary>
  <launchable type="desktop-id">org.legcord.Legcord.desktop</launchable>
  <project_license>OSL-3.0</project_license>
  <metadata_license>CC0-1.0</metadata_license>
  <developer_name>smartfrigde</developer_name>
  <url type="homepage">https://github.com/Legcord/Legcord</url>
  <url type="bugtracker">https://github.com/Legcord/Legcord/issues</url>
  <url type="help">https://github.com/Legcord/Legcord/wiki</url>
  <url type="translate">https://hosted.weblate.org/projects/Legcord/Legcord/</url>
  <description>
    <p>Legcord is a custom Discord client designed to enhance your Discord experience while keeping everything lightweight.</p>
    <p>Features:</p>
    <ul>
      <li>Standalone client that doesn't rely on the original Discord client</li>
      <li>Built-in mods (Vencord, Equicord, Shelter)</li>
      <li>Native theming support</li>
      <li>Privacy-focused with tracker blocking</li>
      <li>Rich Presence support</li>
      <li>Cross-platform support</li>
    </ul>
  </description>
  <screenshots>
    <screenshot type="default">
      <image>https://raw.githubusercontent.com/Legcord/Legcord/main/assets/screenshots/settings.png</image>
    </screenshot>
    <screenshot>
      <image>https://raw.githubusercontent.com/Legcord/Legcord/main/assets/screenshots/shelter.png</image>
    </screenshot>
    <screenshot>
      <image>https://raw.githubusercontent.com/Legcord/Legcord/main/assets/screenshots/keybinds.png</image>
    </screenshot>
  </screenshots>
  <provides>
    <binary>legcord</binary>
    <mediatype>x-scheme-handler/discord</mediatype>
  </provides>
  <releases>
    <release version="1.2.2" date="2025-03-26"/>
  </releases>
  <content_rating type="oars-1.1">
    <content_attribute id="social-chat">intense</content_attribute>
    <content_attribute id="social-audio">intense</content_attribute>
    <content_attribute id="social-contacts">intense</content_attribute>
  </content_rating>
</component>
