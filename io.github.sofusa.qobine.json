{
  "app-id": "io.github.sofusa.qobine",
  "runtime": "org.gnome.Platform",
  "runtime-version": "50",
  "sdk": "org.gnome.Sdk",
  "sdk-extensions": ["org.freedesktop.Sdk.Extension.rust-stable"],
  "command": "qobuz-player-gtk",

  "finish-args": [
    "--share=network",
    "--share=ipc",
    "--socket=wayland",
    "--socket=fallback-x11",
    "--socket=pulseaudio",
    "--filesystem=xdg-run/gvfsd",
    "--filesystem=xdg-run/gvfs",
    "--own-name=org.mpris.MediaPlayer2.qobuz-player",
    "--device=dri"
  ],

  "modules": [
    {
      "name": "qobuz-player-gtk",
      "buildsystem": "simple",

      "build-options": {
        "append-path": "/usr/lib/sdk/rust-stable/bin",

        "env": {
          "CARGO_HOME": "/run/build/qobuz-player-gtk/cargo"
        }
      },

      "build-commands": [
        "cargo build --offline --locked --release --manifest-path qobuz-player-gtk/Cargo.toml",
        "install -Dm755 ./target/release/qobuz-player-gtk /app/bin/qobuz-player-gtk",

        "install -Dm644 flatpak/icon.svg /app/share/icons/hicolor/scalable/apps/io.github.sofusa.qobine.svg",
        "install -Dm644 flatpak/io.github.sofusa.qobine.desktop /app/share/applications/io.github.sofusa.qobine.desktop",
        "install -Dm644 assets/qobuz-player-gtk.png /app/share/metainfo/qobuz-player-gtk.png",
        "install -Dm644 flatpak/io.github.sofusa.qobine.metainfo.xml /app/share/metainfo/io.github.sofusa.qobine.metainfo.xml"
      ],

      "sources": [
        {
          "type": "git",
          "url": "https://github.com/sofusa/qobine.git",
          "tag": "v0.10.3",
          "commit": "1e632fc4f2b626e1905005d9f5e0814ed2d3745b"
        },
        "cargo-sources.json"
      ]
    }
  ]
}
