#!/bin/bash
set -e

# 1. The filename defined in the manifest 'extra-data' section
ARCHIVE="si.tar.gz"

# 2. Extract the archive
# We assume the tarball contains a folder structure like:
# bin/si
# lib/libgdal.so... (if bundled)
# share/applications/com.fourwindstechnology.SI.desktop
# share/icons/...
echo "Extracting $ARCHIVE..."
tar xf "$ARCHIVE"

# 3. Install the Main Binary
# Adjust 'bin/si' to match the actual path inside your tarball
install -D -m 0755 bin/si /app/bin/si

cp -r bin/share/* /app/bin/share/

# 4. Install Libraries (If your tarball includes bundled libs like VSG/GDAL)
if [ -d "lib" ]; then
    cp -r lib/* /app/lib/
fi

# 6. Clean up
rm "$ARCHIVE"