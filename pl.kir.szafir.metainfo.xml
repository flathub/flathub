<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>pl.kir.szafir</id>
  <name>Szafir</name>
  <summary>Polish qualified electronic signature application</summary>
  <summary xml:lang="pl">Polska aplikacja do obsługi kwalifikowanych podpisów elektronicznych</summary>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>LicenseRef-proprietary=https://www.elektronicznypodpis.pl/</project_license>
  <developer id="pl.com.kir">
    <name>Krajowa Izba Rozliczeniowa S.A.</name>
  </developer>
  <description>
    <!-- unsupported -->
    <p>
      This is a community package of Szafir and not officially supported by KIR.
    </p>
    <p xml:lang="pl">
      Uwaga: Wersja Flatpak nie jest oficjalnie wspierana przez KIR.
    </p>
    <!-- /unsupported -->
    <!-- setup -->
    <p>
      Important setup requirements:
    </p>
    <ul>
      <li>Graphite card library (libCCGraphiteP11.2.0.5.6.so) is located in /app/extra/. On first use, edit your signing profile (Settings), uncheck "use default configuration" in the technical component, and add this library.</li>
      <li>By default, the app only has access to the Documents folder. Use Flatseal to modify file access permissions.</li>
    </ul>
    <p xml:lang="pl">
      Ważne kroki konfiguracyjne:
    </p>
    <ul>
      <li xml:lang="pl">Biblioteka kart Graphite (libCCGraphiteP11.2.0.5.6.so) znajduje się w /app/extra/. Przy pierwszym użyciu edytuj profil (Konfiguracja), odznacz "używaj domyślnej konfiguracji" w komponencie technicznym i wskaż tę bibliotekę.</li>
      <li xml:lang="pl">Domyślnie aplikacja ma dostęp tylko do folderu Dokumenty. Użyj programu Flatseal, aby zmienić uprawnienia dostępu do plików.</li>
    </ul>
    <!-- /setup -->
    <!-- desc -->
    <p>
      Szafir is a desktop application for creating and verifying qualified
      electronic signatures, issued by Krajowa Izba Rozliczeniowa (KIR).
    </p>
    <p xml:lang="pl">
      Szafir to aplikacja komputerowa do składania i weryfikacji kwalifikowanych podpisów elektronicznych, 
      wydana przez Krajową Izbę Rozliczeniową (KIR).
    </p>
    <!-- /desc -->
  </description>
