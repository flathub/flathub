{
    "app-id": "com.storcke64.hts_time",
    "runtime": "org.gnome.Platform",
    "runtime-version": "49",
    "sdk": "org.gnome.Sdk",
    "command": "hts-time",
    "finish-args": [
        "--share=ipc",
        "--socket=wayland",
        "--socket=fallback-x11",
        "--socket=pulseaudio",
        "--device=dri",
        "--share=network",
        "--filesystem=xdg-videos:ro",
        "--talk-name=org.freedesktop.Notifications",
        "--env=GDK_BACKEND=wayland,x11",
        "--env=GTK_USE_PORTAL=1",
        "--env=GST_PLUGIN_PATH=/app/lib/ffmpeg/lib/gstreamer-1.0",
        "--env=LD_LIBRARY_PATH=/app/lib/ffmpeg/lib"
    ],
    "add-extensions": {
        "org.freedesktop.Platform.ffmpeg-full": {
            "directory": "lib/ffmpeg",
            "add-ld-path": "lib",
            "version": "24.08"
        }
    },
    "modules": [
        {
            "name": "ffmpeg-mount-point",
            "buildsystem": "simple",
            "build-commands": [
                "mkdir -p /app/lib/ffmpeg"
            ]
        },
        {
            "name": "libqrencode",
            "buildsystem": "cmake-ninja",
            "config-opts": [
                "-DBUILD_SHARED_LIBS=ON",
                "-DWITH_TOOLS=OFF",
                "-DWITH_TESTS=OFF",
                "-DCMAKE_POLICY_VERSION_MINIMUM=3.5"
            ],
            "sources": [
                {
                    "type": "archive",
                    "url": "https://github.com/fukuchi/libqrencode/archive/refs/tags/v4.1.1.tar.gz",
                    "sha256": "5385bc1b8c2f20f3b91d258bf8ccc8cf62023935df2d2676b5b67049f31a049c"
                }
            ]
        },
        {
            "name": "libmicrohttpd",
            "buildsystem": "autotools",
            "config-opts": [
                "--disable-doc",
                "--disable-examples"
            ],
            "sources": [
                {
                    "type": "archive",
                    "url": "https://ftp.gnu.org/gnu/libmicrohttpd/libmicrohttpd-0.9.77.tar.gz",
                    "sha256": "9e7023a151120060d2806a6ea4c13ca9933ece4eacfc5c9464d20edddb76b0a0"
                }
            ]
        },
        {
            "name": "hts-time",
            "buildsystem": "meson",
            "sources": [
                {
                    "type": "git",
                    "url": "https://github.com/storcke64/hts-time.git",
                    "tag": "A40003.4",
                    "commit": "368a838d0969334e6dc81cf6287b7ed640152e4e"
                }
            ]
        },
        {
            "name": "flathub-metadata",
            "buildsystem": "simple",
            "build-commands": [
                "install -D -m 644 com.storcke64.hts_time.metainfo.xml /app/share/metainfo/com.storcke64.hts_time.metainfo.xml",
                "install -D -m 644 com.storcke64.hts_time.desktop /app/share/applications/com.storcke64.hts_time.desktop"
            ],
            "sources": [
                {
                    "type": "git",
                    "url": "https://github.com/storcke64/hts-time.git",
                    "tag": "A40003.5",
                    "commit": "725d3b8185bb9a6432b1426422f99f583ef16255"
                }
            ]
        }
    ]
}
