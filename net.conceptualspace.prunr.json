{
  "id": "net.conceptualspace.prunr",
  "runtime": "org.freedesktop.Platform",
  "runtime-version": "25.08",
  "sdk": "org.freedesktop.Sdk",
  "base": "org.electronjs.Electron2.BaseApp",
  "base-version": "25.08",
  "command": "run.sh",
  "separate-locales": false,
  "finish-args": [
    "--share=ipc",
    "--socket=x11",
    "--socket=wayland",
    "--device=dri",
    "--env=ELECTRON_TRASH=gio"
  ],
  "modules": [
    {
      "name": "prunr",
      "buildsystem": "simple",
      "sources": [
        {
          "type": "archive",
          "only-arches": ["x86_64"],
          "url": "https://prunr.conceptualspace.net/releases/prunr-linux-x64-1.2.4.tar.gz",
          "sha256": "0ce5217157420c1151c452d771d85ebe49e9ed410292dc157575bff3f78f38cf",
          "dest": "prunr-linux-x64"
        },
        {
          "type": "file",
          "path": "net.conceptualspace.prunr.metainfo.xml"
        },
        {
          "type": "file",
          "path": "net.conceptualspace.prunr.desktop"
        },
        {
          "type": "file",
          "path": "icon-512.png"
        },
        {
          "type": "script",
          "dest-filename": "run.sh",
          "commands": [
            "zypak-wrapper.sh /app/prunr/prunr \"$@\""
          ]
        }
      ],
      "build-commands": [
        "cp -r prunr-linux-x64 /app/prunr",
        "patch-desktop-filename /app/prunr/resources/app.asar net.conceptualspace.prunr",
        "install -Dm644 net.conceptualspace.prunr.metainfo.xml /app/share/metainfo/net.conceptualspace.prunr.metainfo.xml",
        "install -Dm644 net.conceptualspace.prunr.desktop /app/share/applications/net.conceptualspace.prunr.desktop",
        "install -Dm644 icon-512.png /app/share/icons/hicolor/512x512/apps/net.conceptualspace.prunr.png",
        "install -Dm755 run.sh /app/bin/run.sh"
      ]
    }
  ]
}
