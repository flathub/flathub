<component type="desktop-application">
  <id>com.alegralabs.AccessFlair</id>
  
  <name>AccessFlair</name>
  <summary>Remote Desktop Application</summary>
  
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>MIT</project_license>
  
  <description>
    <p>
      AccessFlair is a high-performance remote desktop application designed to provide
      seamless access to your computer from anywhere. It offers low-latency screen sharing,
      remote input control, and file transfer capabilities.
    </p>
    <p>Features include:</p>
    <ul>
      <li>High-quality screen sharing with low latency</li>
      <li>Secure remote input control (keyboard and mouse)</li>
      <li>Cross-platform support</li>
      <li>Easy-to-use interface</li>
    </ul>
  </description>
  
  <launchable type="desktop-id">com.alegralabs.AccessFlair.desktop</launchable>
  
