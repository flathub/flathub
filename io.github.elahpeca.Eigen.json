{
    "id" : "io.github.elahpeca.Eigen",
    "runtime" : "org.gnome.Platform",
    "runtime-version" : "49",
    "sdk" : "org.gnome.Sdk",
    "command" : "eigen",
    "finish-args" : [
        "--share=ipc",
        "--socket=fallback-x11",
        "--device=dri",
        "--socket=wayland"
    ],
    "cleanup" : [
        "/include",
        "/lib/pkgconfig",
        "/man",
        "/share/doc",
        "/share/gtk-doc",
        "/share/man",
        "/share/pkgconfig",
        "*.la",
        "*.a"
    ],
    "modules" : [
    "python3-requirements.json",
        {
            "name" : "Eigen",
            "builddir" : true,
            "buildsystem" : "meson",
            "sources" : [
                    {
                        "type" : "git",
                        "url" : "https://github.com/elahpeca/Eigen.git",
                        "tag" : "v1.0.0",
                        "commit" : "ebfe7e05878f96583a263df0f67f1759f38d7761"
                    }
            ]
        }
    ]
}
