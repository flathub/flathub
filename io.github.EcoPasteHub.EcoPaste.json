{
  "app-id": "io.github.EcoPasteHub.EcoPaste",
  "runtime": "org.gnome.Platform",
  "runtime-version": "48",
  "sdk": "org.gnome.Sdk",
  "command": "EcoPaste",
  "finish-args": [
    "--share=ipc",
    "--socket=fallback-x11",
    "--socket=wayland",
    "--device=dri",
    "--share=network"
  ],
  "publish-delay-hours": 1,
  "only-architecture": [
    "amd64"
  ],
  "modules": [
    {
      "name": "eco-paste",
      "buildsystem": "simple",
      "build-commands": [
        "ar x EcoPaste_0.5.0_amd64.deb",
        "tar -xzf data.tar.gz",
        "install -Dm755 usr/bin/EcoPaste /app/bin/EcoPaste",
        "cp -r usr/lib/EcoPaste /app/lib/",
        "desktop-file-edit --set-icon=io.github.EcoPasteHub.EcoPaste usr/share/applications/EcoPaste.desktop",
        "install -Dm644 usr/share/applications/EcoPaste.desktop /app/share/applications/io.github.EcoPasteHub.EcoPaste.desktop",
        "mv usr/share/icons/hicolor/256x256@2 usr/share/icons/hicolor/256x256_2",
        "mkdir -p /app/share/icons/hicolor/128x128/apps /app/share/icons/hicolor/256x256_2/apps /app/share/icons/hicolor/32x32/apps",
        "cp -r usr/share/icons/hicolor/* /app/share/icons/hicolor/",
        "install -Dm644 /app/share/icons/hicolor/128x128/apps/EcoPaste.png /app/share/icons/hicolor/128x128/apps/io.github.EcoPasteHub.EcoPaste.png",
        "install -Dm644 /app/share/icons/hicolor/256x256_2/apps/EcoPaste.png /app/share/icons/hicolor/256x256_2/apps/io.github.EcoPasteHub.EcoPaste.png",
        "install -Dm644 /app/share/icons/hicolor/32x32/apps/EcoPaste.png /app/share/icons/hicolor/32x32/apps/io.github.EcoPasteHub.EcoPaste.png"
      ],
      "sources": [
        {
          "type": "file",
          "url": "https://github.com/EcoPasteHub/EcoPaste/releases/download/v0.5.0/EcoPaste_0.5.0_amd64.deb",
          "sha256": "fba410c5be10f0a00fa1a7ea0e1ff88b2174ebc1b626901884aec0c1fc0f70c6"
        }
      ]
    }
  ]
}
