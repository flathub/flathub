<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>com.gryt.Chat</id>
  <name>Gryt Chat</name>
  <summary>Real-time voice chat</summary>
  <developer id="com.gryt">
    <name>Gryt Chat</name>
  </developer>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>AGPL-3.0-or-later</project_license>

  <description>
    <p>
      Gryt is a self-hostable, real-time voice and text chat application.
      Host your own server and connect with friends, teammates, or communities
      with low-latency WebRTC audio, screen sharing, and text channels.
    </p>
    <p>Features:</p>
    <ul>
      <li>Crystal-clear voice chat powered by WebRTC with Opus codec</li>
      <li>Screen sharing with audio capture</li>
      <li>Text chat with Markdown, mentions, and file sharing</li>
      <li>Self-hostable — run your own server with Docker Compose</li>
      <li>LAN server discovery via mDNS</li>
      <li>Global push-to-talk with configurable keybinds</li>
      <li>RNNoise-based noise suppression</li>
      <li>Auto-updates</li>
    </ul>
  </description>

  <url type="homepage">https://gryt.chat</url>
  <url type="bugtracker">https://github.com/Gryt-chat/gryt/issues</url>
  <url type="vcs-browser">https://github.com/Gryt-chat/gryt</url>
  <url type="help">https://docs.gryt.chat</url>

  <launchable type="desktop-id">com.gryt.Chat.desktop</launchable>

  <screenshots>
    <screenshot type="default">
      <caption>Voice chat with multiple users connected</caption>
      <image>https://gryt.chat/blog/gryt-preview.webp</image>
    </screenshot>
    <screenshot>
      <caption>Full server view with channels, chat, and voice</caption>
      <image>https://gryt.chat/blog/gryt-first-draft-preview.webp</image>
    </screenshot>
    <screenshot>
      <caption>Server browser for discovering communities</caption>
      <image>https://gryt.chat/blog/gryt-server-browser.webp</image>
    </screenshot>
  </screenshots>

  <branding>
    <color type="primary" scheme_preference="light">#f0f0f0</color>
    <color type="primary" scheme_preference="dark">#1a1a2e</color>
  </branding>

  <content_rating type="oars-1.1">
    <content_attribute id="social-chat">intense</content_attribute>
    <content_attribute id="social-audio">intense</content_attribute>
  </content_rating>

  <categories>
    <category>Network</category>
    <category>Chat</category>
    <category>InstantMessaging</category>
  </categories>

  <keywords>
    <keyword>voice</keyword>
    <keyword>chat</keyword>
    <keyword>voip</keyword>
    <keyword>webrtc</keyword>
    <keyword>self-hosted</keyword>
    <keyword>discord</keyword>
    <keyword>teamspeak</keyword>
  </keywords>

  <requires>
    <display_length compare="ge">768</display_length>
  </requires>

  <supports>
    <control>pointing</control>
    <control>keyboard</control>
  </supports>

  <releases>
    <release version="1.0.131" date="2026-03-01">
      <description>
        <p>Latest release with bug fixes and improvements.</p>
      </description>
    </release>
  </releases>
</component>
