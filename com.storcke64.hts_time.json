{
    "app-id": "com.storcke64.hts_time",
    "runtime": "org.gnome.Platform",
    "runtime-version": "49",
    "sdk": "org.gnome.Sdk",
    "command": "hts-time",
    "finish-args": [
        "--share=ipc",
        "--socket=fallback-x11",
        "--socket=wayland",
        "--socket=x11",
        "--socket=pulseaudio",
        "--device=dri",
        "--share=network",
        "--filesystem=xdg-videos:ro",
        "--filesystem=xdg-videos:create",
        "--talk-name=org.freedesktop.Notifications",
        "--env=GDK_BACKEND=wayland,x11",
        "--env=GTK_USE_PORTAL=1",
        "--env=GST_PLUGIN_PATH=/app/lib/ffmpeg/lib/gstreamer-1.0:/usr/lib/x86_64-linux-gnu/gstreamer-1.0:/usr/lib/gstreamer-1.0",
        "--env=LD_LIBRARY_PATH=/app/lib/ffmpeg/lib",
        "--env=WEBKIT_FORCE_SANDBOX=0"
    ],
    "add-extensions": {
        "org.freedesktop.Platform.ffmpeg-full": {
            "directory": "lib/ffmpeg",
            "add-ld-path": "lib",
            "version": "24.08"
        }
    },
    "modules": [
        {
            "name": "rsync",
            "buildsystem": "autotools",
            "config-opts": [
                "--disable-lz4",
                "--disable-zstd",
                "--disable-xxhash",
                "--disable-openssl",
                "--disable-debug"
            ],
            "sources": [
                {
                    "type": "archive",
                    "url": "https://download.samba.org/pub/rsync/src/rsync-3.4.1.tar.gz",
                    "sha256": "2924bcb3a1ed8b551fc101f740b9f0fe0a202b115027647cf69850d65fd88c52"
                }
            ]
        },
        {
            "name": "libqrencode",
            "buildsystem": "cmake-ninja",
            "config-opts": [
                "-DBUILD_SHARED_LIBS=ON",
                "-DWITH_TOOLS=OFF",
                "-DWITH_TESTS=OFF",
                "-DCMAKE_POLICY_VERSION_MINIMUM=3.5"
            ],
            "sources": [
                {
                    "type": "archive",
                    "url": "https://github.com/fukuchi/libqrencode/archive/refs/tags/v4.1.1.tar.gz",
                    "sha256": "5385bc1b8c2f20f3b91d258bf8ccc8cf62023935df2d2676b5b67049f31a049c"
                }
            ]
        },
        {
            "name": "libmicrohttpd",
            "buildsystem": "autotools",
            "config-opts": [
                "--disable-doc",
                "--disable-examples"
            ],
            "sources": [
                {
                    "type": "archive",
                    "url": "https://ftp.gnu.org/gnu/libmicrohttpd/libmicrohttpd-0.9.77.tar.gz",
                    "sha256": "9e7023a151120060d2806a6ea4c13ca9933ece4eacfc5c9464d20edddb76b0a0"
                }
            ]
        },
        {
            "name": "hts-time",
            "buildsystem": "meson",
            "sources": [
                {
                    "type": "git",
                    "url": "https://github.com/storcke64/hts-time.git",
                    "branch": "main"
                }
            ]
        },
        {
            "name": "ffmpeg-mount-point",
            "buildsystem": "simple",
            "build-commands": [
                "mkdir -p /app/lib/ffmpeg"
            ]
        },
        {
            "name": "flathub-metadata",
            "buildsystem": "simple",
            "build-commands": [
                "install -D -m 644 com.storcke64.hts_time.metainfo.xml /app/share/metainfo/com.storcke64.hts_time.metainfo.xml",
                "install -D -m 644 com.storcke64.hts_time.desktop /app/share/applications/com.storcke64.hts_time.desktop"
            ],
            "sources": [
                {
                    "type": "git",
                    "url": "https://github.com/storcke64/hts-time.git",
                    "branch": "main"
                }
            ]
        }
    ]
}
