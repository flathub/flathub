<component type="desktop-application">
  <id>vn.suika3.engine</id>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>Zlib</project_license>

  <name>Suika3</name>
  <summary>A portable 2D game engine with a DSL for visual novels</summary>

  <launchable type="desktop-id">vn.suika3.engine.desktop</launchable>

  <developer id="vn.suika3">
    <name>Awe Morris / SCHOLA SUIKAE</name>
  </developer>

  <description>
    <p>
      Suika3 is a high-performance, mobile-first 2D game engine designed for
      visual novels. It focuses on portability, written in C89 to ensure
      long-term maintenance and compatibility.
    </p>
    <p>
      Note: This is a game engine runtime. To run a game, you need to provide
      a game directory as an argument.
    </p>
    <ul>
      <li>Target: Mobile-first, yet runs anywhere including Linux</li>
      <li>High-Performance: Native, written in C</li>
      <li>Hybrid Scripting: JIT VM with AOT fallback for App Store compliance</li>
      <li>Broad Platforms: Desktop, mobile, and game consoles</li>
    </ul>
  </description>

  <categories>
    <category>Development</category>
    <category>Game</category>
  </categories>

  <keywords>
    <keyword>game</keyword>
    <keyword>visual novel</keyword>
  </keywords>

  <icon type="stock">vn.suika3.engine</icon>
  <icon type="remote">https://raw.githubusercontent.com/awemorris/suika3/refs/heads/main/docs/img/logo-small.png</icon>

  <branding>
    <color type="primary" scheme_preference="light">#ff00ff</color>
    <color type="primary" scheme_preference="dark">#993d3d</color>
  </branding>

  <content_rating type="oars-1.1" />

  <url type="homepage">https://suika3.vn/</url>
  <url type="bugtracker">https://github.com/awemorris/suika3/issues</url>

  <screenshots>
    <screenshot type="default">
      <caption>The Suika3 engine running a sample script</caption>
      <image>https://raw.githubusercontent.com/awemorris/suika3/refs/heads/main/docs/img/screenshot-20260406.webp</image>
    </screenshot>
  </screenshots>

  <provides>
    <mediatype>
      <mimetype>application/x-novelml</mimetype>
      <mimetype>application/x-rayscript</mimetype>
    </mediatype>
  </provides>

  <supports>
    <control>keyboard</control>
    <control>pointing</control>
    <control>gamepad</control>
  </supports>

  <requires>
    <control>keyboard</control>
    <control>pointing</control>
    <display_length compare="ge">768</display_length>
  </requires>

  <releases>
    <release version="26.04.20" date="2026-04-25">
      <description>
        <p>26.04 is the first public version.</p>
      </description>
    </release>
  </releases>

</component>
