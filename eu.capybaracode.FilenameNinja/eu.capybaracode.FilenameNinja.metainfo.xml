<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>eu.capybaracode.FilenameNinja</id>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>MIT</project_license>
  <name>Filename Ninja</name>
  <summary>Batch rename files and folders safely with preview and regex support</summary>

  <developer id="eu.capybaracode">
    <name>Zbyněk Šťáva</name>
  </developer>

  <launchable type="desktop-id">eu.capybaracode.FilenameNinja.desktop</launchable>

  <url type="homepage">https://capybaracode.eu/filename-ninja/</url>
  <url type="bugtracker">https://gitlab.com/capybara-code/filename-ninja/-/issues</url>
  <url type="vcs-browser">https://gitlab.com/capybara-code/filename-ninja/</url>
  <url type="help">https://capybaracode.eu/filename-ninja/help.html</url>

  <description>
    <p>
      Filename Ninja is a cross-platform desktop application for safe, bulk file
      renaming. It supports previews, regex-powered workflows, case conversion,
      numbering, Unicode filenames, and conflict-aware operations.
    </p>
  </description>

  <categories>
    <category>Utility</category>
    <category>FileTools</category>
  </categories>

  <keywords>
    <keyword>rename</keyword>
    <keyword>batch</keyword>
    <keyword>regex</keyword>
    <keyword>files</keyword>
    <keyword>gui</keyword>
  </keywords>

  <screenshots>
    <screenshot type="default">
      <image>https://capybaracode.eu/filename-ninja/images/help_main_window.png</image>
