{
    "app-id": "com.alegralabs.AccessFlair",
    "runtime": "org.freedesktop.Platform",
    "runtime-version": "23.08",
    "sdk": "org.freedesktop.Sdk",
    "base": "org.electronjs.Electron2.BaseApp",
    "base-version": "23.08",
    "command": "accessflair",
    "separate-locales": false,
    "finish-args": [
        "--share=ipc",
        "--share=network",
        "--socket=x11",
        "--socket=wayland",
        "--socket=pulseaudio",
        "--device=all",
        "--filesystem=xdg-download",
        "--talk-name=org.freedesktop.Notifications",
        "--talk-name=org.kde.StatusNotifierWatcher"
    ],
    "modules": [
        {
            "name": "accessflair",
            "buildsystem": "simple",
            "build-commands": [
                "ar x accessflair.deb",
                "tar xf data.tar.xz",
                "mv opt/AccessFlair /app/bin/accessflair-bin",
                "install -D usr/share/icons/hicolor/0x0/apps/accessflair.png /app/share/icons/hicolor/512x512/apps/com.alegralabs.AccessFlair.png",
                "ln -s /app/bin/accessflair-bin/accessflair /app/bin/accessflair",
                "install -D com.alegralabs.AccessFlair.metainfo.xml /app/share/metainfo/com.alegralabs.AccessFlair.metainfo.xml",
                "install -D com.alegralabs.AccessFlair.desktop /app/share/applications/com.alegralabs.AccessFlair.desktop"
            ],
            "sources": [
                {
                    "type": "file",
                    "path": "com.alegralabs.AccessFlair.metainfo.xml"
                },
                {
                    "type": "file",
                    "path": "com.alegralabs.AccessFlair.desktop"
                },
                {
                    "type": "file",
                    "url": "https://github.com/jay3000bc/AccessFlair_app/releases/download/v1.0.0/accessflair_1.0.0_amd64.deb",
                    "dest-filename": "accessflair.deb",
                    "sha256": "842e8d59545501fe7c703ccc22c2002305a7931256765924f4646bb7b092a120"
                }
            ]
        }
    ]
}