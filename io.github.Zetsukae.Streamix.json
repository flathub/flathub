{
  "app-id": "io.github.Zetsukae.Streamix",
  "runtime": "org.freedesktop.Platform",
  "runtime-version": "24.08",
  "sdk": "org.freedesktop.Sdk",
  "sdk-extensions": [
    "org.freedesktop.Sdk.Extension.node20"
  ],
  "base": "org.electronjs.Electron2.BaseApp",
  "base-version": "24.08",
  "command": "streamix",
  "separate-locales": false,
  "finish-args": [
    "--share=ipc",
    "--device=dri",
    "--socket=wayland",
    "--socket=fallback-x11",
    "--socket=pulseaudio",
    "--share=network",
    "--talk-name=org.freedesktop.Notifications",
    "--talk-name=org.kde.StatusNotifierWatcher",
    "--filesystem=xdg-download"
  ],
  "modules": [
    {
      "name": "streamix",
      "buildsystem": "simple",
      "build-options": {
        "append-path": "/usr/lib/sdk/node20/bin",
        "env": {
          "npm_config_nodedir": "/usr/lib/sdk/node20",
          "npm_config_cache": "flatpak-node/npm-cache",
          "ELECTRON_CACHE": "flatpak-node/cache/electron",
          "ELECTRON_BUILDER_CACHE": "flatpak-node/cache/electron-builder"
        }
      },
      "build-commands": [
        ". flatpak-node/electron-builder-arch-args.sh",
        "npm install --offline",
        "npm run build -- --linux --dir ${ELECTRON_BUILDER_ARCH_ARGS}",
        "cp -r dist/linux*-unpacked /app/streamix",
        "ln -sf /app/streamix/streamix /app/bin/streamix",
        "install -D flatpak-utilities/io.github.Zetsukae.Streamix.desktop /app/share/applications/io.github.Zetsukae.Streamix.desktop",
        "install -D flatpak-utilities/io.github.Zetsukae.Streamix.metainfo.xml /app/share/metainfo/io.github.Zetsukae.Streamix.metainfo.xml",
        "install -D flatpak-utilities/icons/512x512.png /app/share/icons/hicolor/512x512/apps/io.github.Zetsukae.Streamix.png"
      ],
      "sources": [
        "generated-sources.json",
        {
          "type": "git",
          "url": "https://github.com/Zetsukae/streamix.git",
          "tag": "v1.0.0",
          "commit": "f4dbc917a92d3c63210756a8cec5db0502881712"
        },
        {
          "type": "script",
          "dest-filename": "streamix.sh",
          "commands": [
            "exec zypak-wrapper /app/streamix/streamix --ozone-platform-hint=auto \"$@\""
          ]
        }
      ]
    }
  ]
}
