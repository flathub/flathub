{
  "app-id": "io.github.Zetsukae.Streamix",
  "runtime": "org.freedesktop.Platform",
  "runtime-version": "25.08",
  "sdk": "org.freedesktop.Sdk",
  "base": "org.electronjs.Electron2.BaseApp",
  "base-version": "25.08",
  "command": "streamix",
  "separate-locales": false,
  "finish-args": [
    "--share=ipc",
    "--device=dri",
    "--socket=wayland",
    "--socket=fallback-x11",
    "--socket=pulseaudio",
    "--share=network",
    "--filesystem=xdg-download"
  ],
  "modules": [
    "generated-sources.json",
    {
      "name": "streamix",
      "buildsystem": "simple",
      "build-options": {
        "env": {
          "npm_config_nodedir": "/usr/lib/sdk/node20"
        }
      },
      "build-commands": [
        "npm install --offline",
        "npm run build -- --linux --dir",
        "cp -r dist/linux-unpacked /app/main",
        "install -D streamix.sh /app/bin/streamix",
        "install -D -m0644 io.github.Zetsukae.Streamix.desktop /app/share/applications/io.github.Zetsukae.Streamix.desktop",
        "install -D -m0644 io.github.Zetsukae.Streamix.metainfo.xml /app/share/metainfo/io.github.Zetsukae.Streamix.metainfo.xml",
        "install -D -m0644 icon.png /app/share/icons/hicolor/512x512/apps/io.github.Zetsukae.Streamix.png"
      ],
      "sources": [
        {
          "type": "git",
          "url": "https://github.com/Zetsukae/streamix.git",
          "branch": "main"
        },
        {
          "type": "script",
          "dest-filename": "streamix.sh",
          "commands": [
            "exec zypak-wrapper /app/main/streamix --ozone-platform-hint=auto \"$@\""
          ]
        },
        {
          "type": "file",
          "url": "https://github.com/Zetsukae/streamix/releases/download/STABLE-Streamix-1.0.0-FLATHUB/icon.png",
          "sha256": "4872d7e69e40ab0a5bfb2421b9215133b3302369ba6642a1c8c4be46fec496ac",
          "dest-filename": "icon.png"
        },
        {
          "type": "file",
          "url": "https://github.com/Zetsukae/streamix/releases/download/STABLE-Streamix-1.0.0-FLATHUB/io.github.Zetsukae.Streamix.desktop",
          "sha256": "361d09451f914331c29ab61e99672b9818dfb83294515165005222031e7ba772",
          "dest-filename": "io.github.Zetsukae.Streamix.desktop"
        },
        {
          "type": "file",
          "url": "https://github.com/Zetsukae/streamix/releases/download/STABLE-Streamix-1.0.0-FLATHUB/io.github.Zetsukae.Streamix.metainfo.xml",
          "sha256": "e7c7709d797849f65870514ad236e6ba588757aa4f9f6afff3cdf8007723c720",
          "dest-filename": "io.github.Zetsukae.Streamix.metainfo.xml"
        }
      ]
    }
  ]
}
