{
  "app-id": "io.github.Zetsukae.Streamix",
  "runtime": "org.freedesktop.Platform",
  "runtime-version": "24.08",
  "sdk": "org.freedesktop.Sdk",
  "base": "org.electronjs.Electron2.BaseApp",
  "base-version": "24.08",
  "command": "streamix",
  "separate-locales": false,
  "finish-args": [
    "--share=ipc",
    "--device=dri",
    "--socket=wayland",
    "--socket=fallback-x11",
    "--socket=pulseaudio",
    "--share=network",
    "--filesystem=xdg-download"
  ],
  "modules": [
    {
      "name": "streamix",
      "buildsystem": "simple",
      "build-commands": [
        "cp -r * /app/main/",
        "install -D streamix.sh /app/bin/streamix",
        "install -D -m0644 io.github.Zetsukae.Streamix.desktop /app/share/applications/io.github.Zetsukae.Streamix.desktop",
        "install -D -m0644 io.github.Zetsukae.Streamix.metainfo.xml /app/share/metainfo/io.github.Zetsukae.Streamix.metainfo.xml",
        "install -D -m0644 icon.png /app/share/icons/hicolor/512x512/apps/io.github.Zetsukae.Streamix.png"
      ],
      "sources": [
        {
          "type": "archive",
          "url": "https://github.com/Zetsukae/streamix/releases/download/STABLE-Streamix-1.0.0-FLATHUB/streamix-1.0.0.tar.gz",
          "sha256": "7ad4cfec008f141d1a0eae307831f1de05cba11b6a89dd16a7838e6eaf100cd3"
        },
        {
          "type": "file",
          "url": "https://raw.githubusercontent.com/Zetsukae/streamix/42ae3e78136291eab39a021c70c82a235f56ef67/assets/icon.png",
          "sha256": "4872d7e69e40ab0a5bfb2421b9215133b3302369ba6642a1c8c4be46fec496ac",
          "dest-filename": "icon.png"
        },
        {
          "type": "script",
          "dest-filename": "streamix.sh",
          "commands": [
            "exec zypak-wrapper /app/main/streamix \"$@\""
          ]
        },
        {
          "type": "script",
          "dest-filename": "io.github.Zetsukae.Streamix.desktop",
          "commands": [
            "cat <<EOF > io.github.Zetsukae.Streamix.desktop",
            "[Desktop Entry]",
            "Name=Streamix",
            "Comment=Centralisez vos streamings",
            "Exec=streamix",
            "Icon=io.github.Zetsukae.Streamix",
            "Type=Application",
            "Categories=Utility;AudioVideo;",
            "StartupWMClass=streamix",
            "EOF"
          ]
        },
        {
          "type": "script",
          "dest-filename": "io.github.Zetsukae.Streamix.metainfo.xml",
          "commands": [
            "cat <<EOF > io.github.Zetsukae.Streamix.metainfo.xml",
            "<?xml version=\"1.0\" encoding=\"UTF-8\"?>",
            "<component type=\"desktop-application\">",
            "  <id>io.github.Zetsukae.Streamix</id>",
            "  <name>Streamix</name>",
            "  <summary>Application de streaming centralisé</summary>",
            "  <metadata_license>CC0-1.0</metadata_license>",
            "  <project_license>MIT</project_license>",
            "  <description>",
            "    <p>Streamix vous permet de regrouper vos sources de streaming (GitHub Pages, Anime-Sama, etc.) dans une interface unifiée et immersive.</p>",
            "  </description>",
            "  <launchable type=\"desktop-id\">io.github.Zetsukae.Streamix.desktop</launchable>",
            "  <screenshots>",
            "    <screenshot type=\"default\">",
            "      <image>https://raw.githubusercontent.com/Zetsukae/streamix/42ae3e78136291eab39a021c70c82a235f56ef67/assets/icon.png</image>",
            "    </screenshot>",
            "  </screenshots>",
            "  <releases>",
            "    <release version=\"1.0.0\" date=\"2025-02-09\"/>",
            "  </releases>",
            "  <content_rating type=\"oars-1.1\"/>",
            "</component>",
            "EOF"
          ]
        }
      ]
    }
  ]
}
